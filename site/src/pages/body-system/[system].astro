---
import Base from '@/layouts/Base.astro';
import { getBodySystemDetail, formatCurrency, formatCurrencyFull, slugify } from '@/lib/api';

const { system } = Astro.params;
if (!system) return Astro.redirect('/body-system/');

const data = await getBodySystemDetail(system);
if (!data || (!data.procedures?.length && !data.conditions?.length)) {
  return Astro.redirect('/body-system/');
}

const bodySystem = data.bodySystem;
const procedures = data.procedures || [];
const conditions = data.conditions || [];
const drugs = data.drugs || [];
const stats = data.stats || {};

// Group procedures by category
const byCategory: Record<string, any[]> = {};
for (const proc of procedures) {
  const cat = proc.category || 'Other';
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(proc);
}
const sortedCategories = Object.entries(byCategory).sort((a, b) => b[1].length - a[1].length);

// Top 20 most expensive procedures
const topExpensive = [...procedures].filter((p: any) => p.nationalFacilityRate).sort((a: any, b: any) => b.nationalFacilityRate - a.nationalFacilityRate).slice(0, 20);

// Drug name helper
function drugDisplayName(desc: string): string {
  return desc.split(' ').map((w: string, i: number) => {
    if (i === 0) return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
    if (/^\d/.test(w) || ['MG', 'ML', 'MCG', 'TAB', 'CAP', 'TABLET', 'CAPSULE'].includes(w.toUpperCase())) return w;
    return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
  }).join(' ');
}

// Unique drugs by base name
const uniqueDrugs: any[] = [];
const seenDrugBases = new Set<string>();
for (const d of drugs) {
  const baseName = d.drugName?.split(/\s+\d/)[0]?.trim()?.toLowerCase();
  if (baseName && !seenDrugBases.has(baseName)) {
    seenDrugBases.add(baseName);
    uniqueDrugs.push(d);
  }
}

const title = `${bodySystem} Medical Costs — Procedures, Conditions & Treatments | MedicalCosts.info`;
const description = `Complete guide to ${bodySystem.toLowerCase()} medical costs. ${stats.totalProcedures} procedures averaging ${formatCurrency(stats.avgCost)}. Browse conditions, treatments, and medication costs for the ${bodySystem.toLowerCase()} system.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": `${bodySystem} Medical Costs`,
  "about": { "@type": "AnatomicalSystem", "name": bodySystem },
  "description": description,
};
---

<Base title={title} description={description} canonical={`/body-system/${system}/`} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/body-system/" class="hover:text-brand-600">Body Systems</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">{bodySystem}</span>
    </nav>

    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        <!-- Header -->
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
            {bodySystem} Medical Costs
          </h1>
          <p class="text-lg text-gray-600">
            Procedures, conditions, and treatments for the {bodySystem.toLowerCase()} system.
            Browse {stats.totalProcedures} procedures with Medicare rates and commercial insurance estimates.
          </p>
        </div>

        <!-- Stats Cards -->
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="bg-white rounded-xl border-2 border-brand-300 p-5">
            <div class="text-sm text-gray-500 mb-1">Total Procedures</div>
            <div class="text-3xl font-bold text-brand-700">{stats.totalProcedures}</div>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-sm text-gray-500 mb-1">Average Medicare Rate</div>
            <div class="text-2xl font-bold text-gray-900">{formatCurrencyFull(stats.avgCost)}</div>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-sm text-gray-500 mb-1">Related Conditions</div>
            <div class="text-2xl font-bold text-gray-900">{conditions.length}</div>
          </div>
        </div>

        <!-- Most Expensive Procedures -->
        {topExpensive.length > 0 && (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
              <h2 class="text-xl font-bold text-gray-900">Most Expensive {bodySystem} Procedures</h2>
              <p class="text-sm text-gray-500">Top procedures by Medicare reimbursement rate</p>
            </div>
            <div class="divide-y divide-gray-100">
              {topExpensive.map((proc: any, i: number) => (
                <a href={`/costs/${proc.slug || proc.code}/`} class="flex items-center justify-between px-6 py-3 hover:bg-gray-50 transition-colors group">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <span class="text-xs text-gray-400 w-6 flex-shrink-0">#{i + 1}</span>
                      <span class="text-sm font-medium text-brand-600 group-hover:underline truncate">
                        {proc.description}
                      </span>
                    </div>
                    <div class="text-xs text-gray-400 ml-8">CPT {proc.code} &middot; {proc.category}</div>
                  </div>
                  <div class="text-right flex-shrink-0 ml-4">
                    <div class="text-sm font-bold text-gray-900">{formatCurrencyFull(proc.nationalFacilityRate)}</div>
                    <div class="text-xs text-gray-400">Medicare</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Procedures by Category -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">{bodySystem} Procedures by Category</h2>
          <div class="space-y-4">
            {sortedCategories.slice(0, 15).map(([category, procs]) => (
              <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-gray-50 transition-colors">
                  <div>
                    <h3 class="font-semibold text-gray-900">{category}</h3>
                    <span class="text-sm text-gray-500">{procs.length} procedure{procs.length !== 1 ? 's' : ''}</span>
                  </div>
                  <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="border-t divide-y divide-gray-50">
                  {procs.slice(0, 30).map((proc: any) => (
                    <a href={`/costs/${proc.slug || proc.code}/`} class="flex items-center justify-between px-6 py-2.5 hover:bg-gray-50 transition-colors">
                      <div class="flex-1 min-w-0">
                        <span class="text-sm text-brand-600 hover:underline">{proc.description}</span>
                        <span class="text-xs text-gray-400 ml-2">CPT {proc.code}</span>
                      </div>
                      {proc.nationalFacilityRate && (
                        <span class="text-sm font-semibold text-gray-900 flex-shrink-0 ml-4">{formatCurrencyFull(proc.nationalFacilityRate)}</span>
                      )}
                    </a>
                  ))}
                  {procs.length > 30 && (
                    <div class="px-6 py-2 text-sm text-gray-500">
                      + {procs.length - 30} more procedures
                    </div>
                  )}
                </div>
              </details>
            ))}
          </div>
        </div>

        <!-- Conditions -->
        {conditions.length > 0 && (
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{bodySystem} Conditions</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {conditions.map((c: any) => (
                <a href={`/conditions/${c.slug}/`} class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow transition-all group">
                  <h3 class="font-semibold text-brand-700 group-hover:underline">{c.name}</h3>
                  {c.description && <p class="text-sm text-gray-500 mt-1 line-clamp-2">{c.description}</p>}
                  {c.moderateCostLow && (
                    <div class="mt-2 text-sm">
                      <span class="text-gray-500">Typical cost: </span>
                      <span class="font-semibold text-gray-900">{formatCurrency(c.moderateCostLow)} — {formatCurrency(c.moderateCostHigh)}</span>
                    </div>
                  )}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Related Medications -->
        {uniqueDrugs.length > 0 && (
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Medications for {bodySystem} Conditions</h2>
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <div class="divide-y divide-gray-100">
                {uniqueDrugs.slice(0, 20).map((d: any) => (
                  <a href={`/drugs/${d.drugCode}/`} class="flex items-center justify-between px-6 py-3 hover:bg-gray-50 transition-colors">
                    <div class="flex-1 min-w-0">
                      <span class="text-sm font-medium text-brand-600">{drugDisplayName(d.drugName)}</span>
                      <div class="text-xs text-gray-400 mt-0.5">
                        {d.drugCategory?.includes('Brand') ? 'Brand' : 'Generic'}
                        {d.conditionSlug && (
                          <span> &middot; For {d.conditionSlug.replace(/-/g, ' ')}</span>
                        )}
                      </div>
                    </div>
                    {d.nadacPerUnit && (
                      <div class="text-right flex-shrink-0 ml-4">
                        <span class="text-sm font-semibold text-gray-900">${d.nadacPerUnit < 1 ? d.nadacPerUnit.toFixed(4) : d.nadacPerUnit.toFixed(2)}</span>
                        <span class="text-xs text-gray-400 block">per unit</span>
                      </div>
                    )}
                  </a>
                ))}
              </div>
            </div>
          </div>
        )}

        <!-- FAQ -->
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
          <div class="space-y-4">
            <div>
              <h3 class="font-semibold text-gray-900">What is the average cost of {bodySystem.toLowerCase()} procedures?</h3>
              <p class="text-gray-600 text-sm mt-1">
                The average Medicare rate for {bodySystem.toLowerCase()} procedures is {formatCurrencyFull(stats.avgCost)}.
                Costs range from {formatCurrency(procedures[procedures.length - 1]?.nationalFacilityRate || 0)} to
                {formatCurrency(procedures[0]?.nationalFacilityRate || 0)} depending on complexity.
                Commercial insurance typically pays 150-250% of these Medicare rates.
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">How many {bodySystem.toLowerCase()} conditions are tracked?</h3>
              <p class="text-gray-600 text-sm mt-1">
                We track {conditions.length} {bodySystem.toLowerCase()} conditions with detailed cost breakdowns,
                treatment timelines, and related procedures. Each condition page includes severity-based cost estimates.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="bg-brand-50 rounded-xl p-6 border border-brand-200 sticky top-20">
          <h3 class="font-bold text-brand-900 mb-3">{bodySystem} System</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-gray-500">Total Procedures</dt>
              <dd class="font-semibold">{stats.totalProcedures}</dd>
            </div>
            <div>
              <dt class="text-gray-500">Related Conditions</dt>
              <dd class="font-semibold">{conditions.length}</dd>
            </div>
            <div>
              <dt class="text-gray-500">Related Medications</dt>
              <dd class="font-semibold">{uniqueDrugs.length}</dd>
            </div>
            <div>
              <dt class="text-gray-500">Avg Medicare Rate</dt>
              <dd class="font-bold text-brand-700">{formatCurrencyFull(stats.avgCost)}</dd>
            </div>
            {stats.maxCostProcedure && (
              <div>
                <dt class="text-gray-500">Most Expensive</dt>
                <dd class="text-xs">
                  <a href={`/costs/${stats.maxCostProcedure.slug || stats.maxCostProcedure.code}/`} class="text-brand-600 hover:underline">
                    {stats.maxCostProcedure.description}
                  </a>
                  <div class="font-bold text-red-600">{formatCurrencyFull(stats.maxCostProcedure.nationalFacilityRate)}</div>
                </dd>
              </div>
            )}
            <div>
              <dt class="text-gray-500">Procedure Categories</dt>
              <dd class="font-semibold">{sortedCategories.length}</dd>
            </div>
          </dl>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-bold text-gray-900 mb-3">Other Body Systems</h3>
          <ul class="space-y-1.5 text-sm">
            {['musculoskeletal', 'cardiovascular', 'nervous', 'digestive', 'respiratory', 'integumentary', 'eye', 'urinary', 'reproductive', 'endocrine', 'auditory', 'hemic-lymphatic', 'general'].filter(s => s !== system).map(s => (
              <li>
                <a href={`/body-system/${s}/`} class="text-brand-600 hover:underline capitalize">{s.replace('-', '/')}</a>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-bold text-gray-900 mb-3">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/procedures/" class="text-brand-600 hover:underline">All Procedures</a></li>
            <li><a href="/conditions/" class="text-brand-600 hover:underline">All Conditions</a></li>
            <li><a href="/drugs/" class="text-brand-600 hover:underline">Drug Prices</a></li>
            <li><a href="/estimator/" class="text-brand-600 hover:underline">Cost Estimator</a></li>
            <li><a href="/compare/" class="text-brand-600 hover:underline">Compare Costs</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</Base>
