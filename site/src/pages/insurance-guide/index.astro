  <script>
    // Load real premium data from API
    (async function() {
      try {
        const API = window.__MEDICAL_COSTS_API__ || 'https://medical-costs-api.david-568.workers.dev';
        const metals = ['Bronze', 'Silver', 'Gold', 'Platinum'];
        const rows: string[] = [];

        for (const metal of metals) {
          const res = await fetch(`${API}/api/insurance-plans?metal=${metal}&limit=200`);
          const json = await res.json();
          const plans = json.data || [];
          if (plans.length === 0) continue;

          const avg30 = plans.reduce((s: number, p: any) => s + (p.premiumAge30 || 0), 0) / plans.length;
          const avg40 = plans.reduce((s: number, p: any) => s + (p.premiumAge40 || 0), 0) / plans.length;
          const avg50 = plans.reduce((s: number, p: any) => s + (p.premiumAge50 || 0), 0) / plans.length;

          const fmt = (n: number) => '$' + Math.round(n).toLocaleString();
          const metalColors: Record<string, string> = {
            'Bronze': 'bg-amber-100 text-amber-800',
            'Silver': 'bg-gray-100 text-gray-800',
            'Gold': 'bg-yellow-100 text-yellow-800',
            'Platinum': 'bg-gray-200 text-gray-900',
          };

          rows.push(`<tr>
            <td class="px-4 py-2.5"><span class="px-2 py-0.5 rounded-full text-xs font-semibold ${metalColors[metal] || ''}">${metal}</span></td>
            <td class="text-right px-4 py-2.5 font-medium">${fmt(avg30)}/mo</td>
            <td class="text-right px-4 py-2.5 font-medium">${fmt(avg40)}/mo</td>
            <td class="text-right px-4 py-2.5 font-medium">${fmt(avg50)}/mo</td>
          </tr>`);
        }

        const table = document.getElementById('premium-table');
        if (table && rows.length > 0) {
          table.innerHTML = rows.join('');
        }
      } catch {}
    })();
  </script>
