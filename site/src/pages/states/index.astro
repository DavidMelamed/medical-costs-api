---
import Base from '@/layouts/Base.astro';
import { STATES } from '@/lib/api';

const title = 'Medical Costs by State — Compare Healthcare Prices Across the US | MedicalCosts.info';
const description = 'Compare medical procedure costs across all 50 states. Healthcare costs vary by 30-60% depending on location due to Medicare Geographic Practice Cost Indices.';
---

<Base title={title} description={description} canonical="/states/">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">States</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Medical Costs by State</h1>
    <p class="text-gray-500 mb-6 max-w-3xl">
      Healthcare costs vary by 30-60% depending on where you live. Medicare uses Geographic Practice Cost
      Indices (GPCIs) to adjust payments across 109 localities. Select a state to see local costs.
    </p>

    <div class="mb-8">
      <a href="/states/map/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
        View Interactive Heat Map
      </a>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {STATES.map(state => (
        <a
          href={`/states/${state.code.toLowerCase()}/`}
          class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-500 hover:shadow-md transition-all group"
        >
          <div class="flex items-center gap-3">
            <span class="text-2xl font-bold text-brand-600">{state.code}</span>
            <span class="font-semibold text-gray-900 group-hover:text-brand-700">{state.name}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
