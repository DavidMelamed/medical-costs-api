  { state: 'Washington', code: 'WA', url: 'https://www.insurance.wa.gov/' },
  { state: 'West Virginia', code: 'WV', url: 'https://www.wvinsurance.gov/' },
  { state: 'Wisconsin', code: 'WI', url: 'https://oci.wi.gov/' },
