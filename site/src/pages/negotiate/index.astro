---
import Base from '@/layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Negotiate Your Medical Bill",
  "description": "A step-by-step guide to negotiating medical bills using data from Medicare rates and hospital price transparency files.",
  "step": [
    { "@type": "HowToStep", "name": "Get an Itemized Bill", "text": "Request a UB-04 or HCFA 1500 form from the billing department listing every charge with CPT codes." },
    { "@type": "HowToStep", "name": "Look Up Each CPT Code", "text": "Search each code on MedicalCosts.info to find the Medicare reimbursement rate." },
    { "@type": "HowToStep", "name": "Compare to Medicare Rate", "text": "Note the Medicare rate for each procedure. This is the baseline federal benchmark." },
    { "@type": "HowToStep", "name": "Calculate Fair Price Range", "text": "Multiply the Medicare rate by 1.5 to 2.5 to get the typical commercial insurance price range." },
    { "@type": "HowToStep", "name": "Call the Billing Department", "text": "Contact the billing department with your specific numbers and request a reduction." },
    { "@type": "HowToStep", "name": "Request Financial Hardship Discount", "text": "Ask about charity care or financial assistance programs for a 20-40% discount." },
    { "@type": "HowToStep", "name": "Negotiate a Payment Plan", "text": "If you cannot pay in full, most providers offer interest-free payment plans." },
    { "@type": "HowToStep", "name": "Escalate If Needed", "text": "File a complaint with your state insurance department if the provider refuses to negotiate." }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What percentage of medical bills can be negotiated?", "acceptedAnswer": { "@type": "Answer", "text": "Studies show roughly 50-80% of medical bills can be successfully negotiated. Uninsured patients and those with high-deductible plans typically have the most leverage." } },
    { "@type": "Question", "name": "How much can I typically save by negotiating?", "acceptedAnswer": { "@type": "Answer", "text": "On average, patients save 30-60% off their original bill through negotiation. Financial hardship programs can reduce bills by 20-100% depending on income." } },
    { "@type": "Question", "name": "When should I negotiate my medical bill?", "acceptedAnswer": { "@type": "Answer", "text": "Negotiate before the bill goes to collections — ideally within 30-60 days of receiving it. The billing department has more flexibility than a collections agency." } },
    { "@type": "Question", "name": "What is the Medicare rate and why does it matter?", "acceptedAnswer": { "@type": "Answer", "text": "The Medicare rate is what the federal government pays for each procedure. It serves as a national pricing benchmark. Commercial insurance typically pays 150-250% of Medicare, so anything above 300% is generally above market rate." } },
    { "@type": "Question", "name": "Can I negotiate a bill that insurance already paid partially?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. You can negotiate your remaining balance (co-pay, coinsurance, or deductible portion). Request an itemized bill, check for errors, and negotiate the patient-responsibility amount." } }
  ]
};

const stateInsuranceDepts = [
  { state: 'Alabama', code: 'AL', url: 'https://www.aldoi.gov/' },
  { state: 'Alaska', code: 'AK', url: 'https://www.commerce.alaska.gov/web/ins/' },
  { state: 'Arizona', code: 'AZ', url: 'https://insurance.az.gov/' },
  { state: 'Arkansas', code: 'AR', url: 'https://insurance.arkansas.gov/' },
  { state: 'California', code: 'CA', url: 'https://www.insurance.ca.gov/' },
  { state: 'Colorado', code: 'CO', url: 'https://doi.colorado.gov/' },
  { state: 'Connecticut', code: 'CT', url: 'https://portal.ct.gov/cid' },
  { state: 'Delaware', code: 'DE', url: 'https://insurance.delaware.gov/' },
  { state: 'Florida', code: 'FL', url: 'https://www.myfloridacfo.com/division/consumers/' },
  { state: 'Georgia', code: 'GA', url: 'https://oci.georgia.gov/' },
  { state: 'Hawaii', code: 'HI', url: 'https://cca.hawaii.gov/ins/' },
