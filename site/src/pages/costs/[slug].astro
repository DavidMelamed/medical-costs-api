---
import Base from '@/layouts/Base.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import { getProcedure, getProcedureBySlug, getRelatedProcedures, getMetricsFacts, getGraphRelationships, getConsumerDescription, formatCurrencyFull, slugify, STATES } from '@/lib/api';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/procedures/');

// The slug could be a CPT code or a human-readable slug
// Try as CPT code first, then as a human-readable slug via the by-slug endpoint
let procedure = await getProcedure(slug);

if (!procedure) {
  procedure = await getProcedureBySlug(slug);
}

// If still not found, redirect to search
if (!procedure) return Astro.redirect(`/procedures/?search=${encodeURIComponent(slug.replace(/-/g, ' '))}`);

const p = procedure as any;

// Fetch related procedures, knowledge graph, consumer description, and interesting facts in parallel
const [relatedProcedures, graphData, consumerDesc, interestingFacts] = await Promise.all([
  getRelatedProcedures(p.code),
  getGraphRelationships('procedure', p.code),
  getConsumerDescription(p.code),
  getMetricsFacts(),
]);

// Extract "commonly_paired" from graph data
const commonlyPaired = (graphData?.relationships?.commonly_paired || []).slice(0, 6);
const geoCosts = p.geographicCosts || [];
const injuryMappings = p.injuryMappings || [];
const commercialEstimates = p.commercialEstimates || {};
const procSlug = slugify(p.description);

// Consumer-friendly info (from dedicated endpoint or embedded in procedure response)
const cd = consumerDesc || p.consumerDescription || null;
const consumerName = cd?.consumerName || null;
const plainDescription = cd?.plainDescription || null;
const whatToExpect = cd?.whatToExpect || null;
const typicalDuration = cd?.typicalDuration || null;
const commonReasons = cd?.commonReasons || null;
const preparationTips = cd?.preparationTips || null;

// SEO-optimized title matching "how much does X cost" queries
const shortName = p.description.replace(/,?\s*each\s+\d+\s+min(utes)?/i, '').replace(/\s+w\/o\s+(dye|contrast)/i, ' without contrast');
const priceStr = p.nationalFacilityRate ? formatCurrencyFull(p.nationalFacilityRate) : null;

const title = `How Much Does ${shortName} Cost? ${priceStr ? `(${priceStr})` : ''} — 2026 Rates | MedicalCosts.info`;
const description = `${shortName} (CPT ${p.code}) costs ${priceStr || 'vary by location'}. Medicare facility rate, hospital outpatient price, surgery center cost, and estimated commercial insurance rates. Updated 2026 CMS data.`;

// Build cost comparison data for bar chart
const costBars: Array<{ label: string; sublabel: string; amount: number; color: string }> = [];
if (p.nationalFacilityRate) costBars.push({ label: 'Medicare', sublabel: 'Facility rate', amount: p.nationalFacilityRate, color: 'bg-brand-500' });
if (p.hospitalOutpatientCost) costBars.push({ label: 'Hospital Outpatient', sublabel: 'OPPS rate', amount: p.hospitalOutpatientCost, color: 'bg-purple-500' });
if (p.ascCost) costBars.push({ label: 'Surgery Center', sublabel: 'ASC rate', amount: p.ascCost, color: 'bg-green-500' });
if (commercialEstimates.facilityLow) costBars.push({ label: 'Commercial Ins.', sublabel: 'Estimated', amount: (commercialEstimates.facilityLow + commercialEstimates.facilityHigh) / 2, color: 'bg-orange-500' });
const maxCost = Math.max(...costBars.map(b => b.amount), 1);

const pageUrl = `https://medicalcosts.info/costs/${slug}/`;

const schema = {
  "@context": "https://schema.org",
  "@type": ["MedicalProcedure", "Service"],
  "name": p.description,
  "alternateName": `CPT ${p.code}`,
  "code": { "@type": "MedicalCode", "codingSystem": p.codeType, "codeValue": p.code },
  "bodyLocation": p.bodySystem,
  "category": p.category,
  ...(p.nationalFacilityRate && {
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": p.nationalFacilityRate,
      "highPrice": commercialEstimates.facilityHigh || p.nationalFacilityRate * 2.5,
      "priceCurrency": "USD",
      "offerCount": geoCosts.length || 1,
    }
  }),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How much does ${shortName} cost?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The Medicare rate for ${shortName} (CPT ${p.code}) is ${priceStr || 'variable'} in a facility setting. ${p.hospitalOutpatientCost ? `The hospital outpatient rate is ${formatCurrencyFull(p.hospitalOutpatientCost)}.` : ''} Commercial insurance typically pays 150-250% of Medicare (${commercialEstimates.facilityLow ? `${formatCurrencyFull(commercialEstimates.facilityLow)} to ${formatCurrencyFull(commercialEstimates.facilityHigh)}` : 'varies'}). Costs vary by geographic location.`
      }
    },
    {
      "@type": "Question",
      "name": `How much does ${shortName} cost without insurance?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Without insurance, ${shortName} typically costs 200-500% of the Medicare rate. The Medicare baseline is ${priceStr || 'variable'}. Many facilities offer cash-pay discounts of 20-40%. Ask your provider about self-pay pricing before your procedure.`
      }
    },
    {
      "@type": "Question",
      "name": `Does insurance cover ${shortName}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Most health insurance plans cover ${shortName} when medically necessary, though you'll typically pay a copay or coinsurance. Your out-of-pocket cost depends on your deductible, plan type, and whether the provider is in-network. Medicare covers this procedure at ${priceStr || 'the standard rate'}.`
      }
    },
  ]
};
---

<Base title={title} description={description} canonical={`/costs/${slug}/`} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" itemprop="item" class="hover:text-brand-600"><span itemprop="name">Home</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <span>/</span>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/procedures/" itemprop="item" class="hover:text-brand-600"><span itemprop="name">Procedures</span></a>
          <meta itemprop="position" content="2" />
        </li>
        <span>/</span>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" class="text-gray-900 font-medium">{p.code}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>

    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        <!-- Header with immediate price answer (AEO: price in first 300 words) -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class="px-3 py-1 bg-brand-100 text-brand-700 text-sm font-semibold rounded-full">{p.codeType} {p.code}</span>
            {p.category && <span class="text-sm text-gray-500">{p.category}</span>}
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
            How Much Does {consumerName || shortName} Cost?
          </h1>
          {consumerName && (
            <p class="text-lg text-brand-600 font-medium mb-4">
              Also known as: {shortName} (CPT {p.code})
            </p>
          )}
          {plainDescription && (
            <p class="text-base text-gray-700 mb-3">{plainDescription}</p>
          )}
          <p class="text-lg text-gray-600">
            {consumerName || p.description} (CPT {p.code}) costs
            <strong class="text-brand-700">{priceStr || 'vary by location and insurance'}</strong>
            at Medicare rates.
            {p.hospitalOutpatientCost && ` Hospital outpatient rate: ${formatCurrencyFull(p.hospitalOutpatientCost)}.`}
            {commercialEstimates.facilityLow && ` With commercial insurance, expect to pay ${formatCurrencyFull(commercialEstimates.facilityLow)} to ${formatCurrencyFull(commercialEstimates.facilityHigh)}.`}
          </p>
          <button
            data-add-to-list={p.code}
            data-name={p.description}
            data-rate={p.nationalFacilityRate || 0}
            class="mt-4 inline-flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-lg border transition-colors bg-brand-50 text-brand-700 border-brand-200 hover:bg-brand-100"
          >
            <svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Add to My List
          </button>
        </div>

        <!-- Visual Cost Comparison Bar Chart -->
        {costBars.length >= 2 && (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-1">Cost Comparison by Payer</h2>
            <p class="text-sm text-gray-500 mb-6">How much {shortName} costs across different settings and payers</p>
            <div class="space-y-4">
              {costBars.map(bar => (
                <div class="flex items-center gap-4">
                  <div class="w-32 sm:w-40 flex-shrink-0 text-right">
                    <div class="font-semibold text-gray-900 text-sm">{bar.label}</div>
                    <div class="text-xs text-gray-400">{bar.sublabel}</div>
                  </div>
                  <div class="flex-1">
                    <div
                      class={`${bar.color} h-9 rounded-lg flex items-center justify-end pr-3 shadow-sm transition-all`}
                      style={`width: ${Math.max((bar.amount / maxCost) * 100, 15)}%`}
                    >
                      <span class="text-white text-sm font-bold whitespace-nowrap">{formatCurrencyFull(bar.amount)}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Cost comparison cards -->
        <div class="grid sm:grid-cols-2 gap-4">
          {p.nationalFacilityRate && (
            <div class="bg-white rounded-xl border-2 border-brand-500 p-6">
              <div class="text-sm text-gray-500 mb-1">Medicare (Facility)</div>
              <div class="text-4xl font-bold text-brand-700">{formatCurrencyFull(p.nationalFacilityRate)}</div>
              <div class="text-xs text-gray-400 mt-2">CMS PFS 2026 national rate</div>
            </div>
          )}
          {p.nationalNonFacRate && p.nationalNonFacRate !== p.nationalFacilityRate && (
            <div class="bg-white rounded-xl border border-gray-200 p-6">
              <div class="text-sm text-gray-500 mb-1">Medicare (Office/Clinic)</div>
              <div class="text-3xl font-bold text-gray-900">{formatCurrencyFull(p.nationalNonFacRate)}</div>
              <div class="text-xs text-gray-400 mt-2">Non-facility setting</div>
            </div>
          )}
          {p.hospitalOutpatientCost && (
            <div class="bg-white rounded-xl border border-gray-200 p-6">
              <div class="text-sm text-gray-500 mb-1">Hospital Outpatient</div>
              <div class="text-3xl font-bold text-gray-900">{formatCurrencyFull(p.hospitalOutpatientCost)}</div>
              <div class="text-xs text-gray-400 mt-2">OPPS rate</div>
            </div>
          )}
          {p.ascCost && (
            <div class="bg-white rounded-xl border border-gray-200 p-6">
              <div class="text-sm text-gray-500 mb-1">Surgery Center (ASC)</div>
              <div class="text-3xl font-bold text-gray-900">{formatCurrencyFull(p.ascCost)}</div>
              <div class="text-xs text-gray-400 mt-2">Ambulatory surgery center</div>
            </div>
          )}
          {commercialEstimates.facilityLow && (
            <div class="bg-white rounded-xl border border-orange-200 p-6 sm:col-span-2">
              <div class="text-sm text-gray-500 mb-1">Estimated Commercial Insurance / Without Insurance</div>
              <div class="text-3xl font-bold text-orange-700">
                {formatCurrencyFull(commercialEstimates.facilityLow)} — {formatCurrencyFull(commercialEstimates.facilityHigh)}
              </div>
              <div class="text-xs text-gray-400 mt-2">Estimated at 1.5x — 2.5x Medicare rates</div>
            </div>
          )}
        </div>

        <!-- What to Expect / Common Reasons / How to Prepare -->
        {(whatToExpect || commonReasons || preparationTips) && (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b bg-gradient-to-r from-blue-50 to-brand-50">
              <h2 class="text-xl font-bold text-gray-900">Patient Guide: {consumerName || shortName}</h2>
              <p class="text-sm text-gray-500">What you need to know before your appointment</p>
            </div>
            <div class="p-6 space-y-6">
              {whatToExpect && (
                <div>
                  <h3 class="font-semibold text-gray-900 text-lg flex items-center gap-2 mb-2">
                    <svg class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    What to Expect
                  </h3>
                  <p class="text-gray-600 ml-7">{whatToExpect}</p>
                </div>
              )}
              {typicalDuration && (
                <div>
                  <h3 class="font-semibold text-gray-900 text-lg flex items-center gap-2 mb-2">
                    <svg class="w-5 h-5 text-purple-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    How Long Does It Take?
                  </h3>
                  <p class="text-gray-600 ml-7">{typicalDuration}</p>
                </div>
              )}
              {commonReasons && (
                <div>
                  <h3 class="font-semibold text-gray-900 text-lg flex items-center gap-2 mb-2">
                    <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Common Reasons Doctors Order This
                  </h3>
                  <p class="text-gray-600 ml-7">{commonReasons}</p>
                </div>
              )}
              {preparationTips && (
                <div>
                  <h3 class="font-semibold text-gray-900 text-lg flex items-center gap-2 mb-2">
                    <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                    How to Prepare
                  </h3>
                  <p class="text-gray-600 ml-7">{preparationTips}</p>
                </div>
              )}
            </div>
          </div>
        )}

        <!-- Procedures Commonly Done Together -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden" id="commonly-together">
          <div class="px-6 py-4 border-b bg-gradient-to-r from-purple-50 to-brand-50">
            <h2 class="text-xl font-bold text-gray-900">Procedures Commonly Done Together</h2>
            <p class="text-sm text-gray-500">These procedures are frequently performed alongside {shortName}</p>
          </div>
          <div id="commonly-paired-list" class="divide-y">
            <div class="px-6 py-8 text-center text-gray-400 text-sm" id="paired-loading">Loading related procedures...</div>
          </div>
        </div>

        <script define:vars={{ procedureCode: p.code }}>
          // Fetch commonly paired procedures from both the graph API and related API
          (async function() {
            const API = 'https://medical-costs-api.david-568.workers.dev/api';
            const container = document.getElementById('commonly-paired-list');
            const section = document.getElementById('commonly-together');

            try {
              const [graphRes, relatedRes] = await Promise.all([
                fetch(`${API}/graph/procedure/${procedureCode}`).then(r => r.json()).catch(() => null),
                fetch(`${API}/related/${procedureCode}`).then(r => r.json()).catch(() => null),
              ]);

              const paired = [];
              const seenCodes = new Set();
              seenCodes.add(procedureCode);

              // Extract commonly_paired from graph
              const graphPaired = graphRes?.data?.relationships?.commonly_paired || [];
              for (const rel of graphPaired) {
                if (!seenCodes.has(rel.id)) {
                  seenCodes.add(rel.id);
                  paired.push({ code: rel.id, fromGraph: true });
                }
              }

              // Also add top related procedures
              const relatedData = relatedRes?.data || relatedRes || [];
              const relatedArr = Array.isArray(relatedData) ? relatedData : [];
              for (const rp of relatedArr.slice(0, 8)) {
                if (!seenCodes.has(rp.code)) {
                  seenCodes.add(rp.code);
                  paired.push({ code: rp.code, description: rp.description, category: rp.category, rate: rp.nationalFacilityRate, slug: rp.slug });
                }
              }

              if (paired.length === 0) {
                section.style.display = 'none';
                return;
              }

              // Fetch details for graph-sourced codes that lack description
              const needDetails = paired.filter(p => !p.description);
              const details = await Promise.all(
                needDetails.map(p => fetch(`${API}/procedures/${p.code}`).then(r => r.json()).catch(() => null))
              );
              details.forEach((d, i) => {
                if (d?.data) {
                  needDetails[i].description = d.data.description;
                  needDetails[i].rate = d.data.nationalFacilityRate;
                  needDetails[i].category = d.data.category;
                  needDetails[i].slug = d.data.slug;
                }
              });

              function fmt(n) {
                if (!n) return 'N/A';
                return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
              }

              container.innerHTML = paired.filter(p => p.description).slice(0, 8).map(item => `
                <div class="flex items-center justify-between px-6 py-3 hover:bg-gray-50 transition-colors">
                  <div class="flex-1 min-w-0">
                    <a href="/costs/${item.slug || item.code}/" class="text-sm font-medium text-gray-900 hover:text-brand-600 truncate block">${item.description}</a>
                    <div class="text-xs text-gray-500">${item.code}${item.category ? ' &middot; ' + item.category : ''}</div>
                  </div>
                  <div class="flex items-center gap-3 ml-4 flex-shrink-0">
                    ${item.rate ? `<span class="text-sm font-semibold text-brand-700">${fmt(item.rate)}</span>` : ''}
                    <button
                      data-add-to-list="${item.code}"
                      data-name="${(item.description || '').replace(/"/g, '&quot;')}"
                      data-rate="${item.rate || 0}"
                      class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors bg-brand-50 text-brand-700 border-brand-200 hover:bg-brand-100"
                    >
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                      Add
                    </button>
                  </div>
                </div>
              `).join('');

            } catch (err) {
              section.style.display = 'none';
            }
          })();
        </script>

        <!-- Cost by location table -->
        {geoCosts.length > 0 && (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b bg-gray-50">
              <h2 class="text-xl font-bold text-gray-900">{shortName} Cost by Location</h2>
              <p class="text-sm text-gray-500">Medicare-adjusted rates across CMS localities</p>
            </div>
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b text-left text-gray-500 text-xs uppercase">
                  <th class="px-6 py-2">Location</th>
                  <th class="px-6 py-2 text-right">Medicare Rate</th>
                  <th class="px-6 py-2 text-right">Est. Commercial</th>
                </tr>
              </thead>
              <tbody class="divide-y">
                {geoCosts.slice(0, 25).map((geo: any) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-3">
                      <span class="font-medium">{geo.stateCode}</span>
                      {geo.locality && geo.locality !== `Carrier ${geo.stateCode}` && <span class="text-gray-500 ml-1">— {geo.locality}</span>}
                    </td>
                    <td class="px-6 py-3 text-right font-semibold">{geo.facilityRate ? formatCurrencyFull(geo.facilityRate) : '—'}</td>
                    <td class="px-6 py-3 text-right text-gray-600">
                      {geo.estimatedCommercialLow ? `${formatCurrencyFull(geo.estimatedCommercialLow)} — ${formatCurrencyFull(geo.estimatedCommercialHigh)}` : '—'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        <!-- Save Money Tips -->
        <div class="bg-green-50 rounded-xl border border-green-200 p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-1 flex items-center gap-2">
            <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            How to Reduce Your Cost for {shortName}
          </h2>
          <p class="text-sm text-gray-600 mb-4">Practical tips that can save you hundreds or thousands of dollars</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-green-200 text-green-800 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">1</span>
              <div>
                <div class="font-semibold text-gray-900 text-sm">Ask about cash-pay discounts</div>
                <p class="text-xs text-gray-500">Many hospitals and clinics offer 20-40% discounts for self-pay patients. Always ask before scheduling.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-green-200 text-green-800 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">2</span>
              <div>
                <div class="font-semibold text-gray-900 text-sm">Compare facility vs. office setting costs</div>
                <p class="text-xs text-gray-500">
                  {p.nationalNonFacRate && p.nationalFacilityRate && p.nationalNonFacRate !== p.nationalFacilityRate
                    ? `For this procedure, the office rate (${formatCurrencyFull(p.nationalNonFacRate)}) differs from the facility rate (${formatCurrencyFull(p.nationalFacilityRate)}). Ask if it can be done in an office setting.`
                    : 'Some procedures cost significantly less in an office setting than a hospital. Ask your provider about options.'}
                </p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-green-200 text-green-800 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">3</span>
              <div>
                <div class="font-semibold text-gray-900 text-sm">Shop around — costs vary significantly</div>
                <p class="text-xs text-gray-500">
                  {geoCosts.length > 2
                    ? `Medicare rates for this procedure range from ${formatCurrencyFull(Math.min(...geoCosts.filter((g: any) => g.facilityRate).map((g: any) => g.facilityRate)))} to ${formatCurrencyFull(Math.max(...geoCosts.filter((g: any) => g.facilityRate).map((g: any) => g.facilityRate)))} depending on location. Commercial rates vary even more.`
                    : 'Costs can vary 2-3x between providers in the same city. Get quotes from multiple facilities.'}
                </p>
              </div>
            </li>
            {p.ascCost && (
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-green-200 text-green-800 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">4</span>
                <div>
                  <div class="font-semibold text-gray-900 text-sm">Check ambulatory surgery centers (ASCs)</div>
                  <p class="text-xs text-gray-500">
                    This procedure is available at ASCs for {formatCurrencyFull(p.ascCost)}{p.hospitalOutpatientCost ? `, compared to ${formatCurrencyFull(p.hospitalOutpatientCost)} at hospital outpatient departments` : ''}. ASCs often offer lower costs with comparable quality.
                  </p>
                </div>
              </li>
            )}
          </ul>
        </div>

        <!-- RVU Details -->
        {p.workRvu && (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">How is the Price Calculated?</h2>
            <p class="text-sm text-gray-600 mb-4">
              Medicare calculates procedure payments using Relative Value Units (RVUs). Each procedure has three components
              multiplied by a conversion factor ($33.40 in 2026) and adjusted by geographic cost indices.
            </p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="text-2xl font-bold text-gray-900">{p.workRvu?.toFixed(2)}</div>
                <div class="text-xs text-gray-500 mt-1">Work RVU</div>
              </div>
              {p.facilityPeRvu && (
                <div class="text-center p-4 bg-gray-50 rounded-lg">
                  <div class="text-2xl font-bold text-gray-900">{p.facilityPeRvu?.toFixed(2)}</div>
                  <div class="text-xs text-gray-500 mt-1">Practice Expense RVU</div>
                </div>
              )}
              {p.malpracticeRvu && (
                <div class="text-center p-4 bg-gray-50 rounded-lg">
                  <div class="text-2xl font-bold text-gray-900">{p.malpracticeRvu?.toFixed(2)}</div>
                  <div class="text-xs text-gray-500 mt-1">Malpractice RVU</div>
                </div>
              )}
              {p.totalRvu && (
                <div class="text-center p-4 bg-brand-50 rounded-lg border border-brand-200">
                  <div class="text-2xl font-bold text-brand-700">{p.totalRvu?.toFixed(2)}</div>
                  <div class="text-xs text-brand-600 mt-1">Total RVU</div>
                </div>
              )}
            </div>
            <p class="text-xs text-gray-400 mt-4">
              Payment = Total RVU ({p.totalRvu?.toFixed(2)}) x CF ($33.40) = {p.totalRvu ? formatCurrencyFull(p.totalRvu * 33.40) : 'N/A'}
            </p>
          </div>
        )}

        <!-- Related Procedures -->
        {relatedProcedures.length > 0 && (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b bg-gray-50">
              <h2 class="text-xl font-bold text-gray-900">Related Procedures</h2>
              <p class="text-sm text-gray-500">Similar procedures in the same category or body system</p>
            </div>
            <div class="divide-y">
              {relatedProcedures.map((rp: any) => (
                <div class="flex items-center justify-between px-6 py-3 hover:bg-gray-50 transition-colors">
                  <a href={`/costs/${rp.slug || rp.code}/`} class="min-w-0 flex-1">
                    <div class="text-sm font-medium text-gray-900 truncate">{rp.description}</div>
                    <div class="text-xs text-gray-500">{rp.code} &middot; {rp.category}</div>
                  </a>
                  <div class="flex items-center gap-3 ml-4 flex-shrink-0">
                    {rp.nationalFacilityRate && (
                      <span class="text-sm font-semibold text-brand-700 whitespace-nowrap">
                        {formatCurrencyFull(rp.nationalFacilityRate)}
                      </span>
                    )}
                    <button
                      data-add-to-list={rp.code}
                      data-name={rp.description}
                      data-rate={rp.nationalFacilityRate || 0}
                      class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors bg-brand-50 text-brand-700 border-brand-200 hover:bg-brand-100"
                    >
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                      Add
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- FAQ section (AEO optimized) -->
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-semibold text-gray-900 text-lg">How much does {shortName} cost?</h3>
              <p class="text-gray-600 mt-2">
                The Medicare facility rate for {shortName} is {priceStr || 'variable'}.
                {p.hospitalOutpatientCost && ` In a hospital outpatient setting, the rate is ${formatCurrencyFull(p.hospitalOutpatientCost)}.`}
                {p.ascCost && ` At an ambulatory surgery center, the rate is ${formatCurrencyFull(p.ascCost)}.`}
                Commercial insurance rates typically range from 150% to 250% of Medicare
                ({commercialEstimates.facilityLow ? `${formatCurrencyFull(commercialEstimates.facilityLow)} to ${formatCurrencyFull(commercialEstimates.facilityHigh)}` : 'varies by plan'}).
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 text-lg">How much does {shortName} cost without insurance?</h3>
              <p class="text-gray-600 mt-2">
                Without insurance, the cost of {shortName} can range from {commercialEstimates.facilityLow ? formatCurrencyFull(commercialEstimates.facilityLow) : '150% of Medicare'} to
                {commercialEstimates.facilityHigh ? formatCurrencyFull(commercialEstimates.facilityHigh * 1.5) : '500% of Medicare'} depending on the facility.
                Many hospitals and clinics offer self-pay discounts of 20-40% off their chargemaster price. Always ask about cash pricing before your visit.
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 text-lg">Does insurance cover {shortName}?</h3>
              <p class="text-gray-600 mt-2">
                Most commercial health insurance plans and Medicare cover {shortName} when ordered by a physician for a medically necessary reason.
                Your out-of-pocket cost depends on your plan's deductible, copay/coinsurance structure, and whether you use an in-network provider.
                Check with your insurance company before scheduling to confirm coverage and get a cost estimate.
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 text-lg">Why does the cost vary so much by location?</h3>
              <p class="text-gray-600 mt-2">
                Medicare adjusts payments using Geographic Practice Cost Indices (GPCIs) that reflect local differences in physician work costs,
                practice expenses, and malpractice insurance. Manhattan, San Francisco, and other high-cost areas pay significantly more than
                rural regions. Commercial insurers follow similar geographic patterns.
              </p>
            </div>
          </div>
        </div>
      </div>

        <!-- Share This Page -->
        <div class="bg-gray-50 rounded-xl border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-3">Share This Cost Information</h2>
          <div class="flex flex-wrap gap-3">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${shortName} costs ${priceStr || 'vary by location'} at Medicare rates. See full cost breakdown:`)}&url=${encodeURIComponent(pageUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Post on X
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Share on Facebook
            </a>
            <button
              onclick="navigator.clipboard.writeText(window.location.href);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy Link',2000)"
              class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
              Copy Link
            </button>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="bg-brand-50 rounded-xl p-6 border border-brand-200 sticky top-20">
          <h3 class="font-bold text-brand-900 mb-3">Procedure Details</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-gray-500">CPT/HCPCS Code</dt>
              <dd class="font-mono font-bold text-lg">{p.code}</dd>
            </div>
            <div>
              <dt class="text-gray-500">CMS Description</dt>
              <dd class="text-xs text-gray-600">{p.description}</dd>
            </div>
            {consumerName && (
              <div>
                <dt class="text-gray-500">Common Name</dt>
                <dd class="text-sm font-medium">{consumerName}</dd>
              </div>
            )}
            {p.category && (
              <div>
                <dt class="text-gray-500">Category</dt>
                <dd><a href={`/procedures/?category=${encodeURIComponent(p.category)}`} class="text-brand-600 hover:underline">{p.category}</a></dd>
              </div>
            )}
            {p.bodySystem && (
              <div>
                <dt class="text-gray-500">Body System</dt>
                <dd>{p.bodySystem}</dd>
              </div>
            )}
            <div>
              <dt class="text-gray-500">Data Year</dt>
              <dd>2026</dd>
            </div>
            <div>
              <dt class="text-gray-500">Source</dt>
              <dd class="text-xs">CMS Medicare Fee Schedule</dd>
            </div>
          </dl>
        </div>

        {injuryMappings.length > 0 && (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-3">Related Conditions</h3>
            <ul class="space-y-2">
              {injuryMappings.map((m: any) => (
                <li>
                  <a href={`/conditions/${m.injury?.slug || '#'}/`} class="text-sm text-brand-600 hover:underline">{m.injury?.name}</a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- State links for this procedure -->
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-bold text-gray-900 mb-3">Cost in Your State</h3>
          <div class="grid grid-cols-4 gap-1">
            {STATES.slice(0, 20).map(state => (
              <a href={`/states/${state.code.toLowerCase()}/`} class="text-xs text-center py-1 text-brand-600 hover:bg-brand-50 rounded">{state.code}</a>
            ))}
          </div>
          <a href="/states/" class="text-xs text-brand-600 hover:underline mt-2 block">All states →</a>
        </div>

        <RelatedLinks entityType="procedure" entityId={p.code} />

        {interestingFacts.length > 0 && (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-bold text-gray-900 mb-3">Did You Know?</h3>
            <ul class="space-y-3">
              {interestingFacts.slice(0, 4).map((fact: any) => (
                <li class="text-xs text-gray-600">
                  <div class="font-semibold text-gray-800 text-sm mb-0.5">{fact.label}</div>
                  {fact.detail}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="bg-yellow-50 rounded-xl p-5 border border-yellow-200">
          <p class="text-xs text-yellow-700">
            <strong>Disclaimer:</strong> Costs are based on CMS Medicare data and may not reflect your actual charges.
            Contact your provider and insurance for personalized cost estimates.
          </p>
        </div>
      </aside>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
