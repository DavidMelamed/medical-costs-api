---
import Base from '@/layouts/Base.astro';

const title = 'What Will I Actually Pay? — Out-of-Pocket Cost Calculator | MedicalCosts.info';
const description = 'Calculate your actual out-of-pocket medical costs. Enter your insurance details and procedures to see exactly what you\'ll owe — deductible, coinsurance, copay, and total.';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "What Will I Actually Pay? Calculator",
  "url": "https://medicalcosts.info/what-will-i-pay/",
  "description": description,
  "applicationCategory": "HealthApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate my out-of-pocket medical costs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your out-of-pocket cost depends on your insurance plan's deductible, coinsurance rate, copay, and out-of-pocket maximum. Use our calculator: enter your plan details and the procedures you need, and we'll calculate exactly what you'll owe."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a copay and coinsurance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A copay is a fixed dollar amount you pay for a service (e.g., $30 for a doctor visit). Coinsurance is a percentage of the allowed amount you pay after meeting your deductible (e.g., 20% of a $5,000 surgery = $1,000)."
      }
    },
    {
      "@type": "Question",
      "name": "What happens after I meet my out-of-pocket maximum?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Once you reach your out-of-pocket maximum (OOP max), your insurance pays 100% of covered services for the rest of the plan year. The 2026 ACA OOP max is $9,450 for individuals and $18,900 for families."
      }
    }
  ]
};
---

<Base title={title} description={description} canonical="/what-will-i-pay/" schema={schema}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-emerald-700 via-emerald-800 to-teal-900 text-white py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-emerald-200 mb-6">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white font-medium">What Will I Pay?</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-4">
        What Will I <span class="text-emerald-300">Actually</span> Pay?
      </h1>
      <p class="text-lg text-emerald-100 max-w-2xl">
        The only calculator that combines real procedure pricing with your insurance plan math.
        See your exact deductible, coinsurance, copay, and total out-of-pocket cost.
      </p>
    </div>
  </section>

  <!-- Calculator -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Left: Inputs -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Step 1: Procedures -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="bg-emerald-50 px-6 py-4 border-b border-emerald-100">
            <div class="flex items-center gap-3">
              <span class="w-8 h-8 bg-emerald-600 text-white rounded-full flex items-center justify-center font-bold text-sm">1</span>
              <h2 class="text-lg font-bold text-gray-900">Search for Procedures</h2>
            </div>
          </div>
          <div class="p-6">
            <div class="relative">
              <input
                id="proc-search"
                type="text"
                placeholder="Search by name or CPT code (e.g., MRI, 99213, colonoscopy)..."
                autocomplete="off"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500"
              />
              <div id="proc-dropdown" class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-xl z-30 max-h-64 overflow-y-auto"></div>
            </div>

            <!-- Selected procedures -->
            <div id="selected-procedures" class="mt-4 space-y-2"></div>

            <p class="text-xs text-gray-400 mt-3">Add multiple procedures to calculate combined costs. Click a result to add it.</p>
          </div>
        </div>

        <!-- Step 2: Insurance Details -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="bg-blue-50 px-6 py-4 border-b border-blue-100">
            <div class="flex items-center gap-3">
              <span class="w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-sm">2</span>
              <h2 class="text-lg font-bold text-gray-900">Your Insurance Details</h2>
            </div>
          </div>
          <div class="p-6">
            <!-- Plan selector toggle -->
            <div class="flex gap-3 mb-6">
              <button id="btn-manual" class="flex-1 px-4 py-2.5 bg-blue-600 text-white font-medium rounded-lg text-sm transition-colors">Enter Manually</button>
              <button id="btn-select-plan" class="flex-1 px-4 py-2.5 bg-gray-100 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-200 transition-colors">Select ACA Plan</button>
            </div>

            <!-- Manual entry form -->
            <div id="manual-form">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Annual Deductible</label>
                  <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
                    <input id="inp-deductible" type="number" value="2000" min="0" max="20000" step="100"
                      class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Deductible Met So Far</label>
                  <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
                    <input id="inp-deductible-met" type="number" value="0" min="0" max="20000" step="100"
                      class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Coinsurance (your %)</label>
                  <div class="relative">
                    <input id="inp-coinsurance" type="number" value="20" min="0" max="100" step="5"
                      class="w-full pr-8 pl-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span>
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Out-of-Pocket Maximum</label>
                  <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
                    <input id="inp-oop-max" type="number" value="9450" min="0" max="30000" step="100"
                      class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Copay per Visit</label>
                  <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
                    <input id="inp-copay" type="number" value="30" min="0" max="500" step="5"
                      class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">
                    <a href="/insurance-guide/" class="text-blue-600 hover:underline">What do these mean?</a>
                  </label>
                  <div class="text-xs text-gray-500 mt-1">
                    Typical Bronze: $7,500 ded / 40% coins<br/>
                    Typical Silver: $4,500 ded / 30% coins<br/>
                    Typical Gold: $1,500 ded / 20% coins
                  </div>
                </div>
              </div>
            </div>

            <!-- ACA Plan selector -->
            <div id="plan-selector" class="hidden">
              <div class="grid sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">State</label>
                  <select id="plan-state" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">Select state...</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Metal Level</label>
                  <select id="plan-metal" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">All levels</option>
                    <option value="Catastrophic">Catastrophic</option>
                    <option value="Bronze">Bronze</option>
                    <option value="Expanded Bronze">Expanded Bronze</option>
                    <option value="Silver">Silver</option>
                    <option value="Gold">Gold</option>
                    <option value="Platinum">Platinum</option>
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Plan</label>
                <select id="plan-select" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                  <option value="">Select state first...</option>
                </select>
              </div>
              <div id="plan-details" class="hidden mt-4 p-4 bg-blue-50 rounded-xl text-sm">
                <div class="font-semibold text-blue-800 mb-2" id="plan-detail-name"></div>
                <div class="grid grid-cols-2 gap-2 text-gray-700" id="plan-detail-grid"></div>
              </div>
              <p class="text-xs text-gray-400 mt-3">4,044 real ACA marketplace plans from healthcare.gov (2026 plan year, 30 states).</p>
            </div>
          </div>
        </div>

        <!-- Step 3: Setting -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="bg-purple-50 px-6 py-4 border-b border-purple-100">
            <div class="flex items-center gap-3">
              <span class="w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold text-sm">3</span>
              <h2 class="text-lg font-bold text-gray-900">Care Setting</h2>
            </div>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              <label class="relative cursor-pointer">
                <input type="radio" name="setting" value="facility" checked class="peer sr-only" />
                <div class="p-3 rounded-xl border-2 border-gray-200 text-center peer-checked:border-purple-500 peer-checked:bg-purple-50 transition-all">
                  <div class="text-lg mb-1">&#127975;</div>
                  <div class="text-sm font-semibold text-gray-900">Hospital Facility</div>
                  <div class="text-xs text-gray-500">Inpatient / ER</div>
                </div>
              </label>
              <label class="relative cursor-pointer">
                <input type="radio" name="setting" value="hospital_outpatient" class="peer sr-only" />
                <div class="p-3 rounded-xl border-2 border-gray-200 text-center peer-checked:border-purple-500 peer-checked:bg-purple-50 transition-all">
                  <div class="text-lg mb-1">&#127973;</div>
                  <div class="text-sm font-semibold text-gray-900">Hospital Outpatient</div>
                  <div class="text-xs text-gray-500">Same-day procedures</div>
                </div>
              </label>
              <label class="relative cursor-pointer">
                <input type="radio" name="setting" value="asc" class="peer sr-only" />
                <div class="p-3 rounded-xl border-2 border-gray-200 text-center peer-checked:border-purple-500 peer-checked:bg-purple-50 transition-all">
                  <div class="text-lg mb-1">&#9879;</div>
                  <div class="text-sm font-semibold text-gray-900">Surgery Center</div>
                  <div class="text-xs text-gray-500">ASC (often cheaper)</div>
                </div>
              </label>
              <label class="relative cursor-pointer">
                <input type="radio" name="setting" value="non_facility" class="peer sr-only" />
                <div class="p-3 rounded-xl border-2 border-gray-200 text-center peer-checked:border-purple-500 peer-checked:bg-purple-50 transition-all">
                  <div class="text-lg mb-1">&#128101;</div>
                  <div class="text-sm font-semibold text-gray-900">Doctor's Office</div>
                  <div class="text-xs text-gray-500">Non-facility</div>
                </div>
              </label>
            </div>
          </div>
        </div>

        <!-- Calculate Button -->
        <button id="btn-calculate" class="w-full px-6 py-4 bg-emerald-600 text-white text-lg font-bold rounded-xl hover:bg-emerald-700 transition-colors shadow-lg disabled:opacity-50 disabled:cursor-not-allowed" disabled>
          Calculate My Out-of-Pocket Cost
        </button>
      </div>

      <!-- Right: Results sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-20">
          <!-- Results Card -->
          <div id="results-card" class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b">
              <h3 class="font-bold text-gray-900">Your Cost Breakdown</h3>
            </div>
            <div id="results-content" class="p-6">
              <div class="text-center py-8 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
                <p class="text-sm">Add procedures and enter your insurance details, then click calculate.</p>
              </div>
            </div>
          </div>

          <!-- Quick stats -->
          <div class="mt-4 bg-amber-50 rounded-xl border border-amber-200 p-4">
            <h4 class="font-semibold text-amber-800 text-sm mb-2">Did You Know?</h4>
            <ul class="text-xs text-amber-700 space-y-1.5">
              <li>The average American pays <strong>$1,300/yr</strong> out-of-pocket</li>
              <li>Same procedure: <strong>2-5x price difference</strong> by setting</li>
              <li>ASC saves <strong>25-60%</strong> vs hospital outpatient</li>
              <li>2026 ACA OOP max: <strong>$9,450</strong> individual</li>
            </ul>
          </div>

          <div class="mt-4 text-center">
            <a href="/insurance-guide/" class="text-sm text-blue-600 font-medium hover:underline">
              Learn how insurance costs work &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Setting Comparison (shown after calculation) -->
  <section id="setting-comparison" class="hidden max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b">
        <h3 class="font-bold text-gray-900">Compare by Care Setting</h3>
        <p class="text-sm text-gray-500">Same procedures, different locations — see where you save</p>
      </div>
      <div id="setting-comparison-grid" class="p-6 grid sm:grid-cols-4 gap-4"></div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
          How accurate is this calculator?
        </summary>
        <div class="px-6 pb-4 text-sm text-gray-600">
          Our calculations use real CMS Medicare 2026 fee schedule rates and actual ACA marketplace plan data from healthcare.gov.
          Commercial insurance typically pays 150-250% of Medicare rates. Your actual costs may vary based on your specific plan's
          negotiated rates with providers, which are not publicly available. This tool provides a well-informed estimate.
        </div>
      </details>
      <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
          What is a deductible?
        </summary>
        <div class="px-6 pb-4 text-sm text-gray-600">
          Your deductible is the amount you pay out of pocket before your insurance starts covering costs. For example,
          with a $2,000 deductible, you pay the first $2,000 of medical bills yourself. After that, your insurance kicks in
          and pays a percentage (based on your coinsurance rate).
        </div>
      </details>
      <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
          Why does the same procedure cost different amounts in different settings?
        </summary>
        <div class="px-6 pb-4 text-sm text-gray-600">
          Hospital outpatient departments have higher overhead and charge facility fees that ambulatory surgery centers (ASCs)
          and doctor's offices do not. Medicare pays different rates depending on where the procedure is performed.
          Getting an MRI at a freestanding imaging center can cost 40-60% less than at a hospital.
        </div>
      </details>
      <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden">
        <summary class="px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
          What ACA plan data do you have?
        </summary>
        <div class="px-6 pb-4 text-sm text-gray-600">
          We have 4,044 real marketplace plans from the 2026 plan year across 30 states that use the federal exchange
          (healthcare.gov). This includes plan names, issuers, metal levels, premiums, deductibles, copays, coinsurance,
          and out-of-pocket maximums. Data is sourced from the CMS QHP Landscape file.
        </div>
      </details>
    </div>
  </section>

  <script>
    const API_BASE = window.__MEDICAL_COSTS_API__ || 'https://medical-costs-api.david-568.workers.dev';

    // State
    let selectedProcedures: Array<{code: string; description: string; rate: number}> = [];
    let selectedPlanId: string | null = null;
    let plansCache: Record<string, any[]> = {};

    // Elements
    const procSearch = document.getElementById('proc-search') as HTMLInputElement;
    const procDropdown = document.getElementById('proc-dropdown') as HTMLElement;
    const selectedProcsEl = document.getElementById('selected-procedures') as HTMLElement;
    const btnCalculate = document.getElementById('btn-calculate') as HTMLButtonElement;
    const resultsContent = document.getElementById('results-content') as HTMLElement;
    const settingComparison = document.getElementById('setting-comparison') as HTMLElement;

    // Formatting
    function fmt(n: number | null | undefined): string {
      if (n == null) return 'N/A';
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }
    function fmtPct(n: number): string {
      return Math.round(n * 100) + '%';
    }

    // Procedure search
    let debounce: ReturnType<typeof setTimeout> | null = null;
    procSearch.addEventListener('input', () => {
      const q = procSearch.value.trim();
      if (debounce) clearTimeout(debounce);
      if (q.length < 2) { procDropdown.classList.add('hidden'); return; }
      debounce = setTimeout(async () => {
        try {
          const res = await fetch(`${API_BASE}/api/search?q=${encodeURIComponent(q)}&limit=8`);
          const json = await res.json();
          if (!json.success) return;
          renderSearchResults(json.data);
        } catch {}
      }, 250);
    });

    function renderSearchResults(data: any) {
      const procs = (data.procedures || []).slice(0, 6);
      if (procs.length === 0) {
        procDropdown.innerHTML = '<div class="px-4 py-3 text-sm text-gray-500">No procedures found</div>';
        procDropdown.classList.remove('hidden');
        return;
      }
      let html = '';
      for (const p of procs) {
        const rate = p.nationalFacilityRate || p.nationalNonFacRate || 0;
        const name = p.consumerName || p.description;
        const already = selectedProcedures.some(sp => sp.code === p.code);
        html += `<button type="button" class="block w-full text-left px-4 py-2.5 hover:bg-emerald-50 transition-colors border-b border-gray-50 ${already ? 'opacity-50' : ''}"
          data-code="${p.code}" data-desc="${name.replace(/"/g, '&quot;')}" data-rate="${rate}" ${already ? 'disabled' : ''}>
          <div class="flex items-center justify-between">
            <div>
              <span class="text-sm font-medium text-gray-900">${name}</span>
              <span class="text-xs text-gray-400 font-mono ml-2">CPT ${p.code}</span>
            </div>
            <span class="text-sm font-bold text-emerald-700">${rate ? fmt(rate) : ''}</span>
          </div>
        </button>`;
      }
      procDropdown.innerHTML = html;
      procDropdown.classList.remove('hidden');

      // Add click handlers
      procDropdown.querySelectorAll('button:not([disabled])').forEach(btn => {
        btn.addEventListener('click', () => {
          const code = btn.getAttribute('data-code')!;
          const desc = btn.getAttribute('data-desc')!;
          const rate = parseFloat(btn.getAttribute('data-rate')!);
          addProcedure(code, desc, rate);
          procDropdown.classList.add('hidden');
          procSearch.value = '';
        });
      });
    }

    function addProcedure(code: string, description: string, rate: number) {
      if (selectedProcedures.some(p => p.code === code)) return;
      selectedProcedures.push({ code, description, rate });
      renderSelectedProcedures();
      updateCalculateButton();
    }

    function removeProcedure(code: string) {
      selectedProcedures = selectedProcedures.filter(p => p.code !== code);
      renderSelectedProcedures();
      updateCalculateButton();
    }

    function renderSelectedProcedures() {
      if (selectedProcedures.length === 0) {
        selectedProcsEl.innerHTML = '';
        return;
      }
      selectedProcsEl.innerHTML = selectedProcedures.map(p => `
        <div class="flex items-center justify-between bg-emerald-50 rounded-lg px-4 py-2.5 border border-emerald-200">
          <div>
            <span class="text-sm font-medium text-gray-900">${p.description}</span>
            <span class="text-xs text-gray-400 font-mono ml-2">CPT ${p.code}</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm font-bold text-emerald-700">${fmt(p.rate)}</span>
            <button type="button" onclick="window.removeProcedure('${p.code}')" class="text-red-400 hover:text-red-600 text-lg leading-none">&times;</button>
          </div>
        </div>
      `).join('');
    }
    (window as any).removeProcedure = removeProcedure;

    function updateCalculateButton() {
      btnCalculate.disabled = selectedProcedures.length === 0;
    }

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('#proc-search') && !(e.target as HTMLElement).closest('#proc-dropdown')) {
        procDropdown.classList.add('hidden');
      }
    });

    // Manual vs Plan toggle
    const btnManual = document.getElementById('btn-manual') as HTMLButtonElement;
    const btnSelectPlan = document.getElementById('btn-select-plan') as HTMLButtonElement;
    const manualForm = document.getElementById('manual-form') as HTMLElement;
    const planSelector = document.getElementById('plan-selector') as HTMLElement;

    btnManual.addEventListener('click', () => {
      btnManual.className = 'flex-1 px-4 py-2.5 bg-blue-600 text-white font-medium rounded-lg text-sm transition-colors';
      btnSelectPlan.className = 'flex-1 px-4 py-2.5 bg-gray-100 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-200 transition-colors';
      manualForm.classList.remove('hidden');
      planSelector.classList.add('hidden');
      selectedPlanId = null;
    });

    btnSelectPlan.addEventListener('click', () => {
      btnSelectPlan.className = 'flex-1 px-4 py-2.5 bg-blue-600 text-white font-medium rounded-lg text-sm transition-colors';
      btnManual.className = 'flex-1 px-4 py-2.5 bg-gray-100 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-200 transition-colors';
      manualForm.classList.add('hidden');
      planSelector.classList.remove('hidden');
    });

    // Populate state dropdown
    const STATES = [
      'AK','AL','AR','AZ','DE','FL','GA','HI','IA','ID','IL','IN','KS','KY','LA',
      'ME','MI','MO','MS','MT','NC','ND','NE','NH','NJ','NM','OH','OK','OR','PA',
      'SC','SD','TN','TX','UT','VA','WI','WV','WY'
    ];
    const planStateEl = document.getElementById('plan-state') as HTMLSelectElement;
    const planMetalEl = document.getElementById('plan-metal') as HTMLSelectElement;
    const planSelectEl = document.getElementById('plan-select') as HTMLSelectElement;

    STATES.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s; opt.textContent = s;
      planStateEl.appendChild(opt);
    });

    async function loadPlans() {
      const state = planStateEl.value;
      const metal = planMetalEl.value;
      if (!state) { planSelectEl.innerHTML = '<option value="">Select state first...</option>'; return; }
      const key = `${state}_${metal}`;
      if (!plansCache[key]) {
        try {
          const params = new URLSearchParams({ state, limit: '200' });
          if (metal) params.set('metal', metal);
          const res = await fetch(`${API_BASE}/api/insurance-plans?${params}`);
          const json = await res.json();
          plansCache[key] = json.data || [];
        } catch { plansCache[key] = []; }
      }
      const plans = plansCache[key];
      planSelectEl.innerHTML = `<option value="">Choose a plan (${plans.length} available)...</option>`;
      plans.forEach((p: any) => {
        const opt = document.createElement('option');
        opt.value = p.id;
        opt.textContent = `${p.metalLevel} | ${p.planName} (${p.issuerName}) - ${fmt(p.premiumAge30)}/mo`;
        planSelectEl.appendChild(opt);
      });
    }

    planStateEl.addEventListener('change', loadPlans);
    planMetalEl.addEventListener('change', loadPlans);

    planSelectEl.addEventListener('change', () => {
      const key = `${planStateEl.value}_${planMetalEl.value}`;
      const plans = plansCache[key] || [];
      const plan = plans.find((p: any) => p.id === planSelectEl.value);
      const detailsEl = document.getElementById('plan-details') as HTMLElement;
      const nameEl = document.getElementById('plan-detail-name') as HTMLElement;
      const gridEl = document.getElementById('plan-detail-grid') as HTMLElement;

      if (plan) {
        selectedPlanId = plan.id;
        detailsEl.classList.remove('hidden');
        nameEl.textContent = plan.planName;
        gridEl.innerHTML = `
          <div>Deductible: <strong>${fmt(plan.deductibleIndividual)}</strong></div>
          <div>OOP Max: <strong>${fmt(plan.oopMaxIndividual)}</strong></div>
          <div>PCP Copay: <strong>${plan.copayPrimaryCare ? fmt(plan.copayPrimaryCare) : 'N/A'}</strong></div>
          <div>Specialist Copay: <strong>${plan.copaySpecialist ? fmt(plan.copaySpecialist) : 'N/A'}</strong></div>
          <div>Coinsurance: <strong>${plan.coinsuranceInpatient ? fmtPct(plan.coinsuranceInpatient) : 'N/A'}</strong></div>
          <div>Premium (age 30): <strong>${fmt(plan.premiumAge30)}/mo</strong></div>
        `;
        // Also update manual inputs with plan values
        (document.getElementById('inp-deductible') as HTMLInputElement).value = String(plan.deductibleIndividual || 0);
        (document.getElementById('inp-coinsurance') as HTMLInputElement).value = String(Math.round((plan.coinsuranceInpatient || 0.2) * 100));
        (document.getElementById('inp-oop-max') as HTMLInputElement).value = String(plan.oopMaxIndividual || 9450);
        (document.getElementById('inp-copay') as HTMLInputElement).value = String(plan.copaySpecialist || 30);
      } else {
        selectedPlanId = null;
        detailsEl.classList.add('hidden');
      }
      updateCalculateButton();
    });

    // Calculate
    btnCalculate.addEventListener('click', async () => {
      if (selectedProcedures.length === 0) return;
      btnCalculate.disabled = true;
      btnCalculate.textContent = 'Calculating...';

      const codes = selectedProcedures.map(p => p.code).join(',');
      const setting = (document.querySelector('input[name="setting"]:checked') as HTMLInputElement)?.value || 'facility';
      const deductible = (document.getElementById('inp-deductible') as HTMLInputElement).value;
      const deductibleMet = (document.getElementById('inp-deductible-met') as HTMLInputElement).value;
      const coinsurance = parseInt((document.getElementById('inp-coinsurance') as HTMLInputElement).value) / 100;
      const oopMax = (document.getElementById('inp-oop-max') as HTMLInputElement).value;
      const copay = (document.getElementById('inp-copay') as HTMLInputElement).value;

      const params = new URLSearchParams({
        codes, setting, deductible, deductible_met: deductibleMet,
        coinsurance: String(coinsurance), oop_max: oopMax, copay,
      });
      if (selectedPlanId) params.set('plan_id', selectedPlanId);
      if (planStateEl.value) params.set('state', planStateEl.value);

      try {
        const res = await fetch(`${API_BASE}/api/oop-calculator?${params}`);
        const json = await res.json();
        if (json.success) {
          renderResults(json.data);
          // Also calculate for all settings for comparison
          await calculateSettingComparison(codes, deductible, deductibleMet, String(coinsurance), oopMax, copay);
        } else {
          resultsContent.innerHTML = `<div class="text-red-600 text-sm">${json.error || 'Calculation failed'}</div>`;
        }
      } catch (err) {
        resultsContent.innerHTML = '<div class="text-red-600 text-sm">Network error. Please try again.</div>';
      }

      btnCalculate.disabled = false;
      btnCalculate.textContent = 'Calculate My Out-of-Pocket Cost';
    });

    function renderResults(data: any) {
      const { procedures, insurance, summary } = data;
      let html = '';

      // Big total
      html += `
        <div class="text-center mb-6 pb-6 border-b border-gray-100">
          <div class="text-xs text-gray-500 uppercase tracking-wide mb-1">Your Total Out-of-Pocket</div>
          <div class="text-4xl font-extrabold text-emerald-700">${fmt(summary.totalOutOfPocket)}</div>
          ${summary.oopMaxReached ? '<div class="text-xs text-amber-600 font-semibold mt-1">OOP Maximum Reached!</div>' : ''}
        </div>
      `;

      // Insurance summary
      html += `
        <div class="mb-5 p-3 bg-blue-50 rounded-lg text-xs">
          <div class="font-semibold text-blue-800 mb-1">${insurance.planName || 'Your Insurance'}</div>
          <div class="grid grid-cols-2 gap-1 text-blue-700">
            <div>Deductible: ${fmt(insurance.deductible)}</div>
            <div>Met: ${fmt(insurance.deductibleMet)}</div>
            <div>Coinsurance: ${fmtPct(insurance.coinsurance)}</div>
            <div>OOP Max: ${fmt(insurance.oopMax)}</div>
          </div>
        </div>
      `;

      // Per-procedure breakdown
      html += '<div class="space-y-3">';
      for (const proc of procedures) {
        html += `
          <div class="border border-gray-100 rounded-lg p-3">
            <div class="text-sm font-semibold text-gray-900 mb-1">${proc.description}</div>
            <div class="text-xs text-gray-400 font-mono mb-2">CPT ${proc.code}</div>
            <div class="space-y-1 text-xs">
              <div class="flex justify-between text-gray-500">
                <span>Medicare rate</span>
                <span>${fmt(proc.medicareRate)}</span>
              </div>
              <div class="flex justify-between text-gray-500">
                <span>Est. negotiated rate</span>
                <span>${fmt(proc.estimatedNegotiatedRate)}</span>
              </div>
              <div class="flex justify-between text-gray-500">
                <span>Your deductible portion</span>
                <span>${fmt(proc.yourCost.deductiblePortion)}</span>
              </div>
              <div class="flex justify-between text-gray-500">
                <span>Your coinsurance</span>
                <span>${fmt(proc.yourCost.coinsurancePortion)}</span>
              </div>
              <div class="flex justify-between text-gray-500">
                <span>Copay</span>
                <span>${fmt(proc.yourCost.copay)}</span>
              </div>
              <div class="flex justify-between font-bold text-emerald-700 pt-1 border-t border-gray-100">
                <span>You pay</span>
                <span>${fmt(proc.yourCost.total)}</span>
              </div>
            </div>
          </div>
        `;
      }
      html += '</div>';

      // Summary bar
      html += `
        <div class="mt-5 pt-4 border-t border-gray-200">
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600">Total charges</span>
            <span class="font-semibold">${fmt(summary.totalEstimatedNegotiated)}</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600">Insurance pays</span>
            <span class="font-semibold text-blue-600">${fmt(summary.totalEstimatedNegotiated - summary.totalOutOfPocket)}</span>
          </div>
          <div class="flex justify-between text-sm font-bold">
            <span class="text-gray-900">You pay</span>
            <span class="text-emerald-700">${fmt(summary.totalOutOfPocket)}</span>
          </div>
          <!-- Visual bar -->
          <div class="mt-3 h-4 bg-gray-100 rounded-full overflow-hidden flex">
            <div class="bg-emerald-500 h-full" style="width: ${Math.min(100, (summary.totalOutOfPocket / summary.totalEstimatedNegotiated) * 100)}%"></div>
            <div class="bg-blue-400 h-full flex-1"></div>
          </div>
          <div class="flex justify-between text-xs text-gray-400 mt-1">
            <span>You: ${Math.round((summary.totalOutOfPocket / summary.totalEstimatedNegotiated) * 100)}%</span>
            <span>Insurance: ${Math.round(100 - (summary.totalOutOfPocket / summary.totalEstimatedNegotiated) * 100)}%</span>
          </div>
        </div>
      `;

      html += `<p class="text-xs text-gray-400 mt-4">Based on CMS Medicare 2026 rates. Commercial rates estimated at 150-250% of Medicare. Actual costs vary by provider and plan.</p>`;

      resultsContent.innerHTML = html;
    }

    async function calculateSettingComparison(codes: string, ded: string, dedMet: string, coins: string, oop: string, cop: string) {
      const settings = ['facility', 'hospital_outpatient', 'asc', 'non_facility'];
      const labels = ['Hospital Inpatient', 'Hospital Outpatient', 'Surgery Center (ASC)', "Doctor's Office"];
      const icons = ['&#127975;', '&#127973;', '&#9879;', '&#128101;'];
      const results: any[] = [];

      for (const s of settings) {
        try {
          const params = new URLSearchParams({
            codes, setting: s, deductible: ded, deductible_met: dedMet,
            coinsurance: coins, oop_max: oop, copay: cop,
          });
          const res = await fetch(`${API_BASE}/api/oop-calculator?${params}`);
          const json = await res.json();
          if (json.success) results.push(json.data.summary);
          else results.push(null);
        } catch { results.push(null); }
      }

      const grid = document.getElementById('setting-comparison-grid') as HTMLElement;
      const cheapest = Math.min(...results.filter(Boolean).map((r: any) => r.totalOutOfPocket));

      grid.innerHTML = results.map((r, i) => {
        if (!r) return `<div class="text-center p-4 bg-gray-50 rounded-xl text-gray-400 text-sm">N/A</div>`;
        const isCheapest = r.totalOutOfPocket === cheapest;
        return `
          <div class="text-center p-4 rounded-xl border-2 ${isCheapest ? 'border-emerald-500 bg-emerald-50' : 'border-gray-200 bg-gray-50'}">
            <div class="text-2xl mb-2">${icons[i]}</div>
            <div class="text-sm font-semibold text-gray-900 mb-1">${labels[i]}</div>
            <div class="text-xl font-bold ${isCheapest ? 'text-emerald-700' : 'text-gray-700'}">${fmt(r.totalOutOfPocket)}</div>
            ${isCheapest ? '<div class="text-xs text-emerald-600 font-semibold mt-1">Best Value</div>' : ''}
            <div class="text-xs text-gray-400 mt-1">Est. total: ${fmt(r.totalEstimatedNegotiated)}</div>
          </div>
        `;
      }).join('');

      settingComparison.classList.remove('hidden');
    }
  </script>
</Base>
