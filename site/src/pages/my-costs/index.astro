---
import Base from '@/layouts/Base.astro';

const title = 'My Medical Cost Estimate — Personalized Treatment Cost List | MedicalCosts.info';
const description = 'View and manage your personalized medical cost estimate. Add procedures, see Medicare and commercial insurance cost totals, and share or print your estimate.';
---

<Base title={title} description={description} canonical="/my-costs/" noindex={true}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">My Costs</span>
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900">My Medical Cost Estimate</h1>
        <p class="text-gray-500 mt-1">Personalized Treatment Cost List</p>
      </div>
      <div class="flex gap-3">
        <button
          id="print-estimate"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
          Print Estimate
        </button>
        <button
          id="share-estimate"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-brand-600 text-white rounded-lg text-sm font-medium hover:bg-brand-700 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
          Share Link
        </button>
      </div>
    </div>

    <!-- Empty state -->
    <div id="my-costs-empty" class="text-center py-16 hidden">
      <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
      <h2 class="text-xl font-bold text-gray-900 mb-2">Your cost list is empty</h2>
      <p class="text-gray-500 mb-6 max-w-md mx-auto">
        Browse procedures or conditions and click "Add to My List" to start building your personalized cost estimate.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/procedures/" class="px-5 py-2.5 bg-brand-600 text-white rounded-lg text-sm font-medium hover:bg-brand-700">Browse Procedures</a>
        <a href="/conditions/" class="px-5 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50">Browse Conditions</a>
        <a href="/estimator/" class="px-5 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50">Cost Estimator</a>
      </div>
    </div>

    <!-- Items list -->
    <div id="my-costs-content" class="space-y-6 hidden">
      <!-- Grand total cards -->
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Estimated Total Cost</h2>
        <div class="grid sm:grid-cols-3 gap-6">
          <div class="bg-brand-50 rounded-lg p-4 border border-brand-200">
            <div class="text-sm text-gray-500 mb-1">Medicare Total</div>
            <div id="mc-total-medicare" class="text-3xl font-bold text-brand-700">$0</div>
            <div class="text-xs text-gray-400 mt-1">CMS 2026 national rates</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
            <div class="text-sm text-gray-500 mb-1">Est. Commercial (Low)</div>
            <div id="mc-total-comm-low" class="text-3xl font-bold text-gray-900">$0</div>
            <div class="text-xs text-gray-400 mt-1">1.5x Medicare rates</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4 border border-orange-200">
            <div class="text-sm text-gray-500 mb-1">Est. Commercial (High)</div>
            <div id="mc-total-comm-high" class="text-3xl font-bold text-orange-700">$0</div>
            <div class="text-xs text-gray-400 mt-1">2.5x Medicare rates</div>
          </div>
        </div>
      </div>

      <!-- Procedure items -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b bg-gray-50 flex items-center justify-between">
          <div>
            <h2 class="text-lg font-bold text-gray-900">Procedures</h2>
            <p id="mc-procedure-count" class="text-sm text-gray-500">0 procedures</p>
          </div>
          <button id="mc-clear-all" class="text-sm text-red-600 hover:text-red-800 font-medium">Clear All</button>
        </div>
        <div id="mc-items-list" class="divide-y"></div>
      </div>

      <!-- Disclaimer -->
      <div class="bg-yellow-50 rounded-xl border border-yellow-200 p-6">
        <h3 class="font-bold text-yellow-800 mb-2">Important Disclaimer</h3>
        <p class="text-sm text-yellow-700">
          These cost estimates are based on CMS Medicare 2026 national rates and are provided for informational purposes only.
          Actual costs will vary based on your location, insurance plan, provider, and specific medical situation.
          Commercial insurance estimates (1.5x-2.5x Medicare) are approximations; your actual insured rate depends on your plan's
          negotiated rates. Always contact your healthcare provider and insurance company for personalized cost estimates before
          scheduling procedures. This is not medical or financial advice.
        </p>
      </div>
    </div>
  </div>

  <script>
    // ---- My Costs full-page view ----
    (function() {
      const STORAGE_KEY = 'medcosts_my_list';

      function getItems() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
        catch { return []; }
      }
      function setItems(items) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
        window.dispatchEvent(new CustomEvent('costlist:updated', { detail: { items } }));
        renderPage();
      }

      function fmt(n) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
      }

      function renderPage() {
        const items = getItems();
        const emptyEl = document.getElementById('my-costs-empty');
        const contentEl = document.getElementById('my-costs-content');
        const listEl = document.getElementById('mc-items-list');

        if (items.length === 0) {
          emptyEl.classList.remove('hidden');
          contentEl.classList.add('hidden');
          return;
        }

        emptyEl.classList.add('hidden');
        contentEl.classList.remove('hidden');

        const medicare = items.reduce((s, i) => s + (i.medicareRate || 0), 0);
        document.getElementById('mc-total-medicare').textContent = fmt(medicare);
        document.getElementById('mc-total-comm-low').textContent = fmt(medicare * 1.5);
        document.getElementById('mc-total-comm-high').textContent = fmt(medicare * 2.5);
        document.getElementById('mc-procedure-count').textContent = `${items.length} procedure${items.length !== 1 ? 's' : ''}`;

        listEl.innerHTML = items.map(item => `
          <div class="px-6 py-4 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
            <div class="flex-1 min-w-0">
              <a href="/costs/${item.code}/" class="text-sm font-medium text-brand-600 hover:underline">${item.name}</a>
              <div class="text-xs text-gray-400 mt-0.5">CPT ${item.code}</div>
            </div>
            <div class="flex items-center gap-6 flex-shrink-0">
              <div class="text-right hidden sm:block">
                <div class="text-sm font-semibold text-brand-700">${item.medicareRate > 0 ? fmt(item.medicareRate) : 'N/A'}</div>
                <div class="text-xs text-gray-400">Medicare</div>
              </div>
              <div class="text-right hidden sm:block">
                <div class="text-sm text-gray-700">${item.medicareRate > 0 ? fmt(item.medicareRate * 1.5) + ' — ' + fmt(item.medicareRate * 2.5) : 'N/A'}</div>
                <div class="text-xs text-gray-400">Est. Commercial</div>
              </div>
              <div class="sm:hidden text-right">
                <div class="text-sm font-semibold text-brand-700">${item.medicareRate > 0 ? fmt(item.medicareRate) : 'N/A'}</div>
              </div>
              <button class="mc-remove-item text-gray-400 hover:text-red-500 transition-colors p-1" data-code="${item.code}" aria-label="Remove">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              </button>
            </div>
          </div>
        `).join('');

        // Attach remove handlers
        listEl.querySelectorAll('.mc-remove-item').forEach(btn => {
          btn.addEventListener('click', () => {
            const code = btn.getAttribute('data-code');
            setItems(getItems().filter(i => i.code !== code));
          });
        });
      }

      // Clear all
      document.getElementById('mc-clear-all').addEventListener('click', () => {
        if (confirm('Remove all procedures from your cost list?')) {
          setItems([]);
        }
      });

      // Print
      document.getElementById('print-estimate').addEventListener('click', () => {
        window.print();
      });

      // Share via link
      document.getElementById('share-estimate').addEventListener('click', () => {
        const items = getItems();
        if (items.length === 0) {
          alert('Add some procedures to your list first.');
          return;
        }
        const codes = items.map(i => i.code).join(',');
        const url = `${window.location.origin}/my-costs/?codes=${encodeURIComponent(codes)}`;
        navigator.clipboard.writeText(url).then(() => {
          const btn = document.getElementById('share-estimate');
          const orig = btn.innerHTML;
          btn.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> Link Copied!';
          setTimeout(() => { btn.innerHTML = orig; }, 2000);
        });
      });

      // Load from URL params (shared link)
      const params = new URLSearchParams(window.location.search);
      const sharedCodes = params.get('codes');
      if (sharedCodes) {
        const codes = sharedCodes.split(',').filter(Boolean);
        if (codes.length > 0) {
          const API = 'https://medical-costs-api.david-568.workers.dev/api';
          // Fetch procedure details for each code
          Promise.all(codes.map(code =>
            fetch(`${API}/procedures/${code}`).then(r => r.json()).catch(() => null)
          )).then(results => {
            const items = [];
            results.forEach(r => {
              if (r?.data) {
                items.push({
                  code: r.data.code,
                  name: r.data.description,
                  medicareRate: r.data.nationalFacilityRate || 0
                });
              }
            });
            if (items.length > 0) {
              localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
              renderPage();
            }
          });
        }
      }

      // Listen for updates from the sidebar
      window.addEventListener('costlist:updated', renderPage);

      // Initial render
      renderPage();
    })();
  </script>
</Base>
