---
import Base from '@/layouts/Base.astro';
import { getHospitals, getHospitalStateDrgs, formatCurrencyFull, STATES } from '@/lib/api';

export function getStaticPaths() {
  return [
    { params: { state: 'al' } }, { params: { state: 'ak' } }, { params: { state: 'az' } },
    { params: { state: 'ar' } }, { params: { state: 'ca' } }, { params: { state: 'co' } },
    { params: { state: 'ct' } }, { params: { state: 'de' } }, { params: { state: 'fl' } },
    { params: { state: 'ga' } }, { params: { state: 'hi' } }, { params: { state: 'id' } },
    { params: { state: 'il' } }, { params: { state: 'in' } }, { params: { state: 'ia' } },
    { params: { state: 'ks' } }, { params: { state: 'ky' } }, { params: { state: 'la' } },
    { params: { state: 'me' } }, { params: { state: 'md' } }, { params: { state: 'ma' } },
    { params: { state: 'mi' } }, { params: { state: 'mn' } }, { params: { state: 'ms' } },
    { params: { state: 'mo' } }, { params: { state: 'mt' } }, { params: { state: 'ne' } },
    { params: { state: 'nv' } }, { params: { state: 'nh' } }, { params: { state: 'nj' } },
    { params: { state: 'nm' } }, { params: { state: 'ny' } }, { params: { state: 'nc' } },
    { params: { state: 'nd' } }, { params: { state: 'oh' } }, { params: { state: 'ok' } },
    { params: { state: 'or' } }, { params: { state: 'pa' } }, { params: { state: 'ri' } },
    { params: { state: 'sc' } }, { params: { state: 'sd' } }, { params: { state: 'tn' } },
    { params: { state: 'tx' } }, { params: { state: 'ut' } }, { params: { state: 'vt' } },
    { params: { state: 'va' } }, { params: { state: 'wa' } }, { params: { state: 'wv' } },
    { params: { state: 'wi' } }, { params: { state: 'wy' } }, { params: { state: 'dc' } },
  ];
}

const { state } = Astro.params;
const stateCode = state!.toUpperCase();
const stateInfo = STATES.find(s => s.code === stateCode);
const stateName = stateInfo?.name || stateCode;

// Get all hospitals in state (aggregated by provider)
const hospitalsRes = await getHospitals({ state: stateCode, sort: 'charges_desc', limit: 500 });
const allHospitals = hospitalsRes.data;

// Aggregate by provider (since multiple DRG rows per hospital)
const providerMap = new Map<string, {
  name: string; city: string; state: string;
  totalCharges: number; totalPayments: number; totalMedicare: number;
  count: number; totalDischarges: number;
}>();
for (const h of allHospitals) {
  const key = h.providerCcn;
  const existing = providerMap.get(key);
  if (existing) {
    existing.totalCharges += h.avgCoveredCharges;
    existing.totalPayments += h.avgTotalPayments;
    existing.totalMedicare += h.avgMedicarePayments;
    existing.count += 1;
    existing.totalDischarges += h.totalDischarges;
  } else {
    providerMap.set(key, {
      name: h.providerName, city: h.providerCity, state: h.providerState,
      totalCharges: h.avgCoveredCharges, totalPayments: h.avgTotalPayments,
      totalMedicare: h.avgMedicarePayments, count: 1, totalDischarges: h.totalDischarges,
    });
  }
}

const hospitals = Array.from(providerMap.entries()).map(([ccn, h]) => ({
  ccn,
  name: h.name,
  city: h.city,
  avgCharges: Math.round(h.totalCharges / h.count),
  avgPayments: Math.round(h.totalPayments / h.count),
  avgMedicare: Math.round(h.totalMedicare / h.count),
  markup: h.totalPayments > 0 ? Math.round((h.totalCharges / h.totalPayments) * 100) / 100 : 0,
  totalDischarges: h.totalDischarges,
  drgCount: h.count,
})).sort((a, b) => b.avgCharges - a.avgCharges);

const hospitalCount = hospitals.length;

// Get top DRGs for the state
const drgs = await getHospitalStateDrgs(stateCode, 20);

const bestValueHospitals = [...hospitals].sort((a, b) => a.markup - b.markup).slice(0, 5);

const title = `Hospital Costs in ${stateName} — Compare ${hospitalCount} Hospitals | MedicalCosts.info`;
const description = `Compare hospital costs across ${hospitalCount} hospitals in ${stateName}. See average charges, Medicare payments, charge-to-payment ratios, and find the best value hospitals.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `Hospital Costs in ${stateName}`,
  "description": description,
  "url": `https://medicalcosts.info/hospitals/${state}/`,
};
---

<Base title={title} description={description} canonical={`/hospitals/${state}/`} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-teal-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/hospitals/" class="hover:text-teal-600">Hospitals</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">{stateName}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Hospital Costs in {stateName}</h1>
    <p class="text-gray-500 mb-8 max-w-3xl">
      Compare average charges, Medicare payments, and charge-to-payment ratios for {hospitalCount} hospitals in {stateName}.
    </p>

    <!-- State summary stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <div class="bg-teal-50 rounded-xl p-5 border border-teal-100">
        <div class="text-2xl font-bold text-teal-700">{hospitalCount}</div>
        <div class="text-sm text-gray-600">Hospitals</div>
      </div>
      <div class="bg-teal-50 rounded-xl p-5 border border-teal-100">
        <div class="text-2xl font-bold text-teal-700">{drgs.length}</div>
        <div class="text-sm text-gray-600">DRG Categories</div>
      </div>
      <div class="bg-teal-50 rounded-xl p-5 border border-teal-100">
        <div class="text-2xl font-bold text-teal-700">
          {hospitals.length > 0 ? formatCurrencyFull(Math.round(hospitals.reduce((s, h) => s + h.avgCharges, 0) / hospitals.length)) : 'N/A'}
        </div>
        <div class="text-sm text-gray-600">Avg Hospital Charges</div>
      </div>
      <div class="bg-teal-50 rounded-xl p-5 border border-teal-100">
        <div class="text-2xl font-bold text-teal-700">
          {hospitals.length > 0 ? formatCurrencyFull(Math.round(hospitals.reduce((s, h) => s + h.avgPayments, 0) / hospitals.length)) : 'N/A'}
        </div>
        <div class="text-sm text-gray-600">Avg Payment</div>
      </div>
    </div>

    <!-- Best Value Hospitals -->
    {bestValueHospitals.length > 0 && (
      <div class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Best Value Hospitals in {stateName}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
          {bestValueHospitals.map((h, i) => (
            <div class="bg-gradient-to-br from-green-50 to-teal-50 rounded-xl p-5 border border-green-200">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-7 h-7 rounded-full bg-green-600 text-white text-sm font-bold flex items-center justify-center">{i + 1}</span>
                <span class="text-xs font-semibold text-green-700 uppercase">Best Value</span>
              </div>
              <h3 class="font-semibold text-gray-900 text-sm leading-tight mb-1">{h.name}</h3>
              <div class="text-xs text-gray-500">{h.city}</div>
              <div class="mt-2 text-lg font-bold text-green-700">{h.markup}x markup</div>
              <div class="text-xs text-gray-500">{formatCurrencyFull(h.avgCharges)} avg charges</div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- All Hospitals Table -->
    <h2 class="text-2xl font-bold text-gray-900 mb-4">All Hospitals in {stateName}</h2>
    <div class="overflow-x-auto mb-10">
      <table class="w-full text-sm" id="hospitals-table">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left">
            <th class="py-3 pr-4 font-semibold text-gray-600">Hospital</th>
            <th class="py-3 pr-4 font-semibold text-gray-600">City</th>
            <th class="py-3 pr-4 font-semibold text-gray-600 text-right cursor-pointer hover:text-teal-600" data-sort="charges">Avg Charges</th>
            <th class="py-3 pr-4 font-semibold text-gray-600 text-right cursor-pointer hover:text-teal-600" data-sort="payments">Avg Payment</th>
            <th class="py-3 pr-4 font-semibold text-gray-600 text-right cursor-pointer hover:text-teal-600" data-sort="markup">Markup</th>
            <th class="py-3 font-semibold text-gray-600 text-right">Discharges</th>
          </tr>
        </thead>
        <tbody>
          {hospitals.map(h => (
              <tr class="border-b border-gray-100 hover:bg-gray-50">
                <td class="py-3 pr-4 font-medium text-gray-900">{h.name}</td>
                <td class="py-3 pr-4 text-gray-500">{h.city}</td>
                <td class="py-3 pr-4 text-right font-semibold text-gray-700">{formatCurrencyFull(h.avgCharges)}</td>
                <td class="py-3 pr-4 text-right text-gray-700">{formatCurrencyFull(h.avgPayments)}</td>
                <td class="py-3 pr-4 text-right">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${h.markup >= 4 ? 'bg-red-100 text-red-700' : h.markup > 2 ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700'}`}>
                    {h.markup}x
                  </span>
                </td>
                <td class="py-3 text-right text-gray-500">{h.totalDischarges.toLocaleString()}</td>
              </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Top DRGs in State -->
    {drgs.length > 0 && (
      <div class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Most Common Hospital Stays in {stateName}</h2>
        <p class="text-gray-500 mb-6">Top DRG categories by number of discharges. Click to compare hospitals.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {drgs.slice(0, 20).map(d => (
            <a
              href={`/hospitals/${state}/${d.drgCode}/`}
              class="bg-white rounded-xl border border-gray-200 p-5 hover:border-teal-500 hover:shadow-md transition-all group"
            >
              <div class="text-xs text-teal-600 font-mono mb-1">DRG {d.drgCode}</div>
              <h3 class="font-semibold text-gray-900 group-hover:text-teal-700 text-sm leading-tight mb-2">{d.drgDescription}</h3>
              <div class="flex items-center justify-between text-xs text-gray-500">
                <span>{d.hospitalCount} hospitals</span>
                <span class="font-semibold text-gray-700">{formatCurrencyFull(d.avgCharges)}</span>
              </div>
              <div class="text-xs text-gray-400 mt-1">{d.totalDischarges.toLocaleString()} discharges</div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Other States -->
    <div class="border-t border-gray-200 pt-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Compare Other States</h2>
      <div class="flex flex-wrap gap-2">
        {STATES.filter(s => s.code !== stateCode).map(s => (
          <a href={`/hospitals/${s.code.toLowerCase()}/`} class="px-3 py-1.5 bg-gray-100 rounded-lg text-sm font-medium text-gray-600 hover:bg-teal-100 hover:text-teal-700 transition-colors">
            {s.code}
          </a>
        ))}
      </div>
    </div>
  </div>
</Base>
