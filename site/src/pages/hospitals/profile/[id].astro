---
import Base from '@/layouts/Base.astro';
import { getHospitalProfile, formatCurrencyFull, slugify, STATES } from '@/lib/api';

const { id } = Astro.params;
const data = await getHospitalProfile(id!);

if (!data) {
  return Astro.redirect('/hospitals/');
}

const { hospital, summary, stateAverage, drgs, negotiatedRates } = data;
const stateName = STATES.find(s => s.code === hospital.state)?.name || hospital.state;

const hasNegotiatedRates = negotiatedRates.totalPayers > 0;
const topDrgs = drgs.slice(0, 20);

// Compare to state average
const chargesVsState = stateAverage && stateAverage.avgCharges > 0
  ? Math.round(((summary.avgCharges - stateAverage.avgCharges) / stateAverage.avgCharges) * 100)
  : null;
const paymentsVsState = stateAverage && stateAverage.avgPayments > 0
  ? Math.round(((summary.avgPayments - stateAverage.avgPayments) / stateAverage.avgPayments) * 100)
  : null;

const title = `${hospital.name} in ${hospital.city}, ${hospital.state} — Costs & Prices | MedicalCosts.info`;
const description = `See costs at ${hospital.name} in ${hospital.city}, ${stateName}. ${summary.totalDrgs} DRG categories, average charges of ${formatCurrencyFull(summary.avgCharges)}, and charge-to-payment ratio of ${summary.chargeToPaymentRatio}x.${hasNegotiatedRates ? ` Includes negotiated rates from ${negotiatedRates.totalPayers} insurance companies.` : ''}`;

const schema = {
  "@context": "https://schema.org",
  "@type": ["Hospital", "LocalBusiness"],
  "name": hospital.name,
  "description": `Hospital cost and pricing data for ${hospital.name}`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": hospital.city,
    "addressRegion": hospital.state,
    "postalCode": hospital.zip,
    "addressCountry": "US"
  },
  "url": `https://medicalcosts.info/hospitals/profile/${id}/`,
};
---

<Base title={title} description={description} canonical={`/hospitals/profile/${id}/`} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-teal-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/hospitals/" class="hover:text-teal-600">Hospitals</a>
      <span class="mx-2">/</span>
      <a href={`/hospitals/${hospital.state.toLowerCase()}/`} class="hover:text-teal-600">{stateName}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">{hospital.name}</span>
    </nav>

    <!-- Hospital Header -->
    <div class="bg-gradient-to-br from-teal-700 via-teal-800 to-teal-900 text-white rounded-2xl p-8 mb-8">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2">{hospital.name}</h1>
      <p class="text-teal-100 text-lg mb-1">{hospital.city}, {stateName} {hospital.zip}</p>
      <p class="text-teal-200 text-sm">CMS Provider ID (CCN): {hospital.ccn}</p>
    </div>

    <!-- Cost Overview Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-10">
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-2xl font-bold text-teal-700">{summary.totalDrgs}</div>
        <div class="text-sm text-gray-500">DRG Categories</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-2xl font-bold text-teal-700">{summary.totalDischarges.toLocaleString()}</div>
        <div class="text-sm text-gray-500">Total Discharges</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-2xl font-bold text-red-600">{formatCurrencyFull(summary.avgCharges)}</div>
        <div class="text-sm text-gray-500">Avg Charges</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-2xl font-bold text-gray-700">{formatCurrencyFull(summary.avgPayments)}</div>
        <div class="text-sm text-gray-500">Avg Payment</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-2xl font-bold text-gray-700">{formatCurrencyFull(summary.avgMedicare)}</div>
        <div class="text-sm text-gray-500">Avg Medicare</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class={`text-2xl font-bold ${(summary.chargeToPaymentRatio || 0) >= 4 ? 'text-red-600' : (summary.chargeToPaymentRatio || 0) >= 2 ? 'text-yellow-600' : 'text-green-600'}`}>
          {summary.chargeToPaymentRatio}x
        </div>
        <div class="text-sm text-gray-500">Charge-to-Payment</div>
      </div>
    </div>

    <!-- Comparison to State Average -->
    {stateAverage && (
      <div class="bg-gradient-to-r from-gray-50 to-teal-50 rounded-2xl p-8 border border-gray-200 mb-10">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Compared to {stateName} Average</h2>
        <p class="text-sm text-gray-500 mb-6">How this hospital compares to the average of {stateAverage.totalHospitals} hospitals in {stateName}</p>
        <div class="grid sm:grid-cols-3 gap-6">
          <div>
            <div class="text-sm text-gray-500 mb-1">Average Charges</div>
            <div class="flex items-baseline gap-2">
              <span class="text-lg font-bold text-gray-900">{formatCurrencyFull(summary.avgCharges)}</span>
              {chargesVsState !== null && (
                <span class={`text-sm font-semibold ${chargesVsState > 0 ? 'text-red-600' : 'text-green-600'}`}>
                  {chargesVsState > 0 ? '+' : ''}{chargesVsState}%
                </span>
              )}
            </div>
            <div class="text-xs text-gray-400">State avg: {formatCurrencyFull(stateAverage.avgCharges)}</div>
          </div>
          <div>
            <div class="text-sm text-gray-500 mb-1">Average Payment</div>
            <div class="flex items-baseline gap-2">
              <span class="text-lg font-bold text-gray-900">{formatCurrencyFull(summary.avgPayments)}</span>
              {paymentsVsState !== null && (
                <span class={`text-sm font-semibold ${paymentsVsState > 0 ? 'text-red-600' : 'text-green-600'}`}>
                  {paymentsVsState > 0 ? '+' : ''}{paymentsVsState}%
                </span>
              )}
            </div>
            <div class="text-xs text-gray-400">State avg: {formatCurrencyFull(stateAverage.avgPayments)}</div>
          </div>
          <div>
            <div class="text-sm text-gray-500 mb-1">Charge-to-Payment Ratio</div>
            <div class="flex items-baseline gap-2">
              <span class="text-lg font-bold text-gray-900">{summary.chargeToPaymentRatio}x</span>
              {stateAverage.avgMarkup > 0 && (
                <span class={`text-sm font-semibold ${(summary.chargeToPaymentRatio || 0) > stateAverage.avgMarkup ? 'text-red-600' : 'text-green-600'}`}>
                  {(summary.chargeToPaymentRatio || 0) > stateAverage.avgMarkup ? 'Above' : 'Below'} avg
                </span>
              )}
            </div>
            <div class="text-xs text-gray-400">State avg: {stateAverage.avgMarkup}x</div>
          </div>
        </div>
      </div>
    )}

    <!-- Top DRGs Table -->
    <h2 class="text-2xl font-bold text-gray-900 mb-2">Top {topDrgs.length} DRGs by Volume</h2>
    <p class="text-gray-500 mb-6">Most common diagnosis groups at this hospital, sorted by number of discharges</p>
    <div class="overflow-x-auto mb-10">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left">
            <th class="py-3 pr-4 font-semibold text-gray-600">DRG</th>
            <th class="py-3 pr-4 font-semibold text-gray-600">Description</th>
            <th class="py-3 pr-4 font-semibold text-gray-600 text-right">Discharges</th>
            <th class="py-3 pr-4 font-semibold text-gray-600 text-right">Avg Charges</th>
            <th class="py-3 pr-4 font-semibold text-gray-600 text-right">Avg Payment</th>
            <th class="py-3 font-semibold text-gray-600 text-right">Markup</th>
          </tr>
        </thead>
        <tbody>
          {topDrgs.map((d: any) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="py-3 pr-4 font-mono text-teal-600 text-xs">
                <a href={`/drg/${d.drgCode}/`} class="hover:underline">{d.drgCode}</a>
              </td>
              <td class="py-3 pr-4 text-gray-900 max-w-xs truncate">{d.drgDescription}</td>
              <td class="py-3 pr-4 text-right text-gray-500">{d.totalDischarges.toLocaleString()}</td>
              <td class="py-3 pr-4 text-right font-semibold text-red-600">{formatCurrencyFull(d.avgCoveredCharges)}</td>
              <td class="py-3 pr-4 text-right text-gray-700">{formatCurrencyFull(d.avgTotalPayments)}</td>
              <td class="py-3 text-right">
                <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${
                  (d.chargeToPaymentRatio || 0) >= 4 ? 'bg-red-100 text-red-700' :
                  (d.chargeToPaymentRatio || 0) >= 2 ? 'bg-yellow-100 text-yellow-700' :
                  'bg-green-100 text-green-700'
                }`}>
                  {d.chargeToPaymentRatio}x
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {drgs.length > 20 && (
      <div class="text-center mb-10">
        <p class="text-gray-500 text-sm">Showing top 20 of {drgs.length} DRG categories at this hospital.</p>
      </div>
    )}

    <!-- Negotiated Rates Section -->
    {hasNegotiatedRates && (
      <div class="bg-white rounded-2xl border border-indigo-200 overflow-hidden mb-10">
        <div class="px-6 py-4 border-b bg-indigo-50">
          <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            What Insurance Companies Pay Here
          </h2>
          <p class="text-sm text-indigo-700 mt-1">
            Negotiated rates from {negotiatedRates.totalPayers} insurance companies ({negotiatedRates.totalRates} rate records)
          </p>
        </div>
        <div class="px-6 py-4">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b text-left text-gray-500 text-xs uppercase">
                <th class="py-2 pr-4">Insurance Company</th>
                <th class="py-2 text-right">Avg Rate</th>
                <th class="py-2 text-right">Range</th>
                <th class="py-2 text-right">Procedures</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              {negotiatedRates.byPayer.slice(0, 15).map((p: any) => (
                <tr class="hover:bg-gray-50">
                  <td class="py-2.5 pr-4 font-medium text-gray-900">
                    <a href={`/insurers/${slugify(p.payerName)}/`} class="hover:text-indigo-600">{p.payerName}</a>
                  </td>
                  <td class="py-2.5 text-right font-semibold">{formatCurrencyFull(p.avgRate)}</td>
                  <td class="py-2.5 text-right text-gray-500 text-xs">
                    {p.minRate !== p.maxRate
                      ? `${formatCurrencyFull(p.minRate)} - ${formatCurrencyFull(p.maxRate)}`
                      : formatCurrencyFull(p.minRate)}
                  </td>
                  <td class="py-2.5 text-right text-gray-400">{p.proceduresCovered}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="px-6 py-3 bg-amber-50 border-t border-amber-200 text-xs text-amber-800">
          <strong>Note:</strong> These rates are from hospital Machine-Readable Files (MRFs) required by federal price transparency law.
          Your actual cost depends on your plan, deductible, and network status.
        </div>
      </div>
    )}

    <!-- Links -->
    <div class="flex flex-wrap gap-4 mb-10">
      <a href={`/hospitals/${hospital.state.toLowerCase()}/`} class="inline-flex items-center px-5 py-2.5 bg-teal-50 text-teal-700 rounded-xl font-semibold hover:bg-teal-100 transition-colors border border-teal-200">
        View All Hospitals in {stateName}
      </a>
      <a href="/hospitals/" class="inline-flex items-center px-5 py-2.5 bg-gray-50 text-gray-700 rounded-xl font-semibold hover:bg-gray-100 transition-colors border border-gray-200">
        Compare Hospitals Nationally
      </a>
    </div>

    <!-- Data Source -->
    <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 text-sm text-gray-600">
      <h3 class="font-semibold text-gray-800 mb-2">About This Data</h3>
      <p>Hospital charges and payment data are from the CMS Medicare Inpatient Prospective Payment System (IPPS) Provider Summary. Charges represent the hospital's list price; payments reflect what Medicare actually paid. Negotiated insurance rates are from hospital Machine-Readable Files (MRFs) required by the CMS Hospital Price Transparency Rule.</p>
    </div>
  </div>
</Base>
