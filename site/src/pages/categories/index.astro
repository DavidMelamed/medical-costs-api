---
import Base from '@/layouts/Base.astro';
import { getCategories, getMetrics, slugify, formatCurrencyFull } from '@/lib/api';

const { categories, bodySystems } = await getCategories();
const metricsData = await getMetrics();
const avgCostByCategory = (metricsData.avg_cost_by_category || []) as Array<{ key: string; value: number; label: string; detail: string }>;

// Sort by value descending, take top 20
const topCostCategories = avgCostByCategory
  .sort((a, b) => b.value - a.value)
  .slice(0, 20);
const maxCatCost = topCostCategories.length > 0 ? topCostCategories[0].value : 1;

const title = 'Medical Procedure Categories — Browse Costs by Specialty | MedicalCosts.info';
const description = `Browse medical procedure costs across ${categories?.length || 50}+ categories including surgery, radiology, physical therapy, and more. Compare Medicare, hospital, and surgery center rates.`;
---

<Base title={title} description={description} canonical="/categories/">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">Categories</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Medical Procedure Categories</h1>
    <p class="text-gray-500 mb-8">Browse costs across {categories?.length || 50}+ medical specialties and procedure types</p>

    <!-- Category Cost Distribution Chart -->
    {topCostCategories.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Average Cost by Category</h2>
        <p class="text-gray-500 mb-6 text-sm">Horizontal bar chart showing average Medicare procedure cost per category</p>

        <div class="bg-white rounded-2xl border border-gray-200 p-4 md:p-6">
          <div class="space-y-3">
            {topCostCategories.map((cat, i) => {
              const pct = (cat.value / maxCatCost) * 100;
              const procCount = cat.detail.match(/across ([\d,]+)/)?.[1] || '';
              const colors = [
                'bg-brand-600', 'bg-brand-500', 'bg-blue-500', 'bg-blue-400',
                'bg-indigo-500', 'bg-indigo-400', 'bg-purple-500', 'bg-purple-400',
                'bg-violet-500', 'bg-violet-400', 'bg-teal-500', 'bg-teal-400',
                'bg-emerald-500', 'bg-emerald-400', 'bg-cyan-500', 'bg-cyan-400',
                'bg-sky-500', 'bg-sky-400', 'bg-orange-500', 'bg-orange-400',
              ];
              const bgColor = colors[i % colors.length];
              return (
                <div class="flex items-center gap-3">
                  <div class="w-44 sm:w-56 flex-shrink-0 text-right">
                    <a href={`/procedures/?category=${encodeURIComponent(cat.key)}`}
                      class="text-sm font-medium text-gray-800 hover:text-brand-600 transition-colors truncate block">
                      {cat.label}
                    </a>
                    <div class="text-xs text-gray-400">{procCount} procedures</div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class={`${bgColor} h-7 rounded-md flex items-center justify-end pr-2 shadow-sm transition-all`}
                      style={`width: ${Math.max(pct, 8)}%`}>
                      <span class="text-white text-xs font-bold whitespace-nowrap">{formatCurrencyFull(cat.value)}</span>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
          <p class="text-xs text-gray-400 mt-4">Based on average national Medicare facility rate per category. Source: CMS PFS CY2026.</p>
        </div>
      </section>
    )}

    <!-- Category Grid -->
    <h2 class="text-2xl font-bold text-gray-900 mb-4">All Categories</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {(categories || []).map(cat => {
        const name = Array.isArray(cat) ? cat[0] : '';
        const count = Array.isArray(cat) ? cat[1] : 0;
        const slug = slugify(name);
        const costInfo = avgCostByCategory.find(c => c.key === name);
        return (
          <a
            href={`/procedures/?category=${encodeURIComponent(name)}`}
            class="bg-white rounded-xl border border-gray-200 p-6 hover:border-brand-500 hover:shadow-md transition-all group"
          >
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-brand-700 mb-1">{name}</h2>
            <div class="flex items-center gap-3">
              <p class="text-sm text-gray-500">{count.toLocaleString()} procedures</p>
              {costInfo && (
                <span class="text-sm font-semibold text-green-700">avg {formatCurrencyFull(costInfo.value)}</span>
              )}
            </div>
          </a>
        );
      })}
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mt-12 mb-6">By Body System</h2>
    <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-4">
      {(bodySystems || []).map(sys => {
        const name = Array.isArray(sys) ? sys[0] : '';
        const count = Array.isArray(sys) ? sys[1] : 0;
        return (
          <a
            href={`/procedures/?bodySystem=${encodeURIComponent(name)}`}
            class="bg-white rounded-lg border border-gray-200 p-4 hover:border-brand-500 transition-all"
          >
            <h3 class="font-semibold text-gray-900">{name}</h3>
            <p class="text-sm text-gray-500">{count.toLocaleString()} procedures</p>
          </a>
        );
      })}
    </div>
  </div>
</Base>
