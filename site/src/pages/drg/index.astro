---
import Base from '@/layouts/Base.astro';
import { getDrgList, formatCurrencyFull } from '@/lib/api';

const search = Astro.url.searchParams.get('search') || '';
const type = Astro.url.searchParams.get('type') || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const limit = 100;
const offset = (page - 1) * limit;

const { data: drgs, pagination } = await getDrgList({
  search,
  type: type || undefined,
  limit,
  offset,
});

const totalPages = Math.ceil((pagination?.total || 0) / limit);

// Separate surgical vs medical
const surgicalDrgs = type ? drgs : drgs.filter(d => d.type === 'SURG');
const medicalDrgs = type ? [] : drgs.filter(d => d.type === 'MED');

const title = search
  ? `"${search}" Hospital Stay Costs — ${pagination.total} DRGs | MedicalCosts.info`
  : type === 'SURG'
    ? `Surgical DRG Costs — Hospital Stay Charges & Payments | MedicalCosts.info`
    : type === 'MED'
      ? `Medical DRG Costs — Hospital Stay Charges & Payments | MedicalCosts.info`
      : `Hospital Stay Costs by DRG — Average Charges & Payments | MedicalCosts.info`;

const description = search
  ? `Find hospital stay costs for "${search}". Average charges, Medicare payments, and length of stay by DRG code.`
  : `Compare hospital stay costs across ${pagination.total?.toLocaleString()}+ Diagnosis-Related Groups (DRGs). Average charges, Medicare payments, and length of stay from CMS data.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Hospital Stay Costs by DRG",
  "url": "https://medicalcosts.info/drg/",
  "description": description,
  "provider": {
    "@type": "Organization",
    "name": "MedicalCosts.info"
  }
};
---

<Base title={title} description={description} canonical="/drg/" schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">Hospital Stay Costs (DRG)</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
      {search ? `Hospital Stay Costs for "${search}"` : type === 'SURG' ? 'Surgical Hospital Stay Costs' : type === 'MED' ? 'Medical Hospital Stay Costs' : 'Hospital Stay Costs by DRG'}
    </h1>
    <p class="text-gray-500 mb-8">
      {pagination.total?.toLocaleString()} Diagnosis-Related Groups with average charges, Medicare payments, and length of stay
    </p>

    <!-- Search -->
    <form action="/drg/" method="GET" class="flex gap-2 max-w-xl mb-6">
      <input
        type="text"
        name="search"
        value={search}
        placeholder="Search DRGs (e.g. hip replacement, pneumonia, heart failure)..."
        class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
      />
      <button type="submit" class="px-6 py-3 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700">Search</button>
    </form>

    <!-- Type filter pills -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a
        href="/drg/"
        class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${!type && !search ? 'bg-brand-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
      >All DRGs</a>
      <a
        href="/drg/?type=SURG"
        class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${type === 'SURG' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100'}`}
      >Surgical</a>
      <a
        href="/drg/?type=MED"
        class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${type === 'MED' ? 'bg-blue-600 text-white' : 'bg-blue-50 text-blue-700 hover:bg-blue-100'}`}
      >Medical</a>
    </div>

    <!-- Results -->
    {(type || search) ? (
      <!-- Single list when filtered -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-8">
        <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 bg-gray-50 border-b text-xs font-semibold text-gray-500 uppercase">
          <div class="col-span-1">DRG</div>
          <div class="col-span-4">Description</div>
          <div class="col-span-1">Type</div>
          <div class="col-span-2 text-right">Avg Medicare Payment</div>
          <div class="col-span-2 text-right">Avg Length of Stay</div>
          <div class="col-span-2 text-right">Discharges</div>
        </div>
        {drgs.map(drg => (
          <a
            href={`/drg/${drg.drgCode}/`}
            class="grid grid-cols-12 gap-4 px-6 py-4 border-b border-gray-100 hover:bg-blue-50 transition-colors items-center group"
          >
            <div class="col-span-12 md:col-span-1">
              <span class="font-mono text-sm text-brand-600 font-bold">{drg.drgCode}</span>
            </div>
            <div class="col-span-12 md:col-span-4">
              <span class="text-sm font-medium text-gray-900 group-hover:text-brand-700 line-clamp-2">{drg.description}</span>
            </div>
            <div class="col-span-4 md:col-span-1">
              <span class={`inline-flex px-2 py-0.5 rounded-full text-xs font-medium ${drg.type === 'SURG' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700'}`}>
                {drg.type === 'SURG' ? 'Surgical' : 'Medical'}
              </span>
            </div>
            <div class="col-span-4 md:col-span-2 text-right">
              <span class="text-sm font-semibold text-gray-900">
                {drg.avgMedicarePayment ? formatCurrencyFull(Math.round(drg.avgMedicarePayment)) : '—'}
              </span>
            </div>
            <div class="col-span-2 md:col-span-2 text-right">
              <span class="text-sm text-gray-600">
                {drg.avgLengthOfStay ? `${drg.avgLengthOfStay} days` : '—'}
              </span>
            </div>
            <div class="col-span-2 md:col-span-2 text-right">
              <span class="text-sm text-gray-500">
                {drg.totalDischarges ? drg.totalDischarges.toLocaleString() : '—'}
              </span>
            </div>
          </a>
        ))}
        {drgs.length === 0 && (
          <div class="px-6 py-12 text-center text-gray-500">
            <p class="text-lg">No DRGs found{search ? ` for "${search}"` : ''}.</p>
            <a href="/drg/" class="text-brand-600 hover:underline mt-2 inline-block">Clear filters</a>
          </div>
        )}
      </div>
    ) : (
      <!-- Grouped view when no filter -->
      <Fragment>
        {surgicalDrgs.length > 0 && (
          <div class="mb-12">
            <div class="flex items-center gap-3 mb-4">
              <span class="px-3 py-1 bg-red-100 text-red-700 text-sm font-bold rounded-full">Surgical DRGs</span>
              <span class="text-sm text-gray-500">{surgicalDrgs.length} procedures</span>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 bg-gray-50 border-b text-xs font-semibold text-gray-500 uppercase">
                <div class="col-span-1">DRG</div>
                <div class="col-span-5">Description</div>
                <div class="col-span-2 text-right">Avg Medicare Payment</div>
                <div class="col-span-2 text-right">Avg Length of Stay</div>
                <div class="col-span-2 text-right">Discharges</div>
              </div>
              {surgicalDrgs.slice(0, 25).map(drg => (
                <a
                  href={`/drg/${drg.drgCode}/`}
                  class="grid grid-cols-12 gap-4 px-6 py-3 border-b border-gray-100 hover:bg-blue-50 transition-colors items-center group"
                >
                  <div class="col-span-12 md:col-span-1">
                    <span class="font-mono text-sm text-brand-600 font-bold">{drg.drgCode}</span>
                  </div>
                  <div class="col-span-12 md:col-span-5">
                    <span class="text-sm font-medium text-gray-900 group-hover:text-brand-700 line-clamp-1">{drg.description}</span>
                  </div>
                  <div class="col-span-4 md:col-span-2 text-right">
                    <span class="text-sm font-semibold text-gray-900">
                      {drg.avgMedicarePayment ? formatCurrencyFull(Math.round(drg.avgMedicarePayment)) : '—'}
                    </span>
                  </div>
                  <div class="col-span-4 md:col-span-2 text-right">
                    <span class="text-sm text-gray-600">
                      {drg.avgLengthOfStay ? `${drg.avgLengthOfStay} days` : '—'}
                    </span>
                  </div>
                  <div class="col-span-4 md:col-span-2 text-right">
                    <span class="text-sm text-gray-500">
                      {drg.totalDischarges ? drg.totalDischarges.toLocaleString() : '—'}
                    </span>
                  </div>
                </a>
              ))}
            </div>
            {surgicalDrgs.length > 25 && (
              <div class="text-center mt-4">
                <a href="/drg/?type=SURG" class="text-brand-600 font-semibold hover:underline">View all surgical DRGs →</a>
              </div>
            )}
          </div>
        )}

        {medicalDrgs.length > 0 && (
          <div class="mb-12">
            <div class="flex items-center gap-3 mb-4">
              <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm font-bold rounded-full">Medical DRGs</span>
              <span class="text-sm text-gray-500">{medicalDrgs.length} diagnoses</span>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 bg-gray-50 border-b text-xs font-semibold text-gray-500 uppercase">
                <div class="col-span-1">DRG</div>
                <div class="col-span-5">Description</div>
                <div class="col-span-2 text-right">Avg Medicare Payment</div>
                <div class="col-span-2 text-right">Avg Length of Stay</div>
                <div class="col-span-2 text-right">Discharges</div>
              </div>
              {medicalDrgs.slice(0, 25).map(drg => (
                <a
                  href={`/drg/${drg.drgCode}/`}
                  class="grid grid-cols-12 gap-4 px-6 py-3 border-b border-gray-100 hover:bg-blue-50 transition-colors items-center group"
                >
                  <div class="col-span-12 md:col-span-1">
                    <span class="font-mono text-sm text-brand-600 font-bold">{drg.drgCode}</span>
                  </div>
                  <div class="col-span-12 md:col-span-5">
                    <span class="text-sm font-medium text-gray-900 group-hover:text-brand-700 line-clamp-1">{drg.description}</span>
                  </div>
                  <div class="col-span-4 md:col-span-2 text-right">
                    <span class="text-sm font-semibold text-gray-900">
                      {drg.avgMedicarePayment ? formatCurrencyFull(Math.round(drg.avgMedicarePayment)) : '—'}
                    </span>
                  </div>
                  <div class="col-span-4 md:col-span-2 text-right">
                    <span class="text-sm text-gray-600">
                      {drg.avgLengthOfStay ? `${drg.avgLengthOfStay} days` : '—'}
                    </span>
                  </div>
                  <div class="col-span-4 md:col-span-2 text-right">
                    <span class="text-sm text-gray-500">
                      {drg.totalDischarges ? drg.totalDischarges.toLocaleString() : '—'}
                    </span>
                  </div>
                </a>
              ))}
            </div>
            {medicalDrgs.length > 25 && (
              <div class="text-center mt-4">
                <a href="/drg/?type=MED" class="text-brand-600 font-semibold hover:underline">View all medical DRGs →</a>
              </div>
            )}
          </div>
        )}
      </Fragment>
    )}

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="flex justify-center gap-2 mt-8">
        {page > 1 && (
          <a href={`/drg/?${new URLSearchParams({ ...(search ? { search } : {}), ...(type ? { type } : {}), page: String(page - 1) })}`}
             class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm hover:bg-gray-50">&larr; Previous</a>
        )}
        <span class="px-4 py-2 text-sm text-gray-500">Page {page} of {totalPages}</span>
        {page < totalPages && (
          <a href={`/drg/?${new URLSearchParams({ ...(search ? { search } : {}), ...(type ? { type } : {}), page: String(page + 1) })}`}
             class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Next &rarr;</a>
        )}
      </div>
    )}

    <!-- Info Section -->
    <div class="mt-12 bg-gray-50 rounded-xl p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What is a DRG?</h2>
      <p class="text-gray-600 mb-4">
        A <strong>Diagnosis-Related Group (DRG)</strong> is how Medicare classifies hospital inpatient stays for payment purposes.
        Each DRG groups patients with similar diagnoses and treatments, establishing a standard payment amount regardless
        of the actual costs incurred by the hospital.
      </p>
      <div class="grid md:grid-cols-3 gap-6 mt-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Average Medicare Payment</h3>
          <p class="text-sm text-gray-600">
            The amount Medicare pays the hospital for this DRG. This is a national average — actual payments vary by
            hospital wage index, teaching status, and case mix.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Average Length of Stay</h3>
          <p class="text-sm text-gray-600">
            The typical number of days patients spend in the hospital for this DRG. Hospitals receive the same DRG payment
            whether the stay is shorter or longer than average.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Surgical vs. Medical</h3>
          <p class="text-sm text-gray-600">
            Surgical DRGs involve operating room procedures. Medical DRGs are for non-surgical hospital stays.
            Surgical DRGs generally have higher payments due to greater resource use.
          </p>
        </div>
      </div>
    </div>
  </div>
</Base>
