---
import Base from '@/layouts/Base.astro';
import { formatCurrencyFull } from '@/lib/api';

import { API_BASE } from '@/lib/config';

const brand = Astro.url.searchParams.get('brand') || '';
let comparisonData: any = null;
let topExpensive: any[] = [];

if (brand) {
  try {
    const res = await fetch(`${API_BASE}/api/drugs/compare?brand=${encodeURIComponent(brand)}`);
    const json = await res.json();
    if (json.success) comparisonData = json.data;
  } catch {}
}

// Always load top expensive brand drugs with generic alternatives
try {
  const res = await fetch(`${API_BASE}/api/procedures?category=Prescription+Drug+-+Brand&limit=20&offset=0`);
  const json = await res.json();
  topExpensive = (json.data || []).filter((d: any) => d.nationalNonFacRate > 100).sort((a: any, b: any) => (b.nationalNonFacRate || 0) - (a.nationalNonFacRate || 0)).slice(0, 20);
} catch {}

const title = brand
  ? `${brand.charAt(0).toUpperCase() + brand.slice(1)} Generic Alternatives & Pricing | MedicalCosts.info`
  : 'Brand vs Generic Drug Prices — Compare & Save | MedicalCosts.info';
const description = 'Compare brand name vs generic drug prices. Brand drugs average $234/unit while generics average $3.91/unit — a 60x difference. Find cheaper alternatives and save thousands per year.';

function formatNadacPrice(rate: number | null): string {
  if (rate == null) return 'N/A';
  if (rate < 0.01) return '<$0.01';
  if (rate < 1) return `$${rate.toFixed(4)}`;
  return `$${rate.toFixed(2)}`;
}

function drugDisplayName(desc: string): string {
  return desc.split(' ').map((w: string, i: number) => {
    if (i === 0) return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
    if (/^\d/.test(w) || ['MG', 'ML', 'MCG', 'GM', 'TAB', 'CAP', 'SOLN', 'SUSP', 'INJ', 'TABLET', 'CAPSULE'].includes(w.toUpperCase())) return w;
    return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
  }).join(' ');
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Brand vs Generic Drug Price Comparison",
  "url": "https://medicalcosts.info/drugs/compare/",
  "description": description,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much cheaper are generic drugs compared to brand name?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Generic drugs average $3.91 per unit (NADAC) compared to $234 per unit for brand name drugs — approximately 60 times cheaper. Switching from a brand name to a generic equivalent can save patients $500 to $10,000+ per year depending on the medication."
      }
    },
    {
      "@type": "Question",
      "name": "Are generic drugs as effective as brand name drugs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The FDA requires generic drugs to have the same active ingredient, strength, dosage form, and route of administration as the brand-name drug. They must also meet the same quality, purity, and potency standards. Generic drugs are required to work the same way in the body (bioequivalence)."
      }
    },
    {
      "@type": "Question",
      "name": "Why are brand name drugs so much more expensive?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Brand name drug prices include the cost of research, development, and clinical trials (often $1-2 billion per drug), plus marketing costs. Patent protection gives manufacturers exclusive rights for ~20 years. After patents expire, generic manufacturers can produce the same drug at a fraction of the cost because they don't bear the original R&D expenses."
      }
    }
  ]
};
---

<Base title={title} description={description} canonical="/drugs/compare/" schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/drugs/" class="hover:text-brand-600">Drug Prices</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">Compare Brand vs Generic</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
      Brand vs Generic Drug Prices — Compare & Save
    </h1>
    <p class="text-lg text-gray-600 mb-8">
      Brand name drugs average <strong class="text-purple-700">$234/unit</strong> while generics average
      <strong class="text-green-700">$3.91/unit</strong> — a <strong>60x price difference</strong>.
      Enter a brand drug name below to find cheaper generic alternatives.
    </p>

    <!-- Stat Cards -->
    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      <div class="bg-purple-50 rounded-xl border border-purple-200 p-5 text-center">
        <div class="text-sm text-purple-600 font-medium mb-1">Avg Brand Drug</div>
        <div class="text-3xl font-bold text-purple-700">$234</div>
        <div class="text-xs text-purple-500 mt-1">NADAC per unit</div>
      </div>
      <div class="bg-green-50 rounded-xl border border-green-200 p-5 text-center">
        <div class="text-sm text-green-600 font-medium mb-1">Avg Generic Drug</div>
        <div class="text-3xl font-bold text-green-700">$3.91</div>
        <div class="text-xs text-green-500 mt-1">NADAC per unit</div>
      </div>
      <div class="bg-blue-50 rounded-xl border border-blue-200 p-5 text-center">
        <div class="text-sm text-blue-600 font-medium mb-1">Potential Savings</div>
        <div class="text-3xl font-bold text-blue-700">60x</div>
        <div class="text-xs text-blue-500 mt-1">Lower cost with generics</div>
      </div>
    </div>

    <!-- Search Form -->
    <div class="bg-white rounded-xl border-2 border-brand-200 p-6 mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-3">Find Generic Alternatives</h2>
      <form action="/drugs/compare/" method="GET" class="flex gap-2 max-w-xl">
        <input
          type="text"
          name="brand"
          value={brand}
          placeholder="Enter a brand drug name (e.g. Lipitor, Ozempic, Humira)..."
          class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
        />
        <button type="submit" class="px-6 py-3 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700">
          Compare
        </button>
      </form>
    </div>

    {/* Comparison Results */}
    {comparisonData && (
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          Results for "{brand}"
        </h2>

        {/* Brand drugs found */}
        <div class="mb-6">
          <h3 class="text-lg font-semibold text-purple-700 mb-3">Brand Name Versions</h3>
          <div class="bg-white rounded-xl border border-purple-200 overflow-hidden">
            {comparisonData.brand.map((drug: any) => (
              <a href={`/drugs/${drug.code}/`} class="flex justify-between items-center px-5 py-3 border-b border-gray-100 hover:bg-purple-50 transition-colors">
                <div>
                  <span class="text-sm font-medium text-gray-900">{drugDisplayName(drug.description)}</span>
                  <span class="ml-2 inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">Brand</span>
                </div>
                <div class="text-right">
                  <span class="text-sm font-bold text-purple-700">{formatNadacPrice(drug.nadacPerUnit)}</span>
                  <span class="text-xs text-gray-400 ml-1">/unit</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        {/* Generic alternatives */}
        {comparisonData.generics && comparisonData.generics.length > 0 ? (
          <div>
            <h3 class="text-lg font-semibold text-green-700 mb-3">Generic Alternatives</h3>
            <div class="bg-white rounded-xl border border-green-200 overflow-hidden">
              {comparisonData.generics.map((drug: any) => (
                <a href={`/drugs/${drug.code}/`} class="flex flex-wrap justify-between items-center px-5 py-3 border-b border-gray-100 hover:bg-green-50 transition-colors gap-2">
                  <div class="flex-1 min-w-0">
                    <span class="text-sm font-medium text-gray-900 truncate block">{drugDisplayName(drug.description)}</span>
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Generic</span>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <span class="text-sm font-bold text-green-700">{formatNadacPrice(drug.nadacPerUnit)}</span>
                    <span class="text-xs text-gray-400 ml-1">/unit</span>
                    {drug.percentCheaper > 0 && (
                      <div class="text-xs text-green-600 font-semibold">{drug.percentCheaper}% cheaper</div>
                    )}
                  </div>
                </a>
              ))}
            </div>

            {/* Savings highlight */}
            {comparisonData.potentialAnnualSavings && comparisonData.potentialAnnualSavings > 0 && (
              <div class="mt-4 bg-green-50 border border-green-300 rounded-xl p-5">
                <div class="text-lg font-bold text-green-800">
                  Potential Annual Savings: {formatCurrencyFull(comparisonData.potentialAnnualSavings)}
                </div>
                <p class="text-sm text-green-700 mt-1">
                  Switch from {drugDisplayName(comparisonData.brand[0].description)} ({formatNadacPrice(comparisonData.brandAvgPerUnit)}/unit)
                  to the cheapest generic ({formatNadacPrice(comparisonData.cheapestGenericPerUnit)}/unit)
                  and save up to {formatCurrencyFull(comparisonData.potentialAnnualSavings)} per year (based on 1 unit/day).
                </p>
              </div>
            )}
          </div>
        ) : (
          <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-5">
            <p class="text-yellow-800 font-medium">No generic alternatives found with matching dosage forms in our NADAC database.</p>
            <p class="text-sm text-yellow-700 mt-1">This drug may still be under patent protection, or generic equivalents may be listed under a different dosage form. Ask your pharmacist about alternatives.</p>
          </div>
        )}
      </div>
    )}

    {/* Top 20 Most Expensive Brand Drugs */}
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Most Expensive Brand Name Drugs</h2>
      <p class="text-gray-600 mb-4">Top 20 highest-cost brand medications by NADAC pharmacy acquisition price</p>

      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 bg-gray-50 border-b text-xs font-semibold text-gray-500 uppercase">
          <div class="col-span-1">#</div>
          <div class="col-span-6">Drug Name</div>
          <div class="col-span-2 text-right">NADAC / Unit</div>
          <div class="col-span-3 text-right">Est. Monthly</div>
        </div>

        {topExpensive.map((drug: any, idx: number) => {
          const nadac = drug.nationalNonFacRate || drug.nationalFacilityRate;
          return (
            <a
              href={`/drugs/${drug.code}/`}
              class="grid grid-cols-12 gap-4 px-6 py-3 border-b border-gray-100 hover:bg-blue-50 transition-colors items-center group"
            >
              <div class="col-span-1 text-sm text-gray-400 font-mono">{idx + 1}</div>
              <div class="col-span-12 md:col-span-6">
                <span class="text-sm font-medium text-gray-900 group-hover:text-brand-700">{drugDisplayName(drug.description)}</span>
                <span class="ml-2 inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">Brand</span>
              </div>
              <div class="col-span-6 md:col-span-2 text-right">
                <span class="text-sm font-bold text-gray-900">{formatNadacPrice(nadac)}</span>
              </div>
              <div class="col-span-6 md:col-span-3 text-right">
                <span class="text-sm text-gray-600">{nadac ? formatCurrencyFull(Math.round(nadac * 30)) : '--'}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="bg-gray-50 rounded-xl p-8 mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Brand vs Generic: Frequently Asked Questions</h2>
      <div class="space-y-6">
        <div>
          <h3 class="font-semibold text-gray-900 text-lg">How much cheaper are generic drugs compared to brand name?</h3>
          <p class="text-gray-600 mt-1">
            Generic drugs average $3.91 per unit (NADAC) compared to $234 per unit for brand name drugs — approximately
            60 times cheaper. Switching from brand to generic can save patients $500 to $10,000+ per year.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 text-lg">Are generic drugs as effective as brand name drugs?</h3>
          <p class="text-gray-600 mt-1">
            Yes. The FDA requires generic drugs to have the same active ingredient, strength, dosage form, and route of
            administration. They must meet identical quality, purity, and potency standards and demonstrate bioequivalence.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 text-lg">Why are brand name drugs so much more expensive?</h3>
          <p class="text-gray-600 mt-1">
            Brand name prices include R&D costs ($1-2 billion per drug), clinical trial expenses, and marketing.
            Patent protection gives manufacturers exclusive rights for ~20 years. After patents expire, generic manufacturers
            can produce the same drug without bearing original R&D costs.
          </p>
        </div>
      </div>
    </div>

    <!-- Internal links -->
    <div class="grid md:grid-cols-3 gap-4">
      <a href="/drugs/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-bold text-gray-900 mb-1">Browse All Drugs</h3>
        <p class="text-sm text-gray-500">10,000+ medications with NADAC pricing</p>
      </a>
      <a href="/drugs/glp1/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-bold text-gray-900 mb-1">GLP-1 Drug Costs</h3>
        <p class="text-sm text-gray-500">Ozempic, Wegovy, Mounjaro pricing</p>
      </a>
      <a href="/drugs/?type=generic" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-bold text-gray-900 mb-1">Generic Drugs</h3>
        <p class="text-sm text-gray-500">Affordable alternatives to brand names</p>
      </a>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
