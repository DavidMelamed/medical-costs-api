---
import Base from '@/layouts/Base.astro';
import { getDrug, formatCurrencyFull } from '@/lib/api';

const { code } = Astro.params;
if (!code) return Astro.redirect('/drugs/');

const drug = await getDrug(code);
if (!drug) return Astro.redirect('/drugs/');

const d = drug as any;
const isBrand = d.category === 'Prescription Drug - Brand';
const nadacPerUnit = d.nationalFacilityRate || d.nationalNonFacRate || 0;
const est30Day = nadacPerUnit * 30;
const est90Day = nadacPerUnit * 90;
const estRetailPerUnit = nadacPerUnit * 1.35; // ~35% pharmacy markup estimate
const estRetail30Day = estRetailPerUnit * 30;

function drugDisplayName(desc: string): string {
  return desc.split(' ').map((w: string, i: number) => {
    if (i === 0) return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
    if (/^\d/.test(w) || ['MG', 'ML', 'MCG', 'GM', 'TAB', 'CAP', 'SOLN', 'SUSP', 'INJ', 'TABLET', 'CAPSULE', 'CREAM', 'OINT', 'DROP', 'PATCH'].includes(w.toUpperCase())) return w;
    return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
  }).join(' ');
}

function formatNadacPrice(rate: number): string {
  if (rate < 0.01) return '<$0.01';
  if (rate < 1) return `$${rate.toFixed(4)}`;
  return `$${rate.toFixed(2)}`;
}

const displayName = drugDisplayName(d.description);
// Extract just the drug name (first word or two) for FAQ
const drugBaseName = d.description.split(/\s+\d/)[0].trim();
const drugBaseNameFormatted = drugDisplayName(drugBaseName);

const title = `How Much Does ${drugBaseNameFormatted} Cost? — 2026 NADAC Price | MedicalCosts.info`;
const description = `${displayName} costs ${formatNadacPrice(nadacPerUnit)} per unit (NADAC). ${isBrand ? 'Brand name' : 'Generic'} medication. Estimated 30-day supply: ${formatCurrencyFull(Math.round(est30Day * 100) / 100)}. CMS pharmacy acquisition cost data.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": displayName,
  "category": isBrand ? "Brand Name Prescription Drug" : "Generic Prescription Drug",
  "offers": {
    "@type": "Offer",
    "price": nadacPerUnit,
    "priceCurrency": "USD",
    "description": "NADAC pharmacy acquisition cost per unit",
    "availability": "https://schema.org/InStock",
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How much does ${drugBaseNameFormatted} cost?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The pharmacy acquisition cost (NADAC) for ${displayName} is ${formatNadacPrice(nadacPerUnit)} per unit. A 30-day supply costs approximately ${formatCurrencyFull(Math.round(est30Day * 100) / 100)} at acquisition cost. Retail prices with pharmacy markup are typically 20-50% higher.`
      }
    },
    {
      "@type": "Question",
      "name": `How much does ${drugBaseNameFormatted} cost without insurance?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Without insurance, ${drugBaseNameFormatted} typically costs ${formatCurrencyFull(Math.round(estRetail30Day * 100) / 100)} or more for a 30-day supply at retail pharmacies. The base NADAC cost is ${formatNadacPrice(nadacPerUnit)} per unit, but pharmacies add dispensing fees and markup. Ask about discount programs — GoodRx, RxSaver, or manufacturer coupons can significantly reduce costs.`
      }
    },
    {
      "@type": "Question",
      "name": `Is there a generic version of ${drugBaseNameFormatted}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": isBrand
          ? `${drugBaseNameFormatted} is a brand name medication. Generic alternatives may be available — ask your pharmacist or search our drug database for equivalent generics, which typically cost 80-85% less.`
          : `${drugBaseNameFormatted} is already a generic medication, which means it is typically the most affordable version available.`
      }
    },
  ]
};
---

<Base title={title} description={description} canonical={`/drugs/${code}/`} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/drugs/" class="hover:text-brand-600">Drug Prices</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">{drugBaseNameFormatted}</span>
    </nav>

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Header -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class={`inline-flex px-3 py-1 rounded-full text-sm font-semibold ${isBrand ? 'bg-purple-100 text-purple-700' : 'bg-green-100 text-green-700'}`}>
              {isBrand ? 'Brand Name' : 'Generic'}
            </span>
            <span class="text-sm text-gray-500">NDC {d.code}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
            {displayName}
          </h1>
          <p class="text-gray-500">NADAC pharmacy acquisition cost from CMS</p>
        </div>

        <!-- Cost Cards -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-white rounded-xl border-2 border-brand-500 p-5">
            <div class="text-sm text-gray-500 mb-1">NADAC Per Unit</div>
            <div class="text-3xl font-bold text-brand-700">{formatNadacPrice(nadacPerUnit)}</div>
            <div class="text-xs text-gray-400 mt-1">Pharmacy acquisition cost</div>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-sm text-gray-500 mb-1">Est. 30-Day Supply</div>
            <div class="text-2xl font-bold text-gray-900">{formatCurrencyFull(Math.round(est30Day * 100) / 100)}</div>
            <div class="text-xs text-gray-400 mt-1">At NADAC cost (1/day)</div>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-sm text-gray-500 mb-1">Est. 90-Day Supply</div>
            <div class="text-2xl font-bold text-gray-900">{formatCurrencyFull(Math.round(est90Day * 100) / 100)}</div>
            <div class="text-xs text-gray-400 mt-1">At NADAC cost (1/day)</div>
          </div>
          <div class="bg-white rounded-xl border border-orange-200 p-5">
            <div class="text-sm text-gray-500 mb-1">Est. Retail Price / Unit</div>
            <div class="text-2xl font-bold text-orange-700">{formatNadacPrice(estRetailPerUnit)}</div>
            <div class="text-xs text-gray-400 mt-1">~35% pharmacy markup</div>
          </div>
          <div class="bg-white rounded-xl border border-orange-200 p-5">
            <div class="text-sm text-gray-500 mb-1">Est. Retail 30-Day</div>
            <div class="text-2xl font-bold text-orange-700">{formatCurrencyFull(Math.round(estRetail30Day * 100) / 100)}</div>
            <div class="text-xs text-gray-400 mt-1">Without insurance</div>
          </div>
        </div>

        <!-- How pricing works -->
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Understanding Drug Pricing</h2>
          <div class="space-y-4 text-sm text-gray-600">
            <div class="flex gap-3">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center font-bold text-xs">1</div>
              <div>
                <strong class="text-gray-900">NADAC (shown above)</strong> — What the pharmacy pays the wholesaler for this drug.
                This is the most transparent baseline cost, published weekly by CMS.
              </div>
            </div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center font-bold text-xs">2</div>
              <div>
                <strong class="text-gray-900">Retail Price</strong> — Pharmacies add a dispensing fee ($2-$15) and markup (20-50%).
                This is what you pay without insurance or discount cards.
              </div>
            </div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center font-bold text-xs">3</div>
              <div>
                <strong class="text-gray-900">Insurance Copay</strong> — With insurance, you typically pay a flat copay
                ($5-$15 generic, $25-$50 brand) regardless of the NADAC cost.
              </div>
            </div>
          </div>
        </div>

        <!-- FAQ -->
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
          <div class="space-y-4">
            <div>
              <h3 class="font-semibold text-gray-900">How much does {drugBaseNameFormatted} cost?</h3>
              <p class="text-gray-600 text-sm mt-1">
                The pharmacy acquisition cost (NADAC) for {displayName} is {formatNadacPrice(nadacPerUnit)} per unit.
                A 30-day supply at 1 unit per day costs approximately {formatCurrencyFull(Math.round(est30Day * 100) / 100)}.
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">How much does {drugBaseNameFormatted} cost without insurance?</h3>
              <p class="text-gray-600 text-sm mt-1">
                Without insurance, expect to pay approximately {formatCurrencyFull(Math.round(estRetail30Day * 100) / 100)} for a 30-day supply.
                Pharmacy discount programs (GoodRx, RxSaver, Cost Plus Drugs) and manufacturer coupons can reduce this significantly.
                {isBrand ? ' Ask your doctor if a generic alternative is available — generics typically cost 80-85% less.' : ''}
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Is {drugBaseNameFormatted} available as a generic?</h3>
              <p class="text-gray-600 text-sm mt-1">
                {isBrand
                  ? `${drugBaseNameFormatted} is a brand name medication. Generic alternatives may be available. Ask your pharmacist about equivalent generics which can save 80-85%.`
                  : `Yes, ${drugBaseNameFormatted} is a generic medication and is typically the most affordable option.`
                }
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="bg-brand-50 rounded-xl p-6 border border-brand-200">
          <h3 class="font-bold text-brand-900 mb-3">Drug Details</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-gray-500">NDC Code</dt>
              <dd class="font-mono font-bold">{d.code}</dd>
            </div>
            <div>
              <dt class="text-gray-500">Type</dt>
              <dd>
                <span class={`inline-flex px-2 py-0.5 rounded-full text-xs font-medium ${isBrand ? 'bg-purple-100 text-purple-700' : 'bg-green-100 text-green-700'}`}>
                  {isBrand ? 'Brand Name' : 'Generic'}
                </span>
              </dd>
            </div>
            <div>
              <dt class="text-gray-500">NADAC Per Unit</dt>
              <dd class="font-bold text-brand-700">{formatNadacPrice(nadacPerUnit)}</dd>
            </div>
            <div>
              <dt class="text-gray-500">Data Source</dt>
              <dd class="text-xs">CMS NADAC (CY {d.effectiveYear})</dd>
            </div>
          </dl>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-bold text-gray-900 mb-3">Cost Saving Tips</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            {isBrand && <li>Ask about generic alternatives (save 80-85%)</li>}
            <li>Compare prices at different pharmacies</li>
            <li>Use GoodRx or RxSaver discount cards</li>
            <li>Ask about 90-day mail-order supplies</li>
            <li>Check manufacturer patient assistance programs</li>
            <li>Consider Mark Cuban's Cost Plus Drugs</li>
          </ul>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-bold text-gray-900 mb-3">Related</h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/drugs/" class="text-brand-600 hover:underline">Browse All Drug Prices</a>
            </li>
            <li>
              <a href={`/drugs/?type=${isBrand ? 'brand' : 'generic'}`} class="text-brand-600 hover:underline">
                {isBrand ? 'All Brand Name Drugs' : 'All Generic Drugs'}
              </a>
            </li>
            <li>
              <a href="/procedures/" class="text-brand-600 hover:underline">Medical Procedure Costs</a>
            </li>
            <li>
              <a href="/drg/" class="text-brand-600 hover:underline">Hospital Stay Costs</a>
            </li>
          </ul>
        </div>

        <div class="bg-yellow-50 rounded-xl p-5 border border-yellow-200">
          <h3 class="font-bold text-yellow-800 text-sm mb-2">Disclaimer</h3>
          <p class="text-xs text-yellow-700">
            NADAC prices shown are pharmacy acquisition costs and do not reflect what consumers pay at the counter.
            Actual costs vary by pharmacy, insurance plan, and discount programs.
            This is not medical or financial advice.
          </p>
        </div>
      </aside>
    </div>
  </div>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
