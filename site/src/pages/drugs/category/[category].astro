---
import Base from '@/layouts/Base.astro';
import { formatCurrencyFull } from '@/lib/api';

import { API_BASE } from '@/lib/config';

const { category } = Astro.params;
if (!category) return Astro.redirect('/drugs/');

// Category definitions with drug name search keywords
const CATEGORIES: Record<string, { name: string; description: string; longDescription: string; keywords: string[] }> = {
  'pain-medications': {
    name: 'Pain Medications',
    description: 'Analgesics, NSAIDs, opioids, and pain management drugs with NADAC pharmacy acquisition costs.',
    longDescription: 'Pain medications include non-steroidal anti-inflammatory drugs (NSAIDs) like ibuprofen and naproxen, opioid analgesics like oxycodone and hydrocodone, neuropathic pain drugs like gabapentin and pregabalin, and topical pain relievers. Generic pain medications are among the most affordable drugs available, while brand-name formulations can cost significantly more.',
    keywords: ['IBUPROFEN', 'ACETAMINOPHEN', 'NAPROXEN', 'TRAMADOL', 'OXYCODONE', 'HYDROCODONE', 'MORPHINE', 'GABAPENTIN', 'PREGABALIN', 'MELOXICAM', 'DICLOFENAC', 'CELECOXIB', 'KETOROLAC', 'CODEINE', 'FENTANYL', 'HYDROMORPHONE', 'METHADONE', 'BUPRENORPHINE', 'LIDOCAINE'],
  },
  'antibiotics': {
    name: 'Antibiotics',
    description: 'Antibiotic drug prices for common bacterial infections. Compare generic and brand-name antibiotic costs.',
    longDescription: 'Antibiotics are among the most commonly prescribed medications. Most are available as affordable generics. Common classes include penicillins (amoxicillin), macrolides (azithromycin), fluoroquinolones (ciprofloxacin), tetracyclines (doxycycline), and cephalosporins (cephalexin). Generic antibiotics typically cost under $1 per unit at NADAC.',
    keywords: ['AMOXICILLIN', 'AZITHROMYCIN', 'CIPROFLOXACIN', 'DOXYCYCLINE', 'LEVOFLOXACIN', 'METRONIDAZOLE', 'CEPHALEXIN', 'CLINDAMYCIN', 'SULFAMETHOXAZOLE', 'NITROFURANTOIN', 'PENICILLIN', 'AUGMENTIN', 'CEFTRIAXONE', 'VANCOMYCIN', 'ERYTHROMYCIN', 'TETRACYCLINE'],
  },
  'heart-medications': {
    name: 'Heart & Cardiovascular Medications',
    description: 'Heart medication costs including beta-blockers, blood thinners, and antiarrhythmics with NADAC pricing.',
    longDescription: 'Cardiovascular medications include beta-blockers (metoprolol, carvedilol), blood thinners (warfarin, apixaban/Eliquis, rivaroxaban/Xarelto), antiarrhythmics (amiodarone), and antiplatelet agents (clopidogrel). Generic beta-blockers and warfarin are very affordable, while newer blood thinners like Eliquis remain expensive brand-name drugs.',
    keywords: ['METOPROLOL', 'CARVEDILOL', 'DIGOXIN', 'AMIODARONE', 'WARFARIN', 'APIXABAN', 'RIVAROXABAN', 'CLOPIDOGREL', 'DILTIAZEM', 'VERAPAMIL', 'NITROGLYCERIN', 'ISOSORBIDE', 'ELIQUIS', 'XARELTO'],
  },
  'diabetes-drugs': {
    name: 'Diabetes Medications',
    description: 'Diabetes drug prices including insulin, metformin, GLP-1 drugs, and SGLT2 inhibitors from CMS NADAC data.',
    longDescription: 'Diabetes medications range from very affordable generics (metformin at pennies per tablet) to expensive brand-name biologics (GLP-1 drugs at $500-1,000+/month). This category includes oral medications (metformin, glipizide, pioglitazone), injectable insulin, GLP-1 receptor agonists (Ozempic, Mounjaro), and SGLT2 inhibitors (Jardiance, Farxiga).',
    keywords: ['METFORMIN', 'INSULIN', 'GLIPIZIDE', 'GLYBURIDE', 'PIOGLITAZONE', 'SITAGLIPTIN', 'JARDIANCE', 'FARXIGA', 'INVOKANA', 'OZEMPIC', 'MOUNJARO', 'TRULICITY', 'RYBELSUS', 'VICTOZA', 'SEMAGLUTIDE', 'TIRZEPATIDE', 'DULAGLUTIDE', 'LIRAGLUTIDE', 'EMPAGLIFLOZIN', 'DAPAGLIFLOZIN'],
  },
  'mental-health': {
    name: 'Mental Health Medications',
    description: 'Mental health drug costs: antidepressants, anti-anxiety, antipsychotics, and mood stabilizer prices.',
    longDescription: 'Mental health medications include SSRIs (sertraline, fluoxetine, escitalopram), SNRIs (venlafaxine, duloxetine), atypical antidepressants (bupropion, trazodone), antipsychotics (quetiapine, aripiprazole), benzodiazepines (alprazolam, lorazepam), and mood stabilizers (lithium, lamotrigine). Most first-line antidepressants are available as affordable generics.',
    keywords: ['SERTRALINE', 'FLUOXETINE', 'ESCITALOPRAM', 'CITALOPRAM', 'VENLAFAXINE', 'DULOXETINE', 'BUPROPION', 'TRAZODONE', 'AMITRIPTYLINE', 'QUETIAPINE', 'ARIPIPRAZOLE', 'RISPERIDONE', 'OLANZAPINE', 'LITHIUM', 'LAMOTRIGINE', 'ALPRAZOLAM', 'LORAZEPAM', 'CLONAZEPAM', 'BUSPIRONE', 'HYDROXYZINE'],
  },
  'blood-pressure': {
    name: 'Blood Pressure Medications',
    description: 'Blood pressure drug prices: ACE inhibitors, ARBs, calcium channel blockers, and diuretics with NADAC costs.',
    longDescription: 'Blood pressure (antihypertensive) medications are among the most prescribed drugs in America. Most are available as very affordable generics. Classes include ACE inhibitors (lisinopril, enalapril), ARBs (losartan, valsartan), calcium channel blockers (amlodipine, nifedipine), diuretics (hydrochlorothiazide, furosemide), and others (clonidine, hydralazine).',
    keywords: ['LISINOPRIL', 'AMLODIPINE', 'LOSARTAN', 'VALSARTAN', 'HYDROCHLOROTHIAZIDE', 'ENALAPRIL', 'RAMIPRIL', 'BENAZEPRIL', 'IRBESARTAN', 'OLMESARTAN', 'TELMISARTAN', 'NIFEDIPINE', 'FUROSEMIDE', 'SPIRONOLACTONE', 'CHLORTHALIDONE', 'CLONIDINE', 'HYDRALAZINE'],
  },
  'cholesterol': {
    name: 'Cholesterol Medications',
    description: 'Cholesterol drug prices including statins, fibrates, and PCSK9 inhibitors with NADAC pharmacy costs.',
    longDescription: 'Cholesterol-lowering medications include statins (atorvastatin, rosuvastatin, simvastatin), cholesterol absorption inhibitors (ezetimibe), fibrates (fenofibrate), and expensive biologic PCSK9 inhibitors (Repatha, Praluent). Generic statins are among the cheapest medications available, often costing just pennies per tablet.',
    keywords: ['ATORVASTATIN', 'ROSUVASTATIN', 'SIMVASTATIN', 'PRAVASTATIN', 'LOVASTATIN', 'EZETIMIBE', 'FENOFIBRATE', 'GEMFIBROZIL', 'REPATHA', 'PRALUENT'],
  },
};

const catInfo = CATEGORIES[category];
if (!catInfo) return Astro.redirect('/drugs/');

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const limit = 50;
const offset = (page - 1) * limit;

// Build search query — search for each keyword
let allDrugs: any[] = [];
let totalCount = 0;

try {
  // Use the first keyword to get paginated results, then we'll do a broader search
  const searchTerms = catInfo.keywords.join('|');
  // We need to fetch from the API using the search parameter
  // Since the API only supports single search, we'll search for each keyword
  // But for efficiency, let's use the category search approach
  const res = await fetch(`${API_BASE}/api/procedures?category=Prescription+Drug&search=${encodeURIComponent(catInfo.keywords[0])}&limit=${limit}&offset=${offset}`);
  const json = await res.json();
  allDrugs = json.data || [];
  totalCount = json.pagination?.total || 0;

  // If we only got results for one keyword, let's try to get a broader view
  // For the "all drugs" count, fetch counts for all keywords
  if (catInfo.keywords.length > 1) {
    // Fetch a few more keywords to supplement
    const supplementKeywords = catInfo.keywords.slice(1, 5);
    for (const kw of supplementKeywords) {
      if (allDrugs.length >= limit) break;
      const supRes = await fetch(`${API_BASE}/api/procedures?category=Prescription+Drug&search=${encodeURIComponent(kw)}&limit=10&offset=0`);
      const supJson = await supRes.json();
      const newDrugs = (supJson.data || []).filter((d: any) => !allDrugs.some((existing: any) => existing.code === d.code));
      allDrugs = [...allDrugs, ...newDrugs].slice(0, limit);
      totalCount = Math.max(totalCount, supJson.pagination?.total || 0);
    }
  }
} catch {}

const totalPages = Math.ceil(totalCount / limit);

function formatNadacPrice(rate: number | null): string {
  if (rate == null) return 'N/A';
  if (rate < 0.01) return '<$0.01';
  if (rate < 1) return `$${rate.toFixed(4)}`;
  return `$${rate.toFixed(2)}`;
}

function drugDisplayName(desc: string): string {
  return desc.split(' ').map((w: string, i: number) => {
    if (i === 0) return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
    if (/^\d/.test(w) || ['MG', 'ML', 'MCG', 'GM', 'TAB', 'CAP', 'SOLN', 'SUSP', 'INJ', 'TABLET', 'CAPSULE'].includes(w.toUpperCase())) return w;
    return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
  }).join(' ');
}

const title = `${catInfo.name} Prices — Drug Costs & NADAC Data (2026) | MedicalCosts.info`;
const description = catInfo.description;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": catInfo.name,
  "url": `https://medicalcosts.info/drugs/category/${category}/`,
  "description": description,
};
---

<Base title={title} description={description} canonical={`/drugs/category/${category}/`} schema={schema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/drugs/" class="hover:text-brand-600">Drug Prices</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">{catInfo.name}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{catInfo.name} — Prices & Costs</h1>
    <p class="text-lg text-gray-600 mb-4">{catInfo.longDescription}</p>
    <p class="text-sm text-gray-500 mb-8">
      Showing NADAC pharmacy acquisition costs from CMS 2026 data. Prices are what pharmacies pay wholesalers.
    </p>

    <!-- Category navigation pills -->
    <div class="flex flex-wrap gap-2 mb-8">
      {Object.entries(CATEGORIES).map(([slug, cat]) => (
        <a
          href={`/drugs/category/${slug}/`}
          class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${slug === category ? 'bg-brand-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
        >{cat.name}</a>
      ))}
    </div>

    <!-- Drug keyword search pills -->
    <div class="flex flex-wrap gap-1.5 mb-6">
      <span class="text-xs text-gray-400 self-center mr-1">Quick search:</span>
      {catInfo.keywords.slice(0, 12).map((kw: string) => (
        <a href={`/drugs/?search=${encodeURIComponent(kw.toLowerCase())}`}
           class="px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 hover:bg-blue-100 transition-colors">
          {kw.charAt(0) + kw.slice(1).toLowerCase()}
        </a>
      ))}
    </div>

    <!-- Results table -->
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 bg-gray-50 border-b text-xs font-semibold text-gray-500 uppercase">
        <div class="col-span-5">Drug Name</div>
        <div class="col-span-2">Type</div>
        <div class="col-span-2 text-right">NADAC / Unit</div>
        <div class="col-span-3 text-right">Est. 30-Day Supply</div>
      </div>

      {allDrugs.map((drug: any) => {
        const isBrand = drug.category === 'Prescription Drug - Brand';
        const nadacPerUnit = drug.nationalFacilityRate || drug.nationalNonFacRate;
        const est30Day = nadacPerUnit ? nadacPerUnit * 30 : null;
        return (
          <a
            href={`/drugs/${drug.code}/`}
            class="grid grid-cols-12 gap-4 px-6 py-4 border-b border-gray-100 hover:bg-blue-50 transition-colors items-center group"
          >
            <div class="col-span-12 md:col-span-5">
              <span class="text-sm font-medium text-gray-900 group-hover:text-brand-700">{drugDisplayName(drug.description)}</span>
            </div>
            <div class="col-span-6 md:col-span-2">
              <span class={`inline-flex px-2 py-0.5 rounded-full text-xs font-medium ${isBrand ? 'bg-purple-100 text-purple-700' : 'bg-green-100 text-green-700'}`}>
                {isBrand ? 'Brand' : 'Generic'}
              </span>
            </div>
            <div class="col-span-3 md:col-span-2 text-right">
              <span class="text-sm font-semibold text-gray-900">
                {nadacPerUnit != null ? formatNadacPrice(nadacPerUnit) : '--'}
              </span>
            </div>
            <div class="col-span-3 md:col-span-3 text-right">
              <span class="text-sm text-gray-600">
                {est30Day != null ? formatCurrencyFull(Math.round(est30Day * 100) / 100) : '--'}
              </span>
            </div>
          </a>
        );
      })}

      {allDrugs.length === 0 && (
        <div class="px-6 py-12 text-center text-gray-500">
          <p class="text-lg">No drugs found in this category.</p>
        </div>
      )}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="flex justify-center gap-2 mt-8">
        {page > 1 && (
          <a href={`/drugs/category/${category}/?page=${page - 1}`}
             class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm hover:bg-gray-50">&larr; Previous</a>
        )}
        <span class="px-4 py-2 text-sm text-gray-500">Page {page} of {totalPages}</span>
        {page < totalPages && (
          <a href={`/drugs/category/${category}/?page=${page + 1}`}
             class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Next &rarr;</a>
        )}
      </div>
    )}

    <!-- Related links -->
    <div class="mt-12 grid md:grid-cols-3 gap-4">
      <a href="/drugs/compare/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-bold text-gray-900 mb-1">Brand vs Generic</h3>
        <p class="text-sm text-gray-500">Compare prices and find savings</p>
      </a>
      <a href="/drugs/glp1/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-bold text-gray-900 mb-1">GLP-1 Drug Costs</h3>
        <p class="text-sm text-gray-500">Ozempic, Wegovy, Mounjaro pricing</p>
      </a>
      <a href="/drugs/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-md transition-all">
        <h3 class="font-bold text-gray-900 mb-1">All Drug Prices</h3>
        <p class="text-sm text-gray-500">Browse 10,000+ medications</p>
      </a>
    </div>
  </div>
</Base>
