---
import Base from '@/layouts/Base.astro';

const title = 'Medical Cost Estimator — Calculate Your Healthcare Costs | MedicalCosts.info';
const description = 'Free medical cost estimator. Select procedures, conditions, or injury types to get estimated costs based on Medicare rates, hospital prices, and commercial insurance data.';
---

<Base title={title} description={description} canonical="/estimator/">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">Cost Estimator</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Medical Cost Estimator</h1>
    <p class="text-gray-500 mb-8 max-w-2xl">
      Estimate your healthcare costs by searching for procedures or conditions. Costs are based on
      CMS Medicare 2026 data with commercial insurance estimates.
    </p>

    <div id="estimator-app">
      <!-- Search -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
        <label for="procedure-search" class="block text-sm font-medium text-gray-700 mb-2">Search for a procedure or condition</label>
        <div class="flex gap-3">
          <input
            id="procedure-search"
            type="text"
            placeholder="e.g., MRI, knee replacement, colonoscopy, 99213..."
            class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-lg"
          />
          <button
            id="search-btn"
            class="px-6 py-3 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700 transition-colors"
          >Search</button>
        </div>
      </div>

      <!-- Results -->
      <div id="results" class="space-y-4"></div>

      <!-- Selected procedures for estimate -->
      <div id="estimate-section" class="hidden mt-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Your Cost Estimate</h2>
        <div id="selected-procedures" class="space-y-3 mb-6"></div>

        <div class="bg-brand-50 rounded-xl border border-brand-200 p-6">
          <div class="grid sm:grid-cols-3 gap-6 text-center">
            <div>
              <div class="text-sm text-gray-500 mb-1">Medicare Rate</div>
              <div id="total-medicare" class="text-3xl font-bold text-brand-700">$0</div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Est. Commercial (Low)</div>
              <div id="total-commercial-low" class="text-3xl font-bold text-gray-900">$0</div>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Est. Commercial (High)</div>
              <div id="total-commercial-high" class="text-3xl font-bold text-orange-700">$0</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const API = 'https://medical-costs-api.david-568.workers.dev/api';
    const selected: Array<{code: string; desc: string; rate: number}> = [];

    const searchInput = document.getElementById('procedure-search') as HTMLInputElement;
    const searchBtn = document.getElementById('search-btn')!;
    const resultsDiv = document.getElementById('results')!;
    const estimateSection = document.getElementById('estimate-section')!;
    const selectedDiv = document.getElementById('selected-procedures')!;

    function fmt(n: number) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    function updateTotals() {
      const medicare = selected.reduce((s, p) => s + p.rate, 0);
      document.getElementById('total-medicare')!.textContent = fmt(medicare);
      document.getElementById('total-commercial-low')!.textContent = fmt(medicare * 1.5);
      document.getElementById('total-commercial-high')!.textContent = fmt(medicare * 2.5);

      estimateSection.classList.toggle('hidden', selected.length === 0);

      selectedDiv.innerHTML = selected.map((p, i) => `
        <div class="flex items-center justify-between bg-white rounded-lg border p-3">
          <div>
            <span class="font-mono text-sm text-blue-600">${p.code}</span>
            <span class="text-sm ml-2">${p.desc}</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="font-semibold">${fmt(p.rate)}</span>
            <button onclick="removeProc(${i})" class="text-red-500 hover:text-red-700 text-sm">Remove</button>
          </div>
        </div>
      `).join('');
    }

    (window as any).removeProc = (i: number) => { selected.splice(i, 1); updateTotals(); };
    (window as any).addProc = (code: string, desc: string, rate: number) => {
      if (!selected.find(p => p.code === code)) {
        selected.push({ code, desc, rate });
        updateTotals();
      }
    };

    async function search() {
      const q = searchInput.value.trim();
      if (!q) return;

      resultsDiv.innerHTML = '<p class="text-gray-500">Searching...</p>';

      try {
        const res = await fetch(`${API}/procedures?search=${encodeURIComponent(q)}&limit=20`);
        const json = await res.json();
        const procs = json.data || [];

        if (procs.length === 0) {
          resultsDiv.innerHTML = '<p class="text-gray-500">No procedures found. Try a different search term.</p>';
          return;
        }

        resultsDiv.innerHTML = procs.map((p: any) => {
          const rate = p.nationalFacilityRate || p.nationalNonFacRate || 0;
          return `
            <div class="bg-white rounded-lg border border-gray-200 p-4 flex items-center justify-between hover:border-blue-300 transition-colors">
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="font-mono text-sm text-blue-600">${p.code}</span>
                  <span class="text-xs text-gray-400">${p.category || ''}</span>
                </div>
                <div class="font-medium text-gray-900 mt-1">${p.description}</div>
              </div>
              <div class="text-right ml-4">
                <div class="font-bold text-lg">${rate > 0 ? fmt(rate) : 'N/A'}</div>
                <button
                  onclick="addProc('${p.code}', '${p.description.replace(/'/g, "\\'")}', ${rate})"
                  class="mt-1 text-sm text-blue-600 hover:text-blue-800 font-medium"
                >+ Add to estimate</button>
              </div>
            </div>
          `;
        }).join('');
      } catch {
        resultsDiv.innerHTML = '<p class="text-red-500">Error searching. Please try again.</p>';
      }
    }

    searchBtn.addEventListener('click', search);
    searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') search(); });
  </script>
</Base>
