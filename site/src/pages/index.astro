---
import Base from '@/layouts/Base.astro';
import { getStatistics, getCategories, formatCurrency, STATES, getTrends } from '@/lib/api';

const stats = await getStatistics();
const { categories } = await getCategories();
const trends = await getTrends();

const cfData = (trends.medicare_conversion_factor || []).filter(d => d.year >= 2018 && d.year <= 2026);
const cfYears = cfData.map(d => d.year);
const cfValues = cfData.map(d => d.value);
const cfMin = Math.floor(Math.min(...cfValues) - 0.5);
const cfMax = Math.ceil(Math.max(...cfValues) + 0.5);
function trendX(year: number) { return 40 + ((year - cfYears[0]) / (cfYears[cfYears.length - 1] - cfYears[0])) * 360; }
function trendY(val: number) { return 15 + 110 - ((val - cfMin) / (cfMax - cfMin)) * 110; }
const trendPoints = cfData.map(d => `${trendX(d.year)},${trendY(d.value)}`).join(' ');

const topCategories = (categories || []).slice(0, 12);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "MedicalCosts.info",
  "url": "https://medicalcosts.info",
  "description": "Free medical procedure cost lookup with 21,000+ procedures. Compare Medicare, hospital, and commercial insurance rates nationwide.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://medicalcosts.info/procedures/?search={search_term}",
    "query-input": "required name=search_term"
  }
};

const popularProcedures = [
  { name: 'MRI (Lumbar Spine)', code: '72148', cost: '$400 - $3,500', costLabel: 'Total cost range', isSurgical: false },
  { name: 'CT Scan (Head)', code: '70450', cost: '$300 - $3,000', costLabel: 'Total cost range', isSurgical: false },
  { name: 'Knee Arthroscopy', code: '29881', cost: '$6,000 - $15,000', costLabel: 'Total estimated cost', isSurgical: true },
  { name: 'Colonoscopy', code: '45378', cost: '$1,000 - $3,500', costLabel: 'Total estimated cost', isSurgical: true },
  { name: 'ER Visit (High Complexity)', code: '99285', cost: '$500 - $3,000', costLabel: 'Total cost range', isSurgical: false },
  { name: 'Physical Therapy (15 min)', code: '97110', cost: '$29 - $32', costLabel: 'Medicare rate', isSurgical: false },
  { name: 'X-Ray (Chest)', code: '71045', cost: '$50 - $400', costLabel: 'Total cost range', isSurgical: false },
  { name: 'Office Visit (Established)', code: '99213', cost: '$57 - $95', costLabel: 'Medicare rate', isSurgical: false },
  { name: 'ACL Reconstruction', code: '27427', cost: '$15,000 - $35,000', costLabel: 'Total estimated cost', isSurgical: true },
  { name: 'Spinal Fusion (Lumbar)', code: '22612', cost: '$25,000 - $75,000', costLabel: 'Total estimated cost', isSurgical: true },
  { name: 'Hip Replacement', code: '27130', cost: '$20,000 - $50,000', costLabel: 'Total estimated cost', isSurgical: true },
  { name: 'Cataract Surgery', code: '66984', cost: '$3,000 - $6,000', costLabel: 'Total estimated cost', isSurgical: true },
];

const popularConditions = [
  { name: 'Heart Attack', slug: 'heart-attack', icon: '&#9829;', color: 'bg-red-100 text-red-600' },
  { name: 'Knee Replacement', slug: 'knee-injury', icon: '&#9898;', color: 'bg-blue-100 text-blue-600' },
  { name: 'Back Pain / Spinal Injury', slug: 'spinal-cord-injury', icon: '&#9646;', color: 'bg-purple-100 text-purple-600' },
  { name: 'Concussion / TBI', slug: 'traumatic-brain-injury', icon: '&#9673;', color: 'bg-orange-100 text-orange-600' },
  { name: 'Broken Bones', slug: 'fractures', icon: '&#9874;', color: 'bg-yellow-100 text-yellow-700' },
  { name: 'ACL / Ligament Tear', slug: 'knee-injury', icon: '&#9899;', color: 'bg-green-100 text-green-600' },
  { name: 'Whiplash / Neck Injury', slug: 'whiplash-cervical-strain', icon: '&#8644;', color: 'bg-teal-100 text-teal-600' },
  { name: 'Burns', slug: 'burns', icon: '&#9832;', color: 'bg-amber-100 text-amber-600' },
];

const didYouKnowFacts = [
  { fact: "Manhattan ER visits cost 36% more than rural Arkansas", icon: "&#127961;" },
  { fact: "Average surgery costs 7.1x more than an office visit", icon: "&#9986;" },
  { fact: "One spine surgery equals 468 physical therapy sessions", icon: "&#129516;" },
  { fact: "Alaska is the most expensive state for healthcare ($525 avg)", icon: "&#10052;" },
  { fact: "Brand drugs cost 60x more than generics", icon: "&#128138;" },
];
---

<Base
  title="Medical Procedure Costs — Free Cost Lookup for 21,000+ Procedures | MedicalCosts.info"
  description="Compare medical procedure costs with data from CMS Medicare, hospital outpatient, and ambulatory surgery center rates. 21,000+ procedures, drug prices, and geographic cost comparisons."
  canonical="/"
  schema={schema}
>
  <!-- Hero with animated gradient background -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-700 via-brand-800 to-brand-900 text-white">
    <!-- Subtle animated background pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="hero-pattern absolute inset-0"></div>
    </div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-float"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-indigo-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-float-delayed"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          How Much Does Your Medical Procedure Cost?
        </h1>
        <p class="text-xl text-blue-100 mb-8">
          Free, transparent pricing for <strong>21,000+ medical procedures</strong> and <strong>10,000+ prescription drugs</strong>.
          Compare Medicare, hospital, and surgery center rates across all 50 states.
        </p>
        <form action="/procedures/" method="GET" class="flex gap-3 max-w-xl">
          <input
            type="text"
            name="search"
            placeholder="Search by procedure name or CPT code..."
            class="flex-1 px-5 py-4 rounded-xl text-gray-900 text-lg placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-300 shadow-lg"
          />
          <button
            type="submit"
            class="px-8 py-4 bg-white text-brand-700 font-bold rounded-xl hover:bg-blue-50 transition-colors shadow-lg"
          >
            Search
          </button>
        </form>
        <p class="text-sm text-blue-200 mt-4">
          Examples: "MRI spine", "knee replacement", "99213", "colonoscopy"
        </p>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="bg-white border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-brand-700">{stats?.counts?.procedures?.toLocaleString() || '21,500+'}</div>
          <div class="text-sm text-gray-500">Medical Procedures</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-700">10,000+</div>
          <div class="text-sm text-gray-500">Drug Prices</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-700">109</div>
          <div class="text-sm text-gray-500">Geographic Regions</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-700">17</div>
          <div class="text-sm text-gray-500">Government Data Sources</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Did You Know? Facts -->
  <section class="bg-gradient-to-r from-indigo-50 to-blue-50 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">Did You Know?</h2>
      <p class="text-gray-500 text-center mb-8">Surprising facts about medical costs in America</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {didYouKnowFacts.map(item => (
          <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow text-center">
            <div class="text-3xl mb-3" set:html={item.icon} />
            <p class="text-sm font-medium text-gray-700 leading-snug">{item.fact}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Procedures -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Most Searched Procedure Costs</h2>
    <p class="text-gray-500 mb-8">Total estimated costs including facility fees, anesthesia, and supplies (2026 data)</p>

    <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-4">
      {popularProcedures.map(proc => (
        <a
          href={`/procedures/${proc.code}/`}
          class="block bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-500 hover:shadow-md transition-all group"
        >
          <div class="text-sm text-brand-600 font-mono mb-1">CPT {proc.code}</div>
          <h3 class="font-semibold text-gray-900 group-hover:text-brand-700 mb-2">{proc.name}</h3>
          <div class={`text-lg font-bold ${proc.isSurgical ? 'text-amber-700' : 'text-green-700'}`}>{proc.cost}</div>
          <div class="text-xs text-gray-400 mt-1">{proc.costLabel}</div>
        </a>
      ))}
    </div>

    <div class="text-center mt-8">
      <a href="/procedures/" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-colors">
        Browse All 21,000+ Procedures
        <svg aria-label="Arrow right" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
  </section>

  <!-- Popular Conditions Grid -->
  <section class="bg-white py-16 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Popular Conditions</h2>
      <p class="text-gray-500 mb-8">See the full cost of treatment for common injuries and conditions</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {popularConditions.map(cond => (
          <a
            href={`/conditions/${cond.slug}/`}
            class="flex items-center gap-4 bg-gray-50 rounded-xl p-5 border border-gray-200 hover:border-brand-500 hover:shadow-md transition-all group"
          >
            <div class={`w-12 h-12 rounded-full flex items-center justify-center text-xl flex-shrink-0 ${cond.color}`}>
              <span set:html={cond.icon} />
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 group-hover:text-brand-700">{cond.name}</h3>
              <span class="text-xs text-brand-600">View treatment costs &rarr;</span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/conditions/" class="text-brand-600 font-semibold hover:underline">View all conditions &rarr;</a>
      </div>
    </div>
  </section>

  <!-- How Insurance Affects Your Cost -->
  <section class="py-16 bg-gradient-to-br from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">How Insurance Affects Your Cost</h2>
      <p class="text-gray-500 text-center mb-10">The same procedure can cost wildly different amounts depending on who pays</p>

      <div class="max-w-3xl mx-auto space-y-5">
        <!-- Medicare -->
        <div class="flex items-center gap-4">
          <div class="w-28 sm:w-36 flex-shrink-0 text-right">
            <div class="font-bold text-gray-900">Medicare</div>
            <div class="text-xs text-gray-500">Baseline rate</div>
          </div>
          <div class="flex-1">
            <div class="bg-brand-500 h-10 rounded-lg flex items-center justify-end pr-3 shadow-sm" style="width: 40%">
              <span class="text-white text-sm font-bold">$100</span>
            </div>
          </div>
        </div>
        <!-- Commercial -->
        <div class="flex items-center gap-4">
          <div class="w-28 sm:w-36 flex-shrink-0 text-right">
            <div class="font-bold text-gray-900">Commercial</div>
            <div class="text-xs text-gray-500">Employer plan</div>
          </div>
          <div class="flex-1">
            <div class="bg-orange-500 h-10 rounded-lg flex items-center justify-end pr-3 shadow-sm" style="width: 80%">
              <span class="text-white text-sm font-bold">$200</span>
            </div>
          </div>
        </div>
        <!-- Self-Pay -->
        <div class="flex items-center gap-4">
          <div class="w-28 sm:w-36 flex-shrink-0 text-right">
            <div class="font-bold text-gray-900">Self-Pay</div>
            <div class="text-xs text-gray-500">No insurance</div>
          </div>
          <div class="flex-1">
            <div class="bg-red-500 h-10 rounded-lg flex items-center justify-end pr-3 shadow-sm" style="width: 100%">
              <span class="text-white text-sm font-bold">$250+</span>
            </div>
          </div>
        </div>
      </div>

      <p class="text-center text-sm text-gray-500 mt-6 max-w-xl mx-auto">
        Commercial insurance typically pays 150-250% of Medicare rates. Uninsured patients may face chargemaster prices 3-5x higher.
        <a href="/estimator/" class="text-brand-600 font-semibold hover:underline ml-1">Try our Cost Estimator &rarr;</a>
      </p>
    </div>
  </section>

  <!-- What Will I Pay Calculator CTA -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-emerald-50 to-teal-50 rounded-2xl p-8 md:p-12 border border-emerald-200">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <span class="inline-block px-3 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full uppercase tracking-wide mb-3">New Tool</span>
            <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-4">What Will I Actually Pay?</h2>
            <p class="text-gray-600 mb-4">
              The only calculator that combines <strong>real procedure pricing</strong> with your insurance plan math.
              Enter your deductible, coinsurance, and copay &mdash; or select from 4,044 real ACA marketplace plans &mdash;
              and see your exact out-of-pocket cost.
            </p>
            <ul class="text-sm text-gray-600 space-y-1 mb-6">
              <li class="flex items-center gap-2"><span class="text-emerald-500">&#10003;</span> Add multiple procedures</li>
              <li class="flex items-center gap-2"><span class="text-emerald-500">&#10003;</span> Compare hospital vs surgery center vs office</li>
              <li class="flex items-center gap-2"><span class="text-emerald-500">&#10003;</span> See deductible + coinsurance + copay breakdown</li>
              <li class="flex items-center gap-2"><span class="text-emerald-500">&#10003;</span> 4,044 real ACA plans from healthcare.gov</li>
            </ul>
            <a href="/what-will-i-pay/" class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-700 transition-colors">
              Calculate My Costs
              <svg aria-label="Arrow right" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl p-5 shadow-sm border border-emerald-100">
              <div class="text-sm text-gray-500 mb-1">Avg Bronze Deductible</div>
              <div class="text-2xl font-bold text-amber-600">$7,500</div>
              <div class="text-xs text-gray-400">Your cost before insurance</div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm border border-emerald-100">
              <div class="text-sm text-gray-500 mb-1">2026 OOP Maximum</div>
              <div class="text-2xl font-bold text-emerald-700">$9,450</div>
              <div class="text-xs text-gray-400">ACA individual cap</div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm border border-emerald-100">
              <div class="text-sm text-gray-500 mb-1">ASC Savings</div>
              <div class="text-2xl font-bold text-emerald-700">25-60%</div>
              <div class="text-xs text-gray-400">vs hospital outpatient</div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm border border-emerald-100">
              <div class="text-sm text-gray-500 mb-1">ACA Plans Loaded</div>
              <div class="text-2xl font-bold text-blue-600">4,044</div>
              <div class="text-xs text-gray-400">30 states, 2026 data</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hospital Stay Costs Preview -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-purple-50 to-indigo-50 rounded-2xl p-8 md:p-12 border border-purple-100">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <span class="text-sm font-semibold text-purple-600 uppercase tracking-wide">Hospital Inpatient Data</span>
            <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-4">Hospital Stay Costs</h2>
            <p class="text-gray-600 mb-6">
              Explore costs for 700+ DRG categories using real hospital discharge data. See average charges, costs,
              Medicare payments, and length of stay for everything from heart surgery to childbirth.
            </p>
            <a href="/drg/" class="inline-flex items-center gap-2 px-6 py-3 bg-purple-600 text-white font-semibold rounded-lg hover:bg-purple-700 transition-colors">
              Browse Hospital Stays
              <svg aria-label="Arrow right" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl p-5 shadow-sm border border-purple-100">
              <div class="text-sm text-gray-500 mb-1">Avg Knee Replacement</div>
              <div class="text-2xl font-bold text-purple-700">$22,300</div>
              <div class="text-xs text-gray-400">3.1 day stay</div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm border border-purple-100">
              <div class="text-sm text-gray-500 mb-1">Avg Heart Bypass</div>
              <div class="text-2xl font-bold text-purple-700">$57,800</div>
              <div class="text-xs text-gray-400">9.2 day stay</div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm border border-purple-100">
              <div class="text-sm text-gray-500 mb-1">Avg C-Section</div>
              <div class="text-2xl font-bold text-purple-700">$15,200</div>
              <div class="text-xs text-gray-400">3.5 day stay</div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm border border-purple-100">
              <div class="text-sm text-gray-500 mb-1">Avg Spinal Fusion</div>
              <div class="text-2xl font-bold text-purple-700">$38,600</div>
              <div class="text-xs text-gray-400">3.8 day stay</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="bg-gray-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Browse by Category</h2>
      <p class="text-gray-500 mb-8">Explore costs across medical specialties</p>

      <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-4">
        {topCategories.map(cat => {
          const name = Array.isArray(cat) ? cat[0] : '';
          const count = Array.isArray(cat) ? cat[1] : 0;
          const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          return (
            <a
              href={`/categories/${slug}/`}
              class="bg-white rounded-lg p-4 border border-gray-200 hover:border-brand-500 hover:shadow transition-all"
            >
              <h3 class="font-semibold text-gray-900">{name}</h3>
              <p class="text-sm text-gray-500">{count.toLocaleString()} procedures</p>
            </a>
          );
        })}
      </div>

      <div class="text-center mt-8">
        <a href="/categories/" class="text-brand-600 font-semibold hover:underline">View all categories &rarr;</a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Where Our Data Comes From</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg aria-label="CMS Medicare rates icon" class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">CMS Medicare Rates</h3>
        <p class="text-gray-500 text-sm">Official 2026 Medicare Physician Fee Schedule with relative value units (RVUs) and conversion factor of $33.40 per RVU.</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg aria-label="Hospital rates chart icon" class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">Hospital & Surgery Center Rates</h3>
        <p class="text-gray-500 text-sm">CMS Outpatient Prospective Payment (OPPS) and Ambulatory Surgery Center (ASC) rates for facility-based procedures.</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg aria-label="Geographic location icon" class="w-8 h-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">Geographic Cost Variation</h3>
        <p class="text-gray-500 text-sm">Costs adjusted by CMS Geographic Practice Cost Indices (GPCIs) across 109 Medicare localities in all 50 states.</p>
      </div>
    </div>
  </section>

  <!-- Social Proof / Trust -->
  <section class="bg-brand-700 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="grid sm:grid-cols-3 gap-8 max-w-3xl mx-auto">
        <div>
          <div class="text-4xl font-extrabold">12,000+</div>
          <div class="text-blue-200 text-sm mt-1">Healthcare consumers monthly</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold">50</div>
          <div class="text-blue-200 text-sm mt-1">States covered</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold">100%</div>
          <div class="text-blue-200 text-sm mt-1">Free. No login required.</div>
        </div>
      </div>
      <p class="text-blue-200 text-sm mt-8 max-w-lg mx-auto">
        Trusted by patients, attorneys, researchers, and healthcare professionals for transparent medical cost data.
      </p>
    </div>
  </section>

  <!-- States -->
  <section class="bg-gray-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Medical Costs by State</h2>
      <p class="text-gray-500 mb-8">Healthcare costs vary significantly by location. Find costs in your state.</p>
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
        {STATES.map(state => (
          <a
            href={`/states/${state.code.toLowerCase()}/`}
            class="bg-white rounded-lg px-3 py-2 text-center text-sm font-medium text-gray-700 border border-gray-200 hover:border-brand-500 hover:text-brand-700 transition-colors"
          >
            {state.code}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cost Trends -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">Healthcare Cost Trends</h2>
      <p class="text-gray-500 text-center mb-8">Medicare conversion factor 2018-2026 — years of cuts, then a 2026 recovery</p>

      <div class="max-w-2xl mx-auto bg-gradient-to-br from-gray-50 to-white rounded-2xl border border-gray-200 p-6">
        <svg viewBox="0 0 420 170" class="w-full">
          <!-- Grid -->
          {[cfMin, cfMin + (cfMax - cfMin) * 0.5, cfMax].map(v => (
            <g>
              <line x1="40" x2="400" y1={trendY(v)} y2={trendY(v)} stroke="#e5e7eb" stroke-width="1" />
              <text x="36" y={trendY(v) + 4} text-anchor="end" fill="#9ca3af" font-size="8">${v.toFixed(0)}</text>
            </g>
          ))}
          {cfData.map(d => (
            <text x={trendX(d.year)} y="155" text-anchor="middle" fill="#9ca3af" font-size="8">{d.year}</text>
          ))}
          <!-- Line -->
          <polyline points={trendPoints} fill="none" stroke="#2563eb" stroke-width="2" stroke-linejoin="round" />
          <!-- Dots -->
          {cfData.map(d => (
            <circle cx={trendX(d.year)} cy={trendY(d.value)} r="3"
              fill={d.year === 2026 ? '#16a34a' : d.value < 34 ? '#dc2626' : '#2563eb'} />
          ))}
          <!-- 2026 callout -->
          {cfData.filter(d => d.year === 2026).map(d => (
            <g>
              <text x={trendX(d.year)} y={trendY(d.value) - 8} text-anchor="middle" fill="#16a34a" font-size="9" font-weight="bold">
                ${d.value}
              </text>
            </g>
          ))}
        </svg>
        <div class="flex items-center justify-between mt-4">
          <div class="text-xs text-gray-500">Medicare Conversion Factor ($/RVU) &mdash; Source: CMS PFS</div>
          <a href="/trends/" class="text-sm text-brand-600 font-semibold hover:underline">See full trends &rarr;</a>
        </div>
      </div>

      <div class="grid sm:grid-cols-3 gap-4 mt-8 max-w-2xl mx-auto">
        <div class="bg-red-50 rounded-xl p-4 text-center border border-red-100">
          <div class="text-xl font-bold text-red-600">-10.5%</div>
          <div class="text-xs text-gray-600 mt-1">Medicare CF decline (2020-25)</div>
        </div>
        <div class="bg-orange-50 rounded-xl p-4 text-center border border-orange-100">
          <div class="text-xl font-bold text-orange-600">+32.6%</div>
          <div class="text-xs text-gray-600 mt-1">Medical CPI rise (2015-26)</div>
        </div>
        <div class="bg-green-50 rounded-xl p-4 text-center border border-green-100">
          <div class="text-xl font-bold text-green-600">+3.25%</div>
          <div class="text-xs text-gray-600 mt-1">2026 Medicare CF increase</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-4">Understand Your Medical Costs</h2>
    <p class="text-gray-500 max-w-2xl mx-auto mb-8">
      Whether you're comparing insurance plans, preparing for surgery, or dealing with medical bills after an injury,
      our free tool helps you understand what procedures really cost.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/procedures/" class="px-8 py-4 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition-colors">
        Search Procedures
      </a>
      <a href="/estimator/" class="px-8 py-4 bg-white text-brand-700 font-bold rounded-xl border-2 border-brand-600 hover:bg-brand-50 transition-colors">
        Cost Estimator
      </a>
    </div>
  </section>

  <style>
    .hero-pattern {
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Ccircle cx='30' cy='30' r='1.5'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    @keyframes float {
      0%, 100% { transform: translateY(0) translateX(0); }
      50% { transform: translateY(-30px) translateX(15px); }
    }
    @keyframes float-delayed {
      0%, 100% { transform: translateY(0) translateX(0); }
      50% { transform: translateY(20px) translateX(-20px); }
    }
    .animate-float { animation: float 8s ease-in-out infinite; }
    .animate-float-delayed { animation: float-delayed 10s ease-in-out infinite; }
  </style>
</Base>
