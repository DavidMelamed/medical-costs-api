---
import Base from '@/layouts/Base.astro';
import { getStatistics, getCategories, formatCurrency, STATES } from '@/lib/api';

const stats = await getStatistics();
const { categories } = await getCategories();

const topCategories = (categories || []).slice(0, 12);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "MedicalCosts.info",
  "url": "https://medicalcosts.info",
  "description": "Free medical procedure cost lookup with 21,000+ procedures. Compare Medicare, hospital, and commercial insurance rates nationwide.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://medicalcosts.info/procedures/?search={search_term}",
    "query-input": "required name=search_term"
  }
};

const popularProcedures = [
  { name: 'MRI (Lumbar Spine)', code: '72148', cost: '$85 - $309' },
  { name: 'CT Scan (Head)', code: '70450', cost: '$107 - $195' },
  { name: 'Knee Arthroscopy', code: '29881', cost: '$469' },
  { name: 'Colonoscopy', code: '45378', cost: '$250 - $500' },
  { name: 'ER Visit (High Complexity)', code: '99285', cost: '$171 - $608' },
  { name: 'Physical Therapy (15 min)', code: '97110', cost: '$29 - $32' },
  { name: 'X-Ray (Chest)', code: '71045', cost: '$13 - $36' },
  { name: 'Office Visit (Established)', code: '99213', cost: '$57 - $95' },
  { name: 'ACL Reconstruction', code: '27427', cost: '$663 - $747' },
  { name: 'Spinal Fusion (Lumbar)', code: '22612', cost: '$1,311' },
  { name: 'Hip Replacement', code: '27130', cost: '$1,100+' },
  { name: 'Cataract Surgery', code: '66984', cost: '$500 - $900' },
];
---

<Base
  title="Medical Procedure Costs — Free Cost Lookup for 21,000+ Procedures | MedicalCosts.info"
  description="Compare medical procedure costs with data from CMS Medicare, hospital outpatient, and ambulatory surgery center rates. 21,000+ procedures, drug prices, and geographic cost comparisons."
  canonical="/"
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-700 via-brand-800 to-brand-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          How Much Does Your Medical Procedure Cost?
        </h1>
        <p class="text-xl text-blue-100 mb-8">
          Free, transparent pricing for <strong>21,000+ medical procedures</strong> and <strong>10,000+ prescription drugs</strong>.
          Compare Medicare, hospital, and surgery center rates across all 50 states.
        </p>
        <form action="/procedures/" method="GET" class="flex gap-3 max-w-xl">
          <input
            type="text"
            name="search"
            placeholder="Search by procedure name or CPT code..."
            class="flex-1 px-5 py-4 rounded-xl text-gray-900 text-lg placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-blue-300 shadow-lg"
          />
          <button
            type="submit"
            class="px-8 py-4 bg-white text-brand-700 font-bold rounded-xl hover:bg-blue-50 transition-colors shadow-lg"
          >
            Search
          </button>
        </form>
        <p class="text-sm text-blue-200 mt-4">
          Examples: "MRI spine", "knee replacement", "99213", "colonoscopy"
        </p>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="bg-white border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-brand-700">{stats?.counts?.procedures?.toLocaleString() || '21,500+'}</div>
          <div class="text-sm text-gray-500">Medical Procedures</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-700">10,000+</div>
          <div class="text-sm text-gray-500">Drug Prices</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-700">109</div>
          <div class="text-sm text-gray-500">Geographic Regions</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-700">17</div>
          <div class="text-sm text-gray-500">Government Data Sources</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Procedures -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Most Searched Procedure Costs</h2>
    <p class="text-gray-500 mb-8">Medicare and hospital rates from CMS 2026 fee schedules</p>

    <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-4">
      {popularProcedures.map(proc => (
        <a
          href={`/procedures/${proc.code}/`}
          class="block bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-500 hover:shadow-md transition-all group"
        >
          <div class="text-sm text-brand-600 font-mono mb-1">CPT {proc.code}</div>
          <h3 class="font-semibold text-gray-900 group-hover:text-brand-700 mb-2">{proc.name}</h3>
          <div class="text-lg font-bold text-green-700">{proc.cost}</div>
          <div class="text-xs text-gray-400 mt-1">Medicare rate</div>
        </a>
      ))}
    </div>

    <div class="text-center mt-8">
      <a href="/procedures/" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-colors">
        Browse All 21,000+ Procedures
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
  </section>

  <!-- Categories -->
  <section class="bg-gray-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Browse by Category</h2>
      <p class="text-gray-500 mb-8">Explore costs across medical specialties</p>

      <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-4">
        {topCategories.map(cat => {
          const name = Array.isArray(cat) ? cat[0] : '';
          const count = Array.isArray(cat) ? cat[1] : 0;
          const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          return (
            <a
              href={`/categories/${slug}/`}
              class="bg-white rounded-lg p-4 border border-gray-200 hover:border-brand-500 hover:shadow transition-all"
            >
              <h3 class="font-semibold text-gray-900">{name}</h3>
              <p class="text-sm text-gray-500">{count.toLocaleString()} procedures</p>
            </a>
          );
        })}
      </div>

      <div class="text-center mt-8">
        <a href="/categories/" class="text-brand-600 font-semibold hover:underline">View all categories →</a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Where Our Data Comes From</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">CMS Medicare Rates</h3>
        <p class="text-gray-500 text-sm">Official 2026 Medicare Physician Fee Schedule with relative value units (RVUs) and conversion factor of $33.40 per RVU.</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">Hospital & Surgery Center Rates</h3>
        <p class="text-gray-500 text-sm">CMS Outpatient Prospective Payment (OPPS) and Ambulatory Surgery Center (ASC) rates for facility-based procedures.</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">Geographic Cost Variation</h3>
        <p class="text-gray-500 text-sm">Costs adjusted by CMS Geographic Practice Cost Indices (GPCIs) across 109 Medicare localities in all 50 states.</p>
      </div>
    </div>
  </section>

  <!-- States -->
  <section class="bg-gray-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Medical Costs by State</h2>
      <p class="text-gray-500 mb-8">Healthcare costs vary significantly by location. Find costs in your state.</p>
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
        {STATES.map(state => (
          <a
            href={`/states/${state.code.toLowerCase()}/`}
            class="bg-white rounded-lg px-3 py-2 text-center text-sm font-medium text-gray-700 border border-gray-200 hover:border-brand-500 hover:text-brand-700 transition-colors"
          >
            {state.code}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-4">Understand Your Medical Costs</h2>
    <p class="text-gray-500 max-w-2xl mx-auto mb-8">
      Whether you're comparing insurance plans, preparing for surgery, or dealing with medical bills after an injury,
      our free tool helps you understand what procedures really cost.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/procedures/" class="px-8 py-4 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition-colors">
        Search Procedures
      </a>
      <a href="/estimator/" class="px-8 py-4 bg-white text-brand-700 font-bold rounded-xl border-2 border-brand-600 hover:bg-brand-50 transition-colors">
        Cost Estimator
      </a>
    </div>
  </section>
</Base>
