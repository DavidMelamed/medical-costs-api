---
import '@/styles/global.css';
import CostList from '@/components/CostList.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  noindex?: boolean;
  ogTitle?: string;
  ogPrice?: string;
  ogType?: string;
}

const { title, description, canonical, schema, noindex, ogTitle, ogPrice, ogType } = Astro.props;
const siteUrl = 'https://medical-costs-site.pages.dev';
const apiUrl = 'https://medical-costs-api.david-568.workers.dev';

// Build dynamic OG image URL
const ogParams = new URLSearchParams();
ogParams.set('title', ogTitle || title.replace(/ — MedicalCosts\.info$/, '').substring(0, 60));
if (ogPrice) ogParams.set('price', ogPrice);
if (ogType) ogParams.set('type', ogType);
const ogImageUrl = `${apiUrl}/api/og?${ogParams.toString()}`;
const fullCanonical = canonical ? `${siteUrl}${canonical}` : Astro.url.href;

// Organization schema (sitewide)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "MedicalCosts.info",
  "url": siteUrl,
  "description": "Free, transparent medical cost data powered by CMS Medicare fee schedules, NADAC drug pricing, and hospital discharge data.",
  "sameAs": [],
  "knowsAbout": [
    "Medical procedure costs",
    "Medicare reimbursement rates",
    "Healthcare pricing transparency",
    "Drug pricing",
    "Hospital costs"
  ]
};

// BreadcrumbList schema (sitewide)
const pathSegments = (canonical || Astro.url.pathname).replace(/^\/|\/$/g, '').split('/').filter(Boolean);
const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl + "/" }
];
const segmentLabels: Record<string, string> = {
  procedures: "Procedures",
  categories: "Categories",
  conditions: "Conditions",
  "body-system": "Body Systems",
  drugs: "Drug Prices",
  drg: "Hospital Stays",
  states: "By State",
  estimator: "Cost Estimator",
  "my-costs": "My Costs",
  compare: "Compare Costs",
  mcp: "MCP Server",
  about: "About",
  methodology: "Methodology",
  costs: "Costs",
  trends: "Cost Trends",
  map: "Heat Map",
  hospitals: "Hospitals",
  insurers: "Insurers",
  "bill-checker": "Bill Checker",
  negotiate: "Negotiate Bills",
  letter: "Letter Generator",
  glp1: "GLP-1 Drugs",
  category: "Category",
  "what-will-i-pay": "What Will I Pay?",
  "insurance-guide": "Insurance Guide",
  "car-accident-costs": "Car Accident Costs",
  "who-pays": "Who Pays?",
  "self-pay": "Self-Pay",
  "api-docs": "API Documentation",
  "embed": "Embed Widget",
};
let breadcrumbPath = '';
for (let i = 0; i < pathSegments.length; i++) {
  breadcrumbPath += '/' + pathSegments[i];
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": segmentLabels[pathSegments[i]] || decodeURIComponent(pathSegments[i]).toUpperCase(),
    "item": siteUrl + breadcrumbPath + '/'
  });
}
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2">
            <svg class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-xl font-bold text-gray-900">MedicalCosts<span class="text-brand-600">.info</span></span>
          </a>
          <!-- Desktop nav -->
          <div class="hidden md:flex items-center gap-4 text-sm font-medium text-gray-600">
            <a href="/procedures/" class="hover:text-brand-600 transition-colors">Procedures</a>
            <a href="/categories/" class="hover:text-brand-600 transition-colors">Categories</a>
            <a href="/conditions/" class="hover:text-brand-600 transition-colors">Conditions</a>
            <a href="/drugs/" class="hover:text-brand-600 transition-colors">Drug Prices</a>
            <a href="/drg/" class="hover:text-brand-600 transition-colors">Hospital Stays</a>
            <a href="/hospitals/" class="hover:text-brand-600 transition-colors">Hospitals</a>
            <a href="/states/" class="hover:text-brand-600 transition-colors">By State</a>
            <a href="/estimator/" class="hover:text-brand-600 transition-colors">Estimator</a>
            <a href="/what-will-i-pay/" class="text-emerald-600 font-semibold hover:text-emerald-700 transition-colors">What Will I Pay?</a>
            <a href="/bill-checker/" class="text-green-600 font-semibold hover:text-green-700 transition-colors">Bill Checker</a>
            <a href="/settlement-calculator/" class="text-amber-600 font-semibold hover:text-amber-700 transition-colors">Settlement</a>
            <!-- Search with autocomplete -->
            <div class="relative" id="search-container">
              <input
                id="nav-search"
                type="text"
                placeholder="Search..."
                autocomplete="off"
                class="w-36 lg:w-48 px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-gray-900 placeholder-gray-400"
              />
              <div id="search-dropdown" class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-xl z-50 max-h-96 overflow-y-auto" style="min-width: 320px; right: auto;"></div>
            </div>
          </div>
          <!-- Mobile hamburger button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors"
            aria-label="Open menu"
            aria-expanded="false"
          >
            <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>
      <!-- Mobile slide-down menu -->
      <div id="mobile-menu" class="md:hidden hidden border-t border-gray-200 bg-white">
        <div class="px-4 py-3 space-y-1">
          <a href="/procedures/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Procedures</a>
          <a href="/categories/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Categories</a>
          <a href="/conditions/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Conditions</a>
          <a href="/drugs/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Drug Prices</a>
          <a href="/drg/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Hospital Stays</a>
          <a href="/hospitals/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Hospitals</a>
          <a href="/insurers/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Insurers</a>
          <a href="/states/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">By State</a>
          <a href="/estimator/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Estimator</a>
          <a href="/my-costs/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">My Costs</a>
          <div class="border-t border-gray-100 pt-2 mt-2">
            <a href="/what-will-i-pay/" class="block px-3 py-2.5 rounded-lg text-emerald-600 font-semibold hover:bg-emerald-50 transition-colors">What Will I Pay?</a>
            <a href="/insurance-guide/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Insurance Guide</a>
            <a href="/bill-checker/" class="block px-3 py-2.5 rounded-lg text-green-600 font-semibold hover:bg-green-50 transition-colors">Bill Checker</a>
            <a href="/negotiate/" class="block px-3 py-2.5 rounded-lg text-gray-700 font-medium hover:bg-brand-50 hover:text-brand-700 transition-colors">Negotiate Bills</a>
            <a href="/settlement-calculator/" class="block px-3 py-2.5 rounded-lg text-amber-600 font-semibold hover:bg-amber-50 transition-colors">Settlement Calculator</a>
          </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-gray-900 text-gray-400 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-white font-bold mb-4">MedicalCosts.info</h3>
            <p class="text-sm">Free, transparent medical cost data powered by CMS Medicare fee schedules, NADAC drug pricing, and hospital discharge data.</p>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3 text-sm">Browse Costs</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/procedures/" class="hover:text-white">All Procedures</a></li>
              <li><a href="/categories/" class="hover:text-white">By Category</a></li>
              <li><a href="/conditions/" class="hover:text-white">By Condition</a></li>
              <li><a href="/body-system/" class="hover:text-white">By Body System</a></li>
              <li><a href="/drugs/" class="hover:text-white">Drug Prices</a></li>
              <li><a href="/drugs/glp1/" class="hover:text-white">GLP-1 Drug Costs</a></li>
              <li><a href="/drugs/compare/" class="hover:text-white">Brand vs Generic</a></li>
              <li><a href="/drg/" class="hover:text-white">Hospital Stays</a></li>
              <li><a href="/hospitals/" class="hover:text-white">Hospital Costs</a></li>
              <li><a href="/insurers/" class="hover:text-white">Insurer Report Card</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3 text-sm">Tools & Info</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/what-will-i-pay/" class="hover:text-white">What Will I Pay?</a></li>
              <li><a href="/insurance-guide/" class="hover:text-white">Insurance Guide</a></li>
              <li><a href="/estimator/" class="hover:text-white">Cost Estimator</a></li>
              <li><a href="/my-costs/" class="hover:text-white">My Cost List</a></li>
              <li><a href="/compare/" class="hover:text-white">Compare Costs</a></li>
              <li><a href="/states/" class="hover:text-white">Costs by State</a></li>
              <li><a href="/states/map/" class="hover:text-white">US Cost Heat Map</a></li>
              <li><a href="/trends/" class="hover:text-white">Cost Trends</a></li>
              <li><a href="/car-accident-costs/" class="hover:text-white">Car Accident Costs</a></li>
              <li><a href="/bill-checker/" class="hover:text-white">Bill Checker</a></li>
              <li><a href="/negotiate/" class="hover:text-white">Negotiate Bills</a></li>
              <li><a href="/about/" class="hover:text-white">About</a></li>
              <li><a href="/methodology/" class="hover:text-white">Methodology</a></li>
              <li><a href="/api-docs/" class="hover:text-white">API Docs</a></li>
              <li><a href="/embed/" class="hover:text-white">Embed Widget</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3 text-sm">Data Sources</h4>
            <ul class="space-y-2 text-sm">
              <li>CMS Medicare Fee Schedule 2026</li>
              <li>CMS OPPS / ASC Rates</li>
              <li>NADAC Drug Acquisition Costs</li>
              <li>NY SPARCS Hospital Data</li>
              <li>CDC / NHTSA Cost Studies</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-xs text-gray-500">
          <p>Cost estimates are based on publicly available Medicare reimbursement rates and may not reflect actual costs. Commercial insurance rates typically range from 150-250% of Medicare rates. This site is for informational purposes only and is not medical or financial advice.</p>
          <p class="mt-2">Data: CMS PFS CY2026 (CF $33.40), CMS CLFS, CMS OPPS, CMS ASC, CMS DMEPOS, NADAC, NHTSA, CDC WISQARS, NSCISC, NY SPARCS.</p>
        </div>
      </div>
    </footer>

    <CostList />

    <!-- Cloudflare Web Analytics (free, privacy-friendly, no cookies) -->
    <!-- To activate: Replace TOKEN with your Cloudflare Web Analytics site token.
         Get it from: Cloudflare Dashboard > Analytics & Logs > Web Analytics > Add a site -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "PLACEHOLDER_CF_WEB_ANALYTICS_TOKEN"}'></script>

    <script>
      // Mobile menu toggle
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('menu-icon-open');
      const iconClose = document.getElementById('menu-icon-close');

      if (btn && menu && iconOpen && iconClose) {
        btn.addEventListener('click', () => {
          const isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          iconOpen.classList.toggle('hidden');
          iconClose.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', String(!isOpen));
        });
      }

      // Search autocomplete
      (function() {
        var input = document.getElementById('nav-search') as HTMLInputElement | null;
        var dropdown = document.getElementById('search-dropdown');
        if (!input || !dropdown) return;

        var debounceTimer: ReturnType<typeof setTimeout> | null = null;
        var API_URL = 'https://medical-costs-api.david-568.workers.dev/api/search';

        function fmt(n: number | null) {
          if (!n) return '';
          return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
        }

        function renderResults(data: any) {
          if (!dropdown) return;
          var html = '';
          var procs = (data.procedures || []).slice(0, 4);
          var conds = (data.conditions || []).slice(0, 2);
          var drugs = (data.drugs || []).slice(0, 2);

          if (procs.length === 0 && conds.length === 0 && drugs.length === 0) {
            dropdown.innerHTML = '<div class="px-4 py-3 text-sm text-gray-500">No results found</div>';
            dropdown.classList.remove('hidden');
            return;
          }

          if (procs.length > 0) {
            html += '<div class="px-3 py-1.5 text-xs font-semibold text-gray-400 uppercase bg-gray-50">Procedures</div>';
            for (var i = 0; i < procs.length; i++) {
              var p = procs[i];
              var href = p.slug ? '/procedures/' + p.slug + '/' : '/procedures/' + p.code + '/';
              var name = p.consumerName || p.description;
              html += '<a href="' + href + '" class="block px-4 py-2 hover:bg-brand-50 transition-colors border-b border-gray-50">' +
                '<div class="text-sm font-medium text-gray-900 truncate">' + name + '</div>' +
                '<div class="flex items-center gap-2 text-xs text-gray-500">' +
                  '<span class="font-mono">CPT ' + p.code + '</span>' +
                  (p.nationalFacilityRate ? '<span class="text-green-700 font-semibold">' + fmt(p.nationalFacilityRate) + '</span>' : '') +
                '</div></a>';
            }
          }

          if (conds.length > 0) {
            html += '<div class="px-3 py-1.5 text-xs font-semibold text-gray-400 uppercase bg-gray-50">Conditions</div>';
            for (var j = 0; j < conds.length; j++) {
              var c = conds[j];
              html += '<a href="/conditions/' + c.slug + '/" class="block px-4 py-2 hover:bg-brand-50 transition-colors border-b border-gray-50">' +
                '<div class="text-sm font-medium text-gray-900">' + c.name + '</div>' +
                '<div class="text-xs text-gray-500">' + (c.bodyRegion || 'Condition') + '</div></a>';
            }
          }

          if (drugs.length > 0) {
            html += '<div class="px-3 py-1.5 text-xs font-semibold text-gray-400 uppercase bg-gray-50">Drugs</div>';
            for (var k = 0; k < drugs.length; k++) {
              var d = drugs[k];
              var dhref = d.slug ? '/drugs/' + d.slug + '/' : '/drugs/' + d.code + '/';
              html += '<a href="' + dhref + '" class="block px-4 py-2 hover:bg-brand-50 transition-colors border-b border-gray-50">' +
                '<div class="text-sm font-medium text-gray-900 truncate">' + (d.consumerName || d.description) + '</div>' +
                '<div class="text-xs text-gray-500 font-mono">' + d.code + '</div></a>';
            }
          }

          dropdown.innerHTML = html;
          dropdown.classList.remove('hidden');
        }

        input.addEventListener('input', function() {
          var q = (input as HTMLInputElement).value.trim();
          if (debounceTimer) clearTimeout(debounceTimer);
          if (q.length < 2) {
            if (dropdown) dropdown.classList.add('hidden');
            return;
          }
          debounceTimer = setTimeout(function() {
            fetch(API_URL + '?q=' + encodeURIComponent(q) + '&limit=8')
              .then(function(r) { return r.json(); })
              .then(function(json) {
                if (json.success) renderResults(json.data);
              })
              .catch(function() {});
          }, 300);
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
          var container = document.getElementById('search-container');
          if (container && !container.contains(e.target as Node)) {
            if (dropdown) dropdown.classList.add('hidden');
          }
        });

        // Navigate on Enter
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && dropdown) {
            dropdown.classList.add('hidden');
          }
        });
      })();
    </script>
  </body>
</html>
