---
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  noindex?: boolean;
}

const { title, description, canonical, schema, noindex } = Astro.props;
const siteUrl = 'https://medicalcosts.info';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body>
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2">
            <svg class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-xl font-bold text-gray-900">MedicalCosts<span class="text-brand-600">.info</span></span>
          </a>
          <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
            <a href="/procedures/" class="hover:text-brand-600 transition-colors">Procedures</a>
            <a href="/categories/" class="hover:text-brand-600 transition-colors">Categories</a>
            <a href="/conditions/" class="hover:text-brand-600 transition-colors">Conditions</a>
            <a href="/drugs/" class="hover:text-brand-600 transition-colors">Drug Prices</a>
            <a href="/drg/" class="hover:text-brand-600 transition-colors">Hospital Stays</a>
            <a href="/states/" class="hover:text-brand-600 transition-colors">By State</a>
            <a href="/estimator/" class="hover:text-brand-600 transition-colors">Estimator</a>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-gray-900 text-gray-400 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-white font-bold mb-4">MedicalCosts.info</h3>
            <p class="text-sm">Free, transparent medical cost data powered by CMS Medicare fee schedules, NADAC drug pricing, and hospital discharge data.</p>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3 text-sm">Browse Costs</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/procedures/" class="hover:text-white">All Procedures</a></li>
              <li><a href="/categories/" class="hover:text-white">By Category</a></li>
              <li><a href="/conditions/" class="hover:text-white">By Condition</a></li>
              <li><a href="/drugs/" class="hover:text-white">Drug Prices</a></li>
              <li><a href="/drg/" class="hover:text-white">Hospital Stays</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3 text-sm">Tools</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/estimator/" class="hover:text-white">Cost Estimator</a></li>
              <li><a href="/compare/" class="hover:text-white">Compare Costs</a></li>
              <li><a href="/states/" class="hover:text-white">Costs by State</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3 text-sm">Data Sources</h4>
            <ul class="space-y-2 text-sm">
              <li>CMS Medicare Fee Schedule 2026</li>
              <li>CMS OPPS / ASC Rates</li>
              <li>NADAC Drug Acquisition Costs</li>
              <li>NY SPARCS Hospital Data</li>
              <li>CDC / NHTSA Cost Studies</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-xs text-gray-500">
          <p>Cost estimates are based on publicly available Medicare reimbursement rates and may not reflect actual costs. Commercial insurance rates typically range from 150-250% of Medicare rates. This site is for informational purposes only and is not medical or financial advice.</p>
          <p class="mt-2">Data: CMS PFS CY2026 (CF $33.40), CMS CLFS, CMS OPPS, CMS ASC, CMS DMEPOS, NADAC, NHTSA, CDC WISQARS, NSCISC, NY SPARCS.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
