---
// CostList.astro — Sticky "My Cost List" sidebar component
// Included in Base layout, appears on every page
// Uses vanilla JS + localStorage for persistence
// API URL is injected via window.__MEDICAL_COSTS_API__ from Base layout
---

<!-- Floating toggle button (bottom-right) -->
<button
  id="cost-list-toggle"
  class="fixed bottom-6 right-6 z-[60] bg-brand-600 text-white w-14 h-14 rounded-full shadow-lg hover:bg-brand-700 transition-all flex items-center justify-center group"
  aria-label="Open cost list"
  style="display:none;"
>
  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
  </svg>
  <span id="cost-list-badge" class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center hidden">0</span>
</button>

<!-- Slide-out panel -->
<div
  id="cost-list-panel"
  class="fixed top-0 right-0 z-[70] h-full w-full sm:w-96 bg-white shadow-2xl border-l border-gray-200 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col"
>
  <!-- Header -->
  <div class="px-6 py-4 border-b border-gray-200 bg-brand-50 flex items-center justify-between flex-shrink-0">
    <div>
      <h2 class="text-lg font-bold text-gray-900">My Cost List</h2>
      <p id="cost-list-count" class="text-xs text-gray-500">0 procedures</p>
    </div>
    <button id="cost-list-close" class="p-2 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Items list (scrollable) -->
  <div id="cost-list-items" class="flex-1 overflow-y-auto px-4 py-4 space-y-3">
    <div id="cost-list-empty" class="text-center py-12 text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
      <p class="text-sm font-medium">No procedures added yet</p>
      <p class="text-xs mt-1">Click "Add to My List" on any procedure to start building your estimate.</p>
    </div>
  </div>

  <!-- Totals footer -->
  <div id="cost-list-footer" class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex-shrink-0 hidden">
    <div class="space-y-2 mb-4">
      <div class="flex justify-between text-sm">
        <span class="text-gray-500">Medicare Total</span>
        <span id="cost-list-medicare" class="font-bold text-brand-700">$0</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-gray-500">Est. Commercial (Low)</span>
        <span id="cost-list-comm-low" class="font-semibold text-gray-900">$0</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-gray-500">Est. Commercial (High)</span>
        <span id="cost-list-comm-high" class="font-semibold text-orange-700">$0</span>
      </div>
    </div>
    <div class="flex gap-2">
      <a id="cost-list-view-full" href="/my-costs/" class="flex-1 px-4 py-2.5 bg-brand-600 text-white text-sm font-medium rounded-lg hover:bg-brand-700 text-center transition-colors">
        View Full Estimate
      </a>
      <button id="cost-list-clear" class="px-4 py-2.5 bg-white border border-gray-300 text-sm font-medium rounded-lg hover:bg-gray-50 text-red-600 transition-colors">
        Clear All
      </button>
    </div>
  </div>
</div>

<!-- Backdrop -->
<div id="cost-list-backdrop" class="fixed inset-0 bg-black/30 z-[65] hidden"></div>

<script>
  // ============================================================
  // MedicalCosts Global Cost List — vanilla JS, localStorage
  // ============================================================
  (function() {
    const STORAGE_KEY = 'medcosts_my_list';
    const API_BASE = (window.__MEDICAL_COSTS_API__ || 'https://medical-costs-api.david-568.workers.dev') + '/api';

    // ---- State ----
    function getItems() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch { return []; }
    }
    function setItems(items) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      render();
      window.dispatchEvent(new CustomEvent('costlist:updated', { detail: { items } }));
    }

    // ---- Public API (on window) ----
    window.CostList = {
      add(code, name, medicareRate) {
        const items = getItems();
        if (items.find(i => i.code === code)) {
          // already in list — open panel as feedback
          openPanel();
          return false;
        }
        items.push({ code, name, medicareRate: Number(medicareRate) || 0 });
        setItems(items);
        openPanel();
        return true;
      },
      remove(code) {
        setItems(getItems().filter(i => i.code !== code));
      },
      clear() {
        setItems([]);
      },
      getItems,
      has(code) {
        return getItems().some(i => i.code === code);
      },
      getTotal() {
        const items = getItems();
        const medicare = items.reduce((s, i) => s + (i.medicareRate || 0), 0);
        return { medicare, commercialLow: medicare * 1.5, commercialHigh: medicare * 2.5 };
      },
      addBundle(procedures) {
        // procedures: Array<{code, name, medicareRate}>
        const items = getItems();
        let added = 0;
        procedures.forEach(p => {
          if (!items.find(i => i.code === p.code)) {
            items.push({ code: p.code, name: p.name, medicareRate: Number(p.medicareRate) || 0 });
            added++;
          }
        });
        if (added > 0) setItems(items);
        openPanel();
        return added;
      }
    };

    // ---- DOM refs ----
    const toggleBtn = document.getElementById('cost-list-toggle');
    const badge = document.getElementById('cost-list-badge');
    const panel = document.getElementById('cost-list-panel');
    const closeBtn = document.getElementById('cost-list-close');
    const backdrop = document.getElementById('cost-list-backdrop');
    const itemsContainer = document.getElementById('cost-list-items');
    const emptyMsg = document.getElementById('cost-list-empty');
    const footer = document.getElementById('cost-list-footer');
    const countEl = document.getElementById('cost-list-count');
    const medicareEl = document.getElementById('cost-list-medicare');
    const commLowEl = document.getElementById('cost-list-comm-low');
    const commHighEl = document.getElementById('cost-list-comm-high');
    const clearBtn = document.getElementById('cost-list-clear');

    function fmt(n) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    function openPanel() {
      panel.classList.remove('translate-x-full');
      backdrop.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closePanel() {
      panel.classList.add('translate-x-full');
      backdrop.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // ---- Render ----
    function render() {
      const items = getItems();
      const count = items.length;

      // Toggle button visibility
      toggleBtn.style.display = count > 0 ? 'flex' : 'none';

      // Badge
      if (count > 0) {
        badge.classList.remove('hidden');
        badge.textContent = count;
      } else {
        badge.classList.add('hidden');
      }

      // Count text
      countEl.textContent = `${count} procedure${count !== 1 ? 's' : ''}`;

      // Empty state vs items
      if (count === 0) {
        emptyMsg.style.display = '';
        footer.classList.add('hidden');
        // Remove all item cards
        itemsContainer.querySelectorAll('.cost-list-item').forEach(el => el.remove());
      } else {
        emptyMsg.style.display = 'none';
        footer.classList.remove('hidden');

        // Rebuild items
        const existingCards = itemsContainer.querySelectorAll('.cost-list-item');
        existingCards.forEach(el => el.remove());

        items.forEach(item => {
          const div = document.createElement('div');
          div.className = 'cost-list-item bg-white rounded-lg border border-gray-200 p-3 flex items-start justify-between gap-2';
          div.innerHTML = `
            <div class="flex-1 min-w-0">
              <a href="/costs/${item.code}/" class="text-sm font-medium text-brand-600 hover:underline block truncate">${item.name}</a>
              <div class="text-xs text-gray-400 mt-0.5">CPT ${item.code}</div>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <span class="text-sm font-semibold text-gray-900">${item.medicareRate > 0 ? fmt(item.medicareRate) : 'N/A'}</span>
              <button class="cost-list-remove text-gray-400 hover:text-red-500 transition-colors" data-code="${item.code}" aria-label="Remove">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
            </div>
          `;
          itemsContainer.appendChild(div);
        });

        // Totals
        const totals = window.CostList.getTotal();
        medicareEl.textContent = fmt(totals.medicare);
        commLowEl.textContent = fmt(totals.commercialLow);
        commHighEl.textContent = fmt(totals.commercialHigh);
      }

      // Update all "Add to My List" buttons on the page
      document.querySelectorAll('[data-add-to-list]').forEach(btn => {
        const code = btn.getAttribute('data-add-to-list');
        if (window.CostList.has(code)) {
          btn.innerHTML = '<svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Added';
          btn.classList.add('bg-green-100', 'text-green-700', 'border-green-300');
          btn.classList.remove('bg-brand-50', 'text-brand-700', 'border-brand-200', 'hover:bg-brand-100');
        } else {
          btn.innerHTML = '<svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Add to My List';
          btn.classList.remove('bg-green-100', 'text-green-700', 'border-green-300');
          btn.classList.add('bg-brand-50', 'text-brand-700', 'border-brand-200', 'hover:bg-brand-100');
        }
      });
    }

    // ---- Event listeners ----
    toggleBtn.addEventListener('click', openPanel);
    closeBtn.addEventListener('click', closePanel);
    backdrop.addEventListener('click', closePanel);

    clearBtn.addEventListener('click', () => {
      if (confirm('Remove all procedures from your cost list?')) {
        window.CostList.clear();
        closePanel();
      }
    });

    // Delegate remove button clicks
    itemsContainer.addEventListener('click', (e) => {
      const btn = e.target.closest('.cost-list-remove');
      if (btn) {
        window.CostList.remove(btn.dataset.code);
      }
    });

    // Delegate "Add to My List" button clicks across the page
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-add-to-list]');
      if (btn) {
        e.preventDefault();
        const code = btn.getAttribute('data-add-to-list');
        const name = btn.getAttribute('data-name');
        const rate = parseFloat(btn.getAttribute('data-rate') || '0');
        if (window.CostList.has(code)) {
          window.CostList.remove(code);
        } else {
          window.CostList.add(code, name, rate);
        }
      }
    });

    // Keyboard: Escape closes panel
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.classList.contains('translate-x-full')) {
        closePanel();
      }
    });

    // Initial render
    render();
  })();
</script>
